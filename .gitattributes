# Auto-detect text files, normalize to LF
* text=auto eol=lf

# C# source
*.cs text diff=csharp
*.csproj text
*.sln text

# Web
*.html text diff=html
*.css text diff=css
*.js text eol=lf
*.ts text
*.json text

# Markdown / docs
*.md text diff=markdown
*.yml text
*.yaml text

# Shell scripts
*.sh text eol=lf

# Images (binary)
*.png binary
*.jpg binary
*.svg text
*.ico binary

# Archives
*.zip binary
*.gz binary

# Binaries
*.so binary
