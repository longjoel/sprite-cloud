# gv-web VPS production environment
# Copy to /docker/gv-web/.env and fill in real values.
#
# Secrets (never commit these):
#   AUTH_SECRET         — NextAuth session encryption key
#   DATABASE_URL        — includes DB password
#
# The rest of these are non-secret wiring values that
# change between deployments.

# ── Public web origin ────────────────────────────────────────
AUTH_SECRET=generate-a-random-64-char-string
AUTH_URL=https://your-domain.com
NEXTAUTH_URL=https://your-domain.com
APP_BASE_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Database (host-networked gv-web + postgres on 5432) ──────
DATABASE_URL=postgresql://games_vault:***@127.0.0.1:5432/games_vault

# ── ICE / WebRTC (for worker signalling) ─────────────────────
GV_ICE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
GV_ICE_TURN_URLS=turn:your-turn-host:3478
GV_ICE_TURN_USERNAME=gv
GV_ICE_TURN_CREDENTIAL=YOUR_TURN_PASSWORD
