# Sprite Cloud host environment
# Copy to /etc/sprite-cloud.env and fill in real values.
# This file is consumed by EnvironmentFile in gv-server.service.

# ── Core directories ─────────────────────────────────────────
GV_CORES_DIR=/var/lib/sprite-cloud/cores
RUST_LOG=info

# ── ICE / WebRTC ─────────────────────────────────────────────
GV_ICE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
GV_ICE_TURN_URLS=turn:your-turn-host:3478?transport=udp
GV_ICE_TURN_USERNAME=gv
GV_ICE_TURN_CREDENTIAL=YOUR_TURN_PASSWORD

# ── gv-web connection ────────────────────────────────────────
# Set if the worker needs a specific URL for gv-web (overrides
# the URL the server was paired with)
# GV_WEB_URL=https://your-web-host.com
