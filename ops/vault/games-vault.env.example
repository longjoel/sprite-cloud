# Games Vault host environment
# Copy to /etc/games-vault.env and fill in real values.

GV_CORES_DIR=/var/lib/games-vault/cores
RUST_LOG=info

GV_ICE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
GV_ICE_TURN_URLS=turn:YOUR_TURN_HOST:3478
GV_ICE_TURN_USERNAME=YOUR_TURN_USER
GV_ICE_TURN_CREDENTIAL=YOUR_TURN_PASSWORD
