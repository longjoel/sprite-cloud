{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=games-vault.db;Cache=Shared;Pooling=True;Default Timeout=10"
  },
  "LibretroDatabase": {
    "RootPath": "App_Data/libretro-database",
    "ZipUrl": "https://github.com/libretro/libretro-database/archive/refs/heads/master.zip"
  },
  "Library": {
    "RootPath": "App_Data/library"
  },
  "WebPlayer": {
    "Enabled": true,
    "BasePath": "/webplayer",
    "AutoInstall": true,
    "RetroArchZipUrl": "https://buildbot.libretro.com/nightly/emscripten/RetroArch.7z",
    "SystemCores": {
      "Nintendo - Nintendo Entertainment System": "fceumm"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
