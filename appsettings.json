{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/var/lib/games-vault/games-vault.db;Cache=Shared;Pooling=True;Default Timeout=10"
  },
  "LibretroDatabase": {
    "RootPath": "/srv/storage/games-vault/App_Data/libretro-database",
    "ZipUrl": "https://github.com/libretro/libretro-database/archive/refs/heads/master.zip"
  },
  "Library": {
    "RootPath": "/srv/storage/games",
    "UploadStagingRootPath": "/srv/storage/games-vault/uploads"
  },
  "Nosebleed": {
    "Enabled": false,
    "BinaryPath": "/opt/nosebleed/nosebleed",
    "PublicScheme": "http",
    "PublicHost": "192.168.86.126",
    "BaseListenPort": 8100,
    "MaxSessions": 4,
    "MaxPlayersPerSession": 4,
    "SeatTtlMinutes": 30,
    "SessionRoot": "/srv/storage/games-vault/nosebleed/sessions",
    "CoreRoot": "/srv/storage/games-vault/nosebleed/cores",
    "CoreBuildbotBaseUrl": "https://buildbot.libretro.com/nightly/linux/x86_64/latest",
    "AutoInstallKnownCores": true,
    "RequireAuth": true,
    "AuthSecretPath": "/var/lib/games-vault/nosebleed-auth-secret",
    "CopyContentToSession": true,
    "SystemCores": {
      "Sega - Game Gear": "genesis_plus_gx_libretro.so",
      "Nintendo - Nintendo Entertainment System": "fceumm_libretro.so"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
