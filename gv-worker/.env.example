# gv-worker environment variables
# See gv-worker/src/config.rs for defaults and descriptions.

# Path to the libretro core shared library (.so)
GV_CORE_PATH=/srv/storage/games/cores/nestopia_libretro.so

# Path to the game ROM file to load
GV_CONTENT_PATH=/srv/storage/media/roms/game.nes

# Directory for save files (SRAM, save states)
GV_SAVE_DIR=/srv/storage/games/saves/

# Directory for system/BIOS files
GV_SYSTEM_DIR=/srv/storage/games/system/

# Host token for DataChannel auth (first SDP offer with this token gets full permissions)
GV_HOST_TOKEN=

# IP address to bind the HTTP server to (default: 127.0.0.1)
GV_BIND_ADDR=127.0.0.1

# VP8 encoder target bitrate in kbps (default: 500)
TARGET_BITRATE_KBPS=500

# STUN/TURN server for WebRTC NAT traversal (default: stun:stun.l.google.com:19302)
STUN_SERVER=stun:stun.l.google.com:19302

# CORS allowed origins (comma-separated). Set in production to your gv-web URL.
ALLOWED_ORIGIN=http://localhost:3001
