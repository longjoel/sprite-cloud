# PostgreSQL password (required)
POSTGRES_PASSWORD=change-me

# Public address (required for WebRTC outside localhost)
# Examples: scheme=https host=gv.example.com   or   scheme=http host=192.168.1.100
GV_NOSEBLEED_PUBLIC_SCHEME=http
GV_NOSEBLEED_PUBLIC_HOST=127.0.0.1

# TURN server secret (optional — empty = STUN-only connections)
GV_NOSEBLEED_TURN_SECRET=

# Path to game ROM files on the Docker host
# GV_LIBRARY_ROOT=/srv/storage/games
