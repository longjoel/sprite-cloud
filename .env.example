# ──────────────────────────────────────────────────────────────────────────────
# Games Vault — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Single source of truth for all env vars used by gv-web, gv-server, and gv-worker.
# Copy this to a .env file or export in your shell before running.
#
# Sections:
#   1. gv-web (Next.js) — Auth & Database
#   2. gv-server — Server config & core management
#   3. gv-worker — Emulator runtime
#   4. ICE / WebRTC — STUN/TURN (gv-worker + gv-web)
#   5. Video / Audio pipeline
#   6. CORS
#   7. Dev / Debug
# ──────────────────────────────────────────────────────────────────────────────

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  1. gv-web (Next.js) — Auth & Database                                     ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── NextAuth ──────────────────────────────────────────────────────────────

# Secret used by NextAuth to encrypt JWTs and session cookies.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth application credentials.
# Create at https://github.com/settings/developers
# Required — sign-in won't work without these.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# LAN-only credentials (optional — enables a side door for trusted networks).
# When set, anyone on a LAN IP (192.168.*, 10.*, 172.16-31.*, 127.*) can
# sign in with these credentials without going through GitHub OAuth.
# The user gets a synthetic account with id=lan-user — no DB row needed.
# Leave empty to disable LAN auth entirely.
LAN_USER=
LAN_PASS=

# ── Database ──────────────────────────────────────────────────────────────

# PostgreSQL connection string for gv-web (Next.js server).
# Used by Drizzle ORM and NextAuth adapter.
# Example: postgresql://user:***@localhost:5432/games_vault
DATABASE_URL=postgresql://localhost:5432/games_vault

# ── Dev dashboard ─────────────────────────────────────────────────────────

# API key for the paired dev server (see /dev route).
# Set this to restrict access to the dev dashboard.
SERVER_API_KEY=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  2. gv-server — Server config & core management                            ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Path to the gv-worker binary.
# Resolution order: config.toml `gv_web.worker_bin` > this env var > auto-detect
# Auto-detect tries: ./target/release/gv-worker-v2 → ./target/debug/gv-worker-v2
GV_WORKER_BIN=

# Hostname used in the worker connect URL sent to the browser.
# Default: auto-detected LAN IP (falls back to localhost).
GV_WORKER_HOST=

# HTTP request timeout for gv-web API calls in seconds (default: 30).
GV_WEB_TIMEOUT_SECS=

# Source URL for automatic libretro core downloads.
# Default: https://buildbot.libretro.com/nightly/linux/x86_64/latest
GV_BUILDBOT_URL=

# Directory where downloaded libretro cores are cached.
# Default: <workspace>/test-data/cores/ → <workspace>/cores/
GV_CORES_DIR=

# ── Core overrides ────────────────────────────────────────────────────────

# Override the default core for any platform by setting
# GV_CORE_OVERRIDE_<sanitized_name>. Sanitize: spaces → _, hyphens → _.
#
# Default mappings (27 platforms):
#   NES / Family Computer Disk System → nestopia_libretro.so
#   SNES                              → snes9x_libretro.so
#   Game Boy / Game Boy Color         → mgba_libretro.so
#   Game Boy Advance                  → mgba_libretro.so
#   Nintendo 64                       → mupen64plus_next_libretro.so
#   Nintendo DS                       → desmume_libretro.so
#   Virtual Boy                       → mednafen_vb_libretro.so
#   Pokemon Mini                      → pokemini_libretro.so
#   Genesis / Master System           → genesis_plus_gx_libretro.so
#   Game Gear / Sega CD               → genesis_plus_gx_libretro.so
#   Sega 32X                          → picodrive_libretro.so
#   Saturn                            → yabause_libretro.so
#   Dreamcast                         → flycast_libretro.so
#   PlayStation                       → pcsx_rearmed_libretro.so
#   PlayStation Portable / PSP        → ppsspp_libretro.so
#   Atari 2600                        → stella_libretro.so
#   Atari 5200                        → a5200_libretro.so
#   Atari 7800                        → prosystem_libretro.so
#   Atari Lynx                        → handy_libretro.so
#   PC Engine / TurboGrafx-16 / CD    → mednafen_pce_fast_libretro.so
#   Neo Geo Pocket / Color            → mednafen_ngp_libretro.so
#   Neo Geo CD                        → neocd_libretro.so
#   WonderSwan / Color                → mednafen_wswan_libretro.so
#   Arcade (FB Neo)                   → fbneo_libretro.so
#
# Override examples:
#   GV_CORE_OVERRIDE_PlayStation=swanstation_libretro.so
#   GV_CORE_OVERRIDE_Saturn=mednafen_saturn_libretro.so
#   GV_CORE_OVERRIDE_Arcade=mame2003_plus_libretro.so

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  3. gv-worker — Emulator runtime                                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Path to the libretro core shared library (.so).
# Falls back to the built-in 2048 test core when not set.
GV_CORE_PATH=/srv/storage/games/cores/nestopia_libretro.so

# Path to the game ROM file to load.
# When not set, the worker uses the test-pattern fallback (no ROM loaded).
GV_CONTENT_PATH=/srv/storage/media/roms/game.nes

# Directory for save files (SRAM, save states).
# Each ROM gets a stable subdirectory derived from its content hash.
# Default: /tmp
GV_SAVE_DIR=/srv/storage/games/saves/

# Directory for system/BIOS files (required by some cores).
# Default: /tmp
GV_SYSTEM_DIR=/srv/storage/games/system/

# Number of audio channels in the Opus stream.
# 1 = mono, 2 = stereo (default).
GV_AUDIO_CHANNELS=2

# Host token for DataChannel auth.
# The first SDP offer carrying this token gets full host permissions.
# When set from the environment, SDP offers cannot overwrite it.
GV_HOST_TOKEN=

# IP address to bind the HTTP server to.
# Default: 127.0.0.1 (loopback — gv-worker is internal-only).
# Set to 0.0.0.0 for direct dev access from other machines.
GV_BIND_ADDR=127.0.0.1

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  4. ICE / WebRTC — STUN/TURN (gv-worker + gv-web)                          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# DEPRECATED: Use GV_ICE_STUN_URLS and GV_ICE_TURN_URLS instead.
# Kept for backward compatibility with existing configs.
# Format: "stun:host:port" or "turn:host:port?transport=tcp"
# Default: stun:stun.l.google.com:19302
STUN_SERVER=

# Comma-separated STUN server URLs for WebRTC.
# Default (when empty): stun:stun.l.google.com:19302
GV_ICE_STUN_URLS=

# Comma-separated TURN server URLs for WebRTC relay.
# VPS TURN relay: turn:72.62.243.69:3478?transport=udp
GV_ICE_TURN_URLS=

# TURN authentication credentials.
# Must both be set or both empty.
# VPS TURN credentials (user: nosebleed)
GV_ICE_TURN_USERNAME=
GV_ICE_TURN_CREDENTIAL=

# ICE transport policy: "all" (default) | "relay" (forces relay-only).
GV_ICE_TRANSPORT_POLICY=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  5. Video / Audio pipeline (GStreamer)                                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── GStreamer video encoder (worker-v2) ────────────────────────────────────

# VP8 encoder speed (0–16, lower = better quality, slower).
# Default: 4
GV_GST_VIDEO_CPU_USED=4

# VP8 encoder threads (0 = auto).
# Default: 4
GV_GST_VIDEO_THREADS=4

# Target bitrate in kbps.
# Default: 2000
GV_GST_VIDEO_BITRATE_KBPS=2000

# Encoder deadline: 0 (best quality) | 1 (realtime).
# Default: 1
GV_GST_VIDEO_DEADLINE=1

# Integer scaling target height (nearest-neighbor).
# Core output is integer-scaled up to at least this height before encoding.
# 0 = off (passthrough). e.g. 1080 → NES 240p → 4× → 960p.
# Default: 0
GV_GST_VIDEO_SCALE_HEIGHT=0

# Maximum integer scale factor. Prevents excessive upscaling that
# overwhelms the VP8 encoder at low bitrates (Genesis 5×, GB 7×).
# Default: 4
GV_GST_VIDEO_MAX_SCALE=4

# Keyframe max distance in frames.
# Default: 150
GV_GST_VIDEO_KEYFRAME_MAX_DIST=150

# ── GStreamer audio encoder (worker-v2) ────────────────────────────────────

# Opus bitrate in bps.
# Default: 64000
GV_GST_AUDIO_BITRATE=64000

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  6. CORS                                                                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Comma-separated list of allowed origins for CORS on the gv-worker HTTP server.
# Set this in production to your gv-web URL (e.g. "https://games.example.com").
# In dev (not set), allows localhost:3000, localhost:3001, vault.local:8080,
# and auto-detected LAN IP on ports 3000, 3001, 8080.
ALLOWED_ORIGIN=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  7. Dev / Debug                                                            ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# DataChannel auth timeout in seconds.
# How long the DataChannel has to send an auth message after opening.
# Default: 5
DC_AUTH_TIMEOUT_SECS=5
