# Copy to .env and edit values before running `docker compose up -d`

# Required
POSTGRES_PASSWORD=change-me
GV_LIBRARY_ROOT=/srv/storage/games
GV_NOSEBLEED_ENABLED=false
GV_NOSEBLEED_PUBLIC_HOST=localhost
GV_PUBLIC_URL=http://localhost:8080

# Optional overrides: Unset GV_LIBRARY_ROOT to fall back to /tmp/ inside container
# (no volume mount). Set it to a directory path to mount it as the ROMs volume.
#GV_LIBRARY_ROOT=
GV_POSTGRES_DB=games_vault
GV_POSTGRES_USER=games_vault
GV_APP_PORT=8080
GV_BASE_PATH=
GV_NOSEBLEED_BINARY_PATH=/opt/nosebleed/nosebleed
GV_NOSEBLEED_BASE_LISTEN_PORT=8100
GV_NOSEBLEED_MAX_SESSIONS=4
GV_NOSEBLEED_MAX_PLAYERS=4
GV_NOSEBLEED_SEAT_TTL_MINUTES=30
GV_NOSEBLEED_REQUIRE_AUTH=true
GV_NOSEBLEED_COPY_CONTENT_TO_SESSION=true
GV_NOSEBLEED_PUBLIC_SCHEME=http
GV_LIBRETRO_DB_URL=https://github.com/libretro/libretro-database/archive/refs/heads/master.zip
