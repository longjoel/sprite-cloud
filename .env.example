# Shared env vars for Rust binaries (gv-server and gv-worker).
# Copy this to a .env file or export in your shell before running.

# ── gv-server ──────────────────────────────────────────────────────────

# Path to the gv-worker binary.
# Resolution order: config.toml `gv_web.worker_bin` > this env var > auto-detect
# Auto-detect tries: .target/release/gv-worker → ./target/debug/gv-worker
GV_WORKER_BIN=

# Hostname used in the worker connect URL sent to the browser.
# Default: auto-detected LAN IP (falls back to localhost).
GV_WORKER_HOST=

# HTTP request timeout for gv-web API calls in seconds (default: 30).
GV_WEB_TIMEOUT_SECS=

# ── gv-worker ──────────────────────────────────────────────────────────

# STUN/TURN server for WebRTC NAT traversal.
# Format: "stun:host:port" or "turn:host:port?transport=tcp"
# Default: stun:stun.l.google.com:19302
STUN_SERVER=

# VP8 encoder target bitrate in kbps (default: 500).
TARGET_BITRATE_KBPS=

# ── gv-worker CORS ────────────────────────────────────────────────────

# Comma-separated list of allowed origins for CORS.
# Set this in production to your gv-web URL (e.g. "https://games.example.com").
# In dev (not set), allows localhost:3001 + auto-detected LAN IP:3001.
ALLOWED_ORIGIN=

# ── gv-web auth ───────────────────────────────────────────────────────

# GitHub OAuth (required — no defaults, sign-in won't work without these)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# LAN-only credentials (optional — enables a side door for trusted networks)
# When set, anyone on a LAN IP (192.168.*, 10.*, 172.16-31.*, 127.*) can
# sign in with these credentials without going through GitHub OAuth.
# The user gets a synthetic account with id=lan-user — no DB row needed.
# Leave empty to disable LAN auth entirely.
# LAN_USER=
# LAN_PASS=
