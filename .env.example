# Games Vault — Environment Variables
# Copy to .env / gv-web/.env.local as needed. Leave secrets empty until you set them.

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║ gv-web gateway                                                              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# NextAuth/Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public gateway origin, for example: https://games.example.com
AUTH_URL=
NEXTAUTH_URL=

# PostgreSQL connection string for gv-web.
DATABASE_URL=postgresql://localhost:5432/games_vault

# Production container option: apply the current Drizzle schema on startup.
# Use explicit migrations instead if you prefer stricter release control.
GV_WEB_SCHEMA_PUSH_ON_START=0

# Optional: skip first-run setup-code generation.
GV_WEB_SKIP_SETUP_INIT=0

# Legacy bootstrap only: if the users table is empty, gv-web can seed one
# initial user from these vars. Public installs should normally use /setup.
LAN_USER=
LAN_PASS=
LAN_PASS_HASH=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║ gv-server host runtime                                                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# HTTP request timeout for gv-web API calls in seconds.
GV_WEB_TIMEOUT_SECS=30

# Comma-separated ROM roots scanned by gv-server.
GV_ROM_ROOTS=

# Directory where downloaded libretro cores are cached.
GV_CORES_DIR=

# Source URL for automatic libretro core downloads.
# Default: https://buildbot.libretro.com/nightly/linux/x86_64/latest
GV_BUILDBOT_URL=

# Hostname/IP advertised in player URLs for the local gv-server player endpoint.
# Default: auto-detected LAN IP, falling back to localhost.
GV_WORKER_HOST=
GV_WORKER_PORT=8787
GV_PLAYER_BIND=0.0.0.0:8787

# Save/state/system directories.
GV_SAVE_DIR=
GV_SYSTEM_DIR=

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║ ICE / WebRTC                                                                ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Comma-separated STUN server URLs. Empty means Google STUN fallback.
GV_ICE_STUN_URLS=

# Comma-separated TURN server URLs. Recommended for players outside LAN.
GV_ICE_TURN_URLS=
GV_ICE_TURN_USERNAME=
GV_ICE_TURN_CREDENTIAL=

# ICE transport policy: all | relay
GV_ICE_TRANSPORT_POLICY=all

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║ Core overrides                                                              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Override default libretro core per platform with:
# GV_CORE_OVERRIDE_<platform>=core_filename.so
# Spaces/hyphens become underscores.
# Example:
# GV_CORE_OVERRIDE_PlayStation=swanstation_libretro.so

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║ GStreamer video/audio tuning                                                ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

GV_GST_VIDEO_CPU_USED=4
GV_GST_VIDEO_THREADS=4
GV_GST_VIDEO_BITRATE_KBPS=2000
GV_GST_VIDEO_DEADLINE=1
GV_GST_VIDEO_SCALE_HEIGHT=0
GV_GST_VIDEO_MAX_SCALE=4
GV_GST_VIDEO_KEYFRAME_MAX_DIST=150
GV_GST_AUDIO_BITRATE=64000

# DataChannel auth timeout in seconds.
DC_AUTH_TIMEOUT_SECS=5
