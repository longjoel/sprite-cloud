# PostgreSQL
POSTGRES_PASSWORD=change-me

# Nosebleed streaming
GV_NOSEBLEED_PUBLIC_SCHEME=http
GV_NOSEBLEED_PUBLIC_HOST=127.0.0.1
GV_NOSEBLEED_REQUIRE_AUTH=true

# TURN server (optional — leave empty to use direct STUN-only connections)
GV_NOSEBLEED_TURN_SECRET=

# Library root (path to your ROM files on the host)
GV_LIBRARY_ROOT=/srv/storage/games
