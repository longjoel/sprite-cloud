<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.spritecloud.SpriteCloud</id>
  <name>Sprite Cloud</name>
  <summary>Stream your retro game library to any device</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-or-later</project_license>
  <description>
    <p>
      Sprite Cloud is a retro game streaming client that connects to a server
      hosting your game library and lets you play on any device.
    </p>
    <p>
      Features include a fullscreen XMB-style interface for couch navigation,
      native gamepad support via gilrs, touch controls for mobile devices,
      and real-time video streaming with low latency.
    </p>
    <p>
      Just point the client at your Sprite Cloud server, browse your library
      with a controller or touch, and start playing instantly — no local
      emulator setup required.
    </p>
  </description>
  <categories>
    <category>Game</category>
    <category>Emulator</category>
  </categories>
