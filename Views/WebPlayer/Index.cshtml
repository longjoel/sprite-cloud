@model games_vault.Models.ViewModels.WebPlayerPageViewModel

@{
    Layout = null;
    var basePath = Model.BasePath.TrimEnd('/');
    var core = Model.Core ?? "";
    var romUrl = Model.RomUrl ?? "";
    var romName = Model.RomName ?? "";
    var gameId = Model.GameId?.ToString() ?? "";
    var savesList = Model.SavesListUrl ?? "";
    var savesPut = Model.SavesPutUrl ?? "";
    var csrfUrl = Model.CsrfTokenUrl ?? "";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Play</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <base href="@basePath/" />

    <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.0.0-alpha.3/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.6.0/css/font-awesome.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/mdbootstrap/4.1.1/css/mdb.min.css">
    <link rel="stylesheet" type="text/css" href="@basePath/libretro.css">
    <link rel="shortcut icon" href="@basePath/media/retroarch.ico" />

    <script>
        // Set the selected core before libretro.js runs (it reads localStorage during init).
        (function () {
            var core = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(core));
            if (core) {
                try { localStorage.setItem("core", core); } catch { }
            }
        })();
    </script>
</head>
<body>
    <!-- Copied/kept compatible with the upstream RetroArch web player HTML -->
    <nav class="navbar navbar-dark bg-primary">
        <div class="container">
            <div class="navbar-toggleable-xs">
                <ul class="nav navbar-nav">
                    <div class="dropdown">
                        <li class="nav-item dropdown">
                            <button class="btn btn-primary dropdown-toggle" type="button" id="dropdownMenu1" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">Core Selection</button>
                            <div class="dropdown-menu dropdown-primary" aria-labelledby="dropdownMenu1" data-dropdown-in="fadeIn" data-dropdown-out="fadeOut" id="core-selector"></div>
                            <button class="btn btn-primary disabled" id="btnRun" disabled>
                                <span class="fa fa-spinner fa-spin" id="icnRun"></span> Run
                            </button>
                            <button class="btn btn-primary disabled" id="btnAdd" disabled>
                                <span class="fa fa-plus" id="icnAdd"></span> Add Content
                            </button>
                            <input style="display: none" type="file" id="btnRom" name="upload" multiple />
                            <button class="btn btn-primary tooltip-enable" id="btnClean" title="Cleanup storage">
                                <span class="fa fa-trash-o" id="icnClean"></span> <span class="sr-only">Cleanup</span>
                            </button>
                            <button class="btn btn-primary disabled tooltip-enable" id="btnMenu" title="Menu toggle" disabled>
                                <span class="fa fa-bars" id="icnMenu"></span> <span class="sr-only">Menu</span>
                            </button>
                            <button class="btn btn-primary disabled tooltip-enable" id="btnFullscreen" title="Fullscreen" disabled>
                                <span class="fa fa-desktop" id="icnFullscreen"></span> <span class="sr-only">Fullscreen</span>
                            </button>
                        </li>
                    </div>
                </ul>
                <div class="toggleMenu">
                    <button class="btn btn-primary" id="btnHideMenu" title="Toggle Menu">
                        <span class="fa fa-chevron-up" id="icnHideMenu"></span> <span class="sr-only">Hide Top Navigation</span>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <div class="bg-inverse webplayer-container">
        <div class="webplayer_border text-xs-center" id="canvas_div">
            <div class="showMenu">
                <button type="button" class="btn btn-link">
                    <span class="fa fa-chevron-down" id="icnShowMenu"></span> <span class="sr-only">Show Top Navigation</span>
                </button>
            </div>
            <canvas class="webplayer" id="canvas" style="display: none"></canvas>
            <img class="webplayer-preview img-fluid" src="@basePath/media/canvas.png" width="960" height="720" alt="RetroArch Logo">
        </div>
    </div>

    <script crossorigin="anonymous" src="//code.jquery.com/jquery-3.1.0.min.js"></script>
    @* rawgit is dead and CORS-blocked when loaded with crossorigin; omit hotkeys *@
    <script crossorigin="anonymous" src="//cdnjs.cloudflare.com/ajax/libs/tether/1.3.4/js/tether.min.js"></script>
    <script crossorigin="anonymous" src="//cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.0.0-alpha.3/js/bootstrap.min.js"></script>

    <script src="@basePath/browserfs.min.js"></script>
    <script src="@basePath/core_list.js"></script>
    <script src="@basePath/libretro.js"></script>

    <script>
        (function () {
            var cfg = {
                core: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(core)),
                romUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(romUrl)),
                romName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(romName)),
                gameId: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(gameId)),
                savesList: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(savesList)),
                savesPut: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(savesPut)),
                csrfUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(csrfUrl))
            };

            function sleep(ms) { return new Promise(function (r) { setTimeout(r, ms); }); }

            function contentPath(name) {
                return "/home/web_user/retroarch/userdata/content/" + name;
            }

            async function fetchArrayBuffer(url) {
                var res = await fetch(url, { cache: "no-store", credentials: "same-origin" });
                if (!res.ok) throw new Error("Fetch failed: " + res.status);
                return await res.arrayBuffer();
            }

            async function autoLoadRom() {
                if (!cfg.romUrl) return;
                if (!cfg.romName) cfg.romName = "content.rom";
                // If the name comes from inside a zip it may be "outer.zip:inner.rom" — take the inner.
                if (cfg.romName.indexOf(":") >= 0) cfg.romName = cfg.romName.split(":").pop();
                // Avoid characters that are problematic in emscripten FS paths.
                cfg.romName = String(cfg.romName).replace(/[\\\\/]/g, "_").replace(/[:]/g, "_");
                if (!cfg.romName) cfg.romName = "content.rom";

                var bytes = await fetchArrayBuffer(cfg.romUrl);
                window.uploadData(bytes, cfg.romName);

                // Launch directly into content (avoid relaunch(), which can effectively start twice).
                if (window.Module) {
                    var cfgPath = "/home/web_user/retroarch/userdata/retroarch.cfg";

                    if (cfg.gameId) {
                        var perGameRoot = "/home/web_user/retroarch/userdata/games-vault/" + String(cfg.gameId);
                        try {
                            var parts = perGameRoot.split("/").filter(Boolean);
                            var cur = "";
                            for (var i = 0; i < parts.length; i++) {
                                cur += "/" + parts[i];
                                try { window.Module.FS.mkdir(cur); } catch { }
                            }
                            try { window.Module.FS.mkdir(perGameRoot + "/saves"); } catch { }
                            try { window.Module.FS.mkdir(perGameRoot + "/states"); } catch { }
                            try { window.Module.FS.mkdir(perGameRoot + "/system"); } catch { }
                            try { window.Module.FS.mkdir(perGameRoot + "/config"); } catch { }

                            var baseCfg = "";
                            try {
                                baseCfg = window.Module.FS.readFile("/home/web_user/retroarch/userdata/retroarch.cfg", { encoding: "utf8" });
                            } catch { baseCfg = ""; }

                            var overrides =
                                "\n# games-vault per-game overrides\n" +
                                "savefile_directory = \"" + perGameRoot + "/saves\"\n" +
                                "savestate_directory = \"" + perGameRoot + "/states\"\n" +
                                "system_directory = \"" + perGameRoot + "/system\"\n" +
                                "rgui_config_directory = \"" + perGameRoot + "/config\"\n";

                            cfgPath = perGameRoot + "/retroarch.cfg";
                            window.Module.FS.writeFile(cfgPath, baseCfg + overrides, { encoding: "utf8" });
                        } catch (e) {
                            console.warn("games-vault: failed to write per-game config", e);
                            cfgPath = "/home/web_user/retroarch/userdata/retroarch.cfg";
                        }
                    }

                    window.Module.arguments = ["-v", contentPath(cfg.romName), "-c", cfgPath];
                }

                if (typeof window.startRetroArch === "function" && !window.retroArchRunning) {
                    window.startRetroArch();
                }
            }

            var started = false;

            function startOnce() {
                if (started) return;
                started = true;
                if (window.__gamesVaultWebPlayerStarted) return;
                window.__gamesVaultWebPlayerStarted = true;

                (async function () {
                    // preLoadingComplete happens after filesystem setup; uploadData is safe then.
                    if (!window.Module || !window.Module.FS || typeof window.uploadData !== "function") {
                        return;
                    }
                    try {
                        await autoLoadRom();
                    } catch (e) {
                        console.error("games-vault: auto-load failed", e);
                    }
                })();
            }

            // Hook preLoadingComplete so we run after the upstream init enables the runtime/filesystem.
            var originalPreLoadingComplete = window.preLoadingComplete;
            window.preLoadingComplete = function () {
                try { if (typeof originalPreLoadingComplete === "function") originalPreLoadingComplete(); } catch { }
                startOnce();
            };
        })();
    </script>
</body>
</html>
