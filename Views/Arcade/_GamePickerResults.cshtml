@model games_vault.Models.ViewModels.ArcadeGamePickerViewModel
@{
    var q = Model.Query.Q;
    var system = Model.Query.System;
    var players = Model.Query.Players;
    var sort = Model.Query.Sort;
    var page = Model.Page;
    var pageSize = Model.PageSize;
}

<div class="arcade-game-picker-results" data-arcade-game-picker-results>
    @if (Model.Games.Count == 0)
    {
        <div class="alert alert-secondary mb-0">
            @if (Model.Query.HasActiveFilters)
            {
                <div class="fw-semibold mb-1">No playable games match those filters.</div>
                <div>Try a different search, system, or player count.</div>
            }
            else
            {
                <div class="fw-semibold mb-1">No playable games found.</div>
                <div>Add stored or linked ROM files before creating arcade cabinets.</div>
            }
        </div>
    }
    else
    {
        <div class="list-group arcade-game-picker-list">
            @foreach (var game in Model.Games)
            {
                <button type="button"
                        class="list-group-item list-group-item-action arcade-game-picker-item"
                        data-arcade-game-id="@game.Id"
                        data-arcade-game-name="@game.Name"
                        data-arcade-game-system="@game.SystemName"
                        data-arcade-game-meta="@game.SystemName · @(game.NumberOfPlayers is null ? "players unknown" : $"{game.NumberOfPlayers} player{(game.NumberOfPlayers == 1 ? "" : "s")}") · @game.FileCount file@(game.FileCount == 1 ? "" : "s")">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold text-break">@game.Name</div>
                            <div class="small text-muted">@game.SystemName · @(game.NumberOfPlayers is null ? "players unknown" : $"{game.NumberOfPlayers} player{(game.NumberOfPlayers == 1 ? "" : "s")}") · @game.FileCount file@(game.FileCount == 1 ? "" : "s")</div>
                        </div>
                        <div class="d-flex gap-1 flex-wrap justify-content-end">
                            @if (game.AlreadyCabinetCount > 0)
                            {
                                <span class="badge text-bg-info">@game.AlreadyCabinetCount cabinet@(game.AlreadyCabinetCount == 1 ? "" : "s")</span>
                            }
                            <span class="badge text-bg-light">Pick</span>
                        </div>
                    </div>
                </button>
            }
        </div>
    }

    @if (Model.PageCount > 1)
    {
        <nav class="mt-3" aria-label="Arcade game picker pages">
            <ul class="pagination pagination-sm mb-0 flex-wrap">
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link arcade-game-picker-page"
                       asp-action="GamePicker"
                       asp-route-q="@q"
                       asp-route-system="@system"
                       asp-route-players="@players"
                       asp-route-sort="@sort"
                       asp-route-page="@(page - 1)"
                       asp-route-pageSize="@pageSize">Previous</a>
                </li>
                @for (var i = Math.Max(1, page - 2); i <= Math.Min(Model.PageCount, page + 2); i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link arcade-game-picker-page"
                           asp-action="GamePicker"
                           asp-route-q="@q"
                           asp-route-system="@system"
                           asp-route-players="@players"
                           asp-route-sort="@sort"
                           asp-route-page="@i"
                           asp-route-pageSize="@pageSize">@i</a>
                    </li>
                }
                <li class="page-item @(page >= Model.PageCount ? "disabled" : "")">
                    <a class="page-link arcade-game-picker-page"
                       asp-action="GamePicker"
                       asp-route-q="@q"
                       asp-route-system="@system"
                       asp-route-players="@players"
                       asp-route-sort="@sort"
                       asp-route-page="@(page + 1)"
                       asp-route-pageSize="@pageSize">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>
