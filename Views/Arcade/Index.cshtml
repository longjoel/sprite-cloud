@model games_vault.Models.ViewModels.ArcadeIndexViewModel
@{
    ViewData["Title"] = "Arcade";
}

<div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
    <div>
        <div class="text-uppercase text-muted small fw-semibold mb-2">Arcade experiment</div>
        <h1 class="display-6 mb-1">@(Model.Arcade?.Name ?? "Arcade")</h1>
        <p class="text-muted mb-2">Free-play cabinets that keep running even when empty.</p>
        @if (Model.Arcade is not null)
        {
            <div class="d-flex flex-wrap gap-2 small text-muted">
                <span class="games-meta-chip">@Model.CabinetCount cabinet@(Model.CabinetCount == 1 ? "" : "s")</span>
                <span class="games-meta-chip">@Model.RunningCabinetCount running</span>
                <span class="games-meta-chip">@Model.SystemCount system@(Model.SystemCount == 1 ? "" : "s")</span>
            </div>
        }
    </div>
    @if (Model.CanManage)
    {
        <div class="d-flex gap-2 flex-wrap">
            @if (Model.Arcade is null)
            {
                <form asp-action="CreateDefault" method="post" asp-antiforgery="true">
                    <button type="submit" class="btn btn-primary">Create free-play arcade</button>
                </form>
            }
        </div>
    }
</div>

@if (!Model.NosebleedEnabled)
{
    <div class="alert alert-warning">Nosebleed server-side playback is disabled, so arcade cabinets cannot boot yet.</div>
}

@if (Model.Arcade is null)
{
    <div class="alert alert-secondary">No arcade yet. Create one to add cabinets.</div>
}
else
{
    @if (Model.CanManage)
    {
        <div class="card mb-4 arcade-add-cabinet-card">
            <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-3">
                <div>
                    <div class="card-title fw-semibold mb-1">Add a free-play cabinet</div>
                    <div class="text-muted">Pick a ROM from your library to pin as a cabinet.</div>
                </div>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#arcade-game-picker-modal">
                    Choose game
                </button>
            </div>
        </div>
    }

    @if (Model.Cabinets.Count == 0)
    {
        <div class="alert alert-secondary">No cabinets yet. Add a game above to boot one.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var cabinet in Model.Cabinets)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="card h-100 shadow-sm @(cabinet.IsRunning ? "border-success" : "")"
                         @if (cabinet.IsRunning)
                         {
                             @:data-nosebleed-preview-card
                             @:data-preview-url="@Url.Action("NosebleedPreviewVideo", "Home", new { sessionId = cabinet.RuntimeSessionId })"
                         }>
                        <div class="ratio ratio-16x9 bg-dark rounded-top overflow-hidden d-flex align-items-center justify-content-center">
                            @if (cabinet.IsRunning)
                            {
                                <canvas data-nosebleed-preview-canvas class="w-100 h-100" style="image-rendering: pixelated;"></canvas>
                            }
                            else
                            {
                                <div class="text-light small">Waiting for cabinet runtime…</div>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <h2 class="h5 mb-1">@cabinet.DisplayName</h2>
                                    <div class="text-muted small">@cabinet.GameName</div>
                                </div>
                                <span class="badge @(cabinet.IsRunning ? "text-bg-success" : cabinet.IsEnabled ? "text-bg-warning" : "text-bg-secondary")">
                                    @(cabinet.IsRunning ? "Running" : cabinet.IsEnabled ? "Booting" : "Stopped")
                                </span>
                            </div>
                            <dl class="row small mt-3 mb-2">
                                <dt class="col-5">Mode</dt>
                                <dd class="col-7">@cabinet.CreditMode</dd>
                                <dt class="col-5">System</dt>
                                <dd class="col-7">@cabinet.SystemName</dd>
                                <dt class="col-5">Runtime</dt>
                                <dd class="col-7">@(cabinet.Session is null ? "—" : FormatDuration(cabinet.Session.Runtime))</dd>
                            </dl>
                            @if (!string.IsNullOrWhiteSpace(cabinet.LastError))
                            {
                                <div class="alert alert-warning small py-2">@cabinet.LastError</div>
                            }
                            <div class="d-flex gap-2 flex-wrap mt-auto">
                                @if (cabinet.IsRunning && !string.IsNullOrWhiteSpace(cabinet.RuntimeSessionId))
                                {
                                    <a class="btn btn-sm btn-primary" href="@Url.RouteUrl("ArcadeSession", new { sessionId = cabinet.RuntimeSessionId })">@(Model.CanPlay ? "Join" : "Watch")</a>
                                }
                                else
                                {
                                    <a class="btn btn-sm btn-primary" asp-action="Join" asp-route-id="@cabinet.Id">@(Model.CanPlay ? "Join" : "Watch")</a>
                                }
                                @if (Model.CanManage)
                                {
                                    <form asp-action="StartCabinet" method="post" asp-antiforgery="true">
                                        <input type="hidden" name="id" value="@cabinet.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Start</button>
                                    </form>
                                    <form asp-action="RestartCabinet" method="post" asp-antiforgery="true">
                                        <input type="hidden" name="id" value="@cabinet.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">Restart</button>
                                    </form>
                                    <form asp-action="StopCabinet" method="post" asp-antiforgery="true">
                                        <input type="hidden" name="id" value="@cabinet.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Stop</button>
                                    </form>
                                    <form asp-action="RemoveCabinet" method="post" asp-antiforgery="true">
                                        <input type="hidden" name="id" value="@cabinet.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@if (Model.CanManage && Model.Arcade is not null)
{
    <div class="modal fade" id="arcade-game-picker-modal" tabindex="-1" aria-labelledby="arcade-game-picker-title" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h2 class="modal-title h5" id="arcade-game-picker-title">Choose a game for the arcade</h2>
                        <div class="text-muted small">Search the full playable library instead of scrolling a giant dropdown.</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-lg-8">
                            <form id="arcade-game-picker-filters" class="row g-2 align-items-end" data-arcade-game-picker-filters>
                                <div class="col-12 col-md-5">
                                    <label class="form-label" for="arcade-game-picker-search">Search library</label>
                                    <input class="form-control" id="arcade-game-picker-search" name="q" value="@Model.GamePicker.Query.Q" placeholder="Search games, systems, files, CRC…" autocomplete="off" />
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="form-label" for="arcade-game-picker-system">System</label>
                                    <select class="form-select" id="arcade-game-picker-system" name="system">
                                        <option value="">All systems</option>
                                        @foreach (var option in Model.GamePicker.SystemOptions)
                                        {
                                            <option value="@option.Name" selected="@(string.Equals(option.Name, Model.GamePicker.Query.System, StringComparison.OrdinalIgnoreCase))">@option.Name (@option.Count)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6 col-md-2">
                                    <label class="form-label" for="arcade-game-picker-players">Players</label>
                                    <select class="form-select" id="arcade-game-picker-players" name="players">
                                        <option value="">Any</option>
                                        @foreach (var option in Model.GamePicker.PlayerOptions)
                                        {
                                            <option value="@option.Players" selected="@(Model.GamePicker.Query.Players == option.Players)">@option.Players (@option.Count)</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12 col-md-2">
                                    <label class="form-label" for="arcade-game-picker-sort">Sort</label>
                                    <select class="form-select" id="arcade-game-picker-sort" name="sort">
                                        <option value="AlphabeticalAsc" selected="@(Model.GamePicker.Query.Sort == games_vault.Models.ViewModels.ArcadeGamePickerSort.AlphabeticalAsc)">A-Z</option>
                                        <option value="RecentlyAdded" selected="@(Model.GamePicker.Query.Sort == games_vault.Models.ViewModels.ArcadeGamePickerSort.RecentlyAdded)">Newest</option>
                                        <option value="System" selected="@(Model.GamePicker.Query.Sort == games_vault.Models.ViewModels.ArcadeGamePickerSort.System)">System</option>
                                        <option value="NumberOfPlayers" selected="@(Model.GamePicker.Query.Sort == games_vault.Models.ViewModels.ArcadeGamePickerSort.NumberOfPlayers)">Players</option>
                                    </select>
                                </div>
                                <input type="hidden" name="page" value="@Model.GamePicker.Page" data-arcade-game-picker-page />
                                <input type="hidden" name="pageSize" value="@Model.GamePicker.PageSize" />
                            </form>

                            <div class="mt-3" id="arcade-game-picker-results" data-arcade-game-picker-results-url="@Url.Action("GamePicker", "Arcade")">
                                <partial name="_GamePickerResults" model="Model.GamePicker" />
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <form asp-action="AddCabinet" method="post" asp-antiforgery="true" class="card h-100 arcade-selected-game-card">
                                <div class="card-body d-flex flex-column gap-3">
                                    <div>
                                        <div class="text-uppercase text-muted small fw-semibold mb-2">Selected cabinet game</div>
                                        <div class="h5 mb-1" data-arcade-selected-game-name>No game selected</div>
                                        <div class="small text-muted" data-arcade-selected-game-meta>Pick a result to enable cabinet creation.</div>
                                    </div>
                                    <input type="hidden" id="arcade-selected-game-id" name="gameId" data-arcade-selected-game-id />
                                    <div>
                                        <label class="form-label" for="arcade-cabinet-display-name">Cabinet label</label>
                                        <input class="form-control" id="arcade-cabinet-display-name" name="displayName" data-arcade-cabinet-display-name placeholder="Defaults to game name" />
                                    </div>
                                    <button type="submit" class="btn btn-primary mt-auto" data-arcade-add-cabinet-submit disabled>Add cabinet</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@functions {
    static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalHours >= 1) return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        if (duration.TotalMinutes >= 1) return $"{duration.Minutes}m {duration.Seconds}s";
        return $"{Math.Max(0, duration.Seconds)}s";
    }
}

@section Scripts {
    <script src="~/js/nosebleed-player/preview.js" asp-append-version="true"></script>
    <script src="~/js/arcade-game-picker.js" asp-append-version="true"></script>
}
