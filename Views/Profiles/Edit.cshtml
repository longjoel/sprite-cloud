@model games_vault.Models.ViewModels.ProfileSettingsViewModel
@{
    ViewData["Title"] = "Edit Profile";
    var avatarOptions = new[] { "🎮", "🕹️", "👾", "🎯", "🎲", "🎪", "🚀", "⭐", "🦊", "🐉", "🦅", "👑", "⚡", "🔥", "💎", "🎨" };
}

<h1>Edit profile</h1>
<p class="text-muted">Update your display name, avatar, color, and bio.</p>

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<form method="post" class="card" autocomplete="off">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label" asp-for="DisplayName"></label>
            <input class="form-control" asp-for="DisplayName" name="displayName" maxlength="80" required />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Color"></label>
            <input class="form-control form-control-color" asp-for="Color" name="color" type="color" value="#0d6efd" />
        </div>
        <div class="mb-3">
            <label class="form-label">Avatar</label>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var emoji in avatarOptions)
                {
                    var isSelected = string.Equals(Model.AvatarKey, emoji, StringComparison.Ordinal);
                    <label class="avatar-option" style="cursor:pointer;padding:0.5rem;border:2px solid @(isSelected ? "var(--bs-primary)" : "transparent");border-radius:0.5rem;font-size:1.5rem;">
                        <input type="radio" name="avatarKey" value="@emoji" style="display:none" @(isSelected ? "checked" : "")
                               onchange="this.parentElement.style.borderColor=this.checked?'var(--bs-primary)':'transparent'" />
                        <span>@emoji</span>
                    </label>
                }
            </div>
            <div class="form-text">Pick an icon for your profile.</div>
            <input type="hidden" name="avatarKey" id="avatarKeyHidden" value="@Model.AvatarKey" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Bio">Bio</label>
            <textarea class="form-control" asp-for="Bio" name="bio" maxlength="500" rows="3" placeholder="A short bio or status line…">@Model.Bio</textarea>
        </div>
        <button type="submit" class="btn btn-primary">Save changes</button>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('.avatar-option input').forEach(function(radio) {
            radio.addEventListener('change', function() {
                document.querySelectorAll('.avatar-option').forEach(function(opt) {
                    opt.style.borderColor = 'transparent';
                });
                if (this.checked) {
                    this.parentElement.style.borderColor = 'var(--bs-primary)';
                    document.getElementById('avatarKeyHidden').value = this.value;
                }
            });
        });
    </script>
}
