@model games_vault.Models.ViewModels.ProfileDetailsViewModel
@{
    ViewData["Title"] = Model.DisplayName;
}

<div class="d-flex align-items-center gap-3 mb-4">
    @if (!string.IsNullOrWhiteSpace(Model.AvatarKey))
    {
        <span class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width:3rem;height:3rem;background:@Model.Color;font-size:1.5rem;">@Model.AvatarKey</span>
    }
    else
    {
        <span class="rounded-circle d-inline-block" style="width:3rem;height:3rem;background:@Model.Color"></span>
    }
    <div>
        <h1 class="mb-0">@Model.DisplayName</h1>
        <div class="text-muted">@(Model.IsCurrent ? "Current player profile" : "Player profile")</div>
        <div class="small text-muted">Username: <code>@("@")@(Model.Username ?? "not set")</code></div>
        @if (!string.IsNullOrWhiteSpace(Model.Bio))
        {
            <div class="small text-light-emphasis mt-1">@Model.Bio</div>
        }
    </div>
    @if (Model.IsCurrent)
    {
        <div class="ms-auto">
            <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@Model.Id">Edit profile</a>
        </div>
    }
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted small">Play time</div><div class="h4">@Model.TotalPlayTime.TotalHours.ToString("0.0") h</div></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted small">Sessions</div><div class="h4">@Model.SessionCount</div></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted small">Last played</div><div class="h4">@(Model.LastPlayedGame ?? "—")</div></div></div></div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        @if (Model.IsCurrent)
        {
            <div class="card mb-4" id="change-password">
                <div class="card-body">
                    <h2 class="h5">Change password</h2>
                    <p class="text-muted small">Use a password with at least 8 characters for this player profile.</p>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <form method="post" asp-action="ChangePassword" autocomplete="off">
                        @Html.AntiForgeryToken()
                        <input asp-for="ChangePassword.ProfileId" type="hidden" />
                        <div class="mb-3">
                            <label class="form-label" asp-for="ChangePassword.CurrentPassword">Current password</label>
                            <input class="form-control" asp-for="ChangePassword.CurrentPassword" type="password" />
                            <span class="text-danger" asp-validation-for="ChangePassword.CurrentPassword"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="ChangePassword.NewPassword">New password</label>
                            <input class="form-control" asp-for="ChangePassword.NewPassword" type="password" minlength="8" />
                            <span class="text-danger" asp-validation-for="ChangePassword.NewPassword"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="ChangePassword.ConfirmNewPassword">Confirm new password</label>
                            <input class="form-control" asp-for="ChangePassword.ConfirmNewPassword" type="password" minlength="8" />
                            <span class="text-danger" asp-validation-for="ChangePassword.ConfirmNewPassword"></span>
                        </div>
                        <button type="submit" class="btn btn-primary">Update password</button>
                    </form>
                </div>
            </div>
        }

        <h2 class="h4">Top games</h2>
        @if (Model.TopGames.Count == 0)
        {
            <p class="text-muted">No games played yet.</p>
        }
        else
        {
            <div class="list-group">
                @foreach (var game in Model.TopGames)
                {
                    <a class="list-group-item list-group-item-action" asp-controller="Games" asp-action="Details" asp-route-id="@game.GameId">
                        <div class="fw-semibold">@game.GameName</div>
                        <div class="small text-muted">@game.TotalPlayTime.TotalHours.ToString("0.0") h · @game.SessionCount sessions</div>
                    </a>
                }
            </div>
        }

        <div class="card mt-4">
            <div class="card-body">
                <h2 class="h5">Profile saves</h2>
                <p class="text-muted mb-0">Coming next: save files and save states scoped to this profile.</p>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <h2 class="h4">Recent sessions</h2>
        @if (Model.RecentSessions.Count == 0)
        {
            <p class="text-muted">No sessions yet.</p>
        }
        else
        {
            <div class="list-group">
                @foreach (var session in Model.RecentSessions)
                {
                    <a class="list-group-item list-group-item-action" asp-controller="Games" asp-action="Details" asp-route-id="@session.GameId">
                        <div class="d-flex justify-content-between gap-3">
                            <div>
                                <div class="fw-semibold">@session.GameName</div>
                                <div class="small text-muted">@session.Mode · @session.StartedUtc.ToLocalTime().ToString("g")</div>
                            </div>
                            <div class="text-end small">@session.Duration.TotalMinutes.ToString("0") min</div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
