@model games_vault.Models.ViewModels.ProfilesIndexViewModel
@{
    ViewData["Title"] = "Profiles";
    var canManageLibrary = ViewData["CanManageLibrary"] as bool? == true;
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="mb-1">Who's playing?</h1>
        <p class="text-muted mb-0">Viewer mode can watch active games. Sign in with a profile PIN to play and track stats.</p>
    </div>
    <div class="d-flex gap-2">
        @if (canManageLibrary)
        {
            <a class="btn btn-outline-primary" asp-action="Invites">Invite links</a>
        }
        <a class="btn btn-primary" asp-action="Create">Create profile</a>
    </div>
</div>

@if (TempData["Error"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

@if (Model.Profiles.Count == 0)
{
    <div class="text-center py-5 border rounded bg-light">
        <h2 class="h4">No profiles yet</h2>
        <p class="text-muted">Ask an admin for an invite link to create the first player profile.</p>
        <a class="btn btn-primary" asp-action="Create">Create profile</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var profile in Model.Profiles)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 @(profile.IsCurrent ? "border-primary shadow-sm" : "")">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <span class="rounded-circle d-inline-block" style="width:2.5rem;height:2.5rem;background:@profile.Color"></span>
                            <div>
                                <h2 class="h5 mb-0">@profile.DisplayName</h2>
                                @if (profile.IsCurrent)
                                {
                                    <span class="badge text-bg-primary">Current</span>
                                }
                                @if (profile.IsAdmin)
                                {
                                    <span class="badge text-bg-dark">Admin</span>
                                }
                            </div>
                        </div>
                        <div class="small text-muted">@profile.SessionCount sessions</div>
                        <div class="fw-semibold">@profile.TotalPlayTime.TotalHours.ToString("0.0") hours played</div>
                        @if (profile.LastPlayedUtc is not null)
                        {
                            <div class="small text-muted">Last played @profile.LastPlayedUtc.Value.ToLocalTime().ToString("g")</div>
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        <form method="post" asp-action="SignIn" class="d-flex gap-2 align-items-center flex-wrap">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="profileId" value="@profile.Id" />
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@profile.Id">Details</a>
                            @if (profile.IsCurrent)
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@profile.Id" asp-fragment="change-pin">Change PIN</a>
                            }
                            <input class="form-control form-control-sm ms-auto" type="password" inputmode="numeric" pattern="[0-9]*" maxlength="4" name="pin" placeholder="PIN" value="0000" aria-label="PIN for @profile.DisplayName" style="max-width:7rem" required />
                            <button class="btn btn-sm btn-outline-primary">Sign in</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.CurrentProfileId is not null)
{
    <form method="post" asp-action="Clear" class="mt-4">
        @Html.AntiForgeryToken()
        <button class="btn btn-outline-secondary">Return to viewer mode</button>
    </form>
}
