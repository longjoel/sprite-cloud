@model games_vault.Models.ViewModels.ProfileEditViewModel
@{
    ViewData["Title"] = "Create Profile";
}

<h1>Create player profile</h1>
<p class="text-muted">Create a Games Vault profile from an admin invite link. New profiles start with PIN <code>0000</code>.</p>

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<form method="post" class="card" autocomplete="off">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label" asp-for="DisplayName"></label>
            <input class="form-control" asp-for="DisplayName" name="displayName" maxlength="80" required />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Color"></label>
            <input class="form-control form-control-color" asp-for="Color" name="color" type="color" value="#0d6efd" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="InviteCode">Invite code</label>
            <input class="form-control" asp-for="InviteCode" name="inviteCode" maxlength="64" required />
            <div class="form-text">Use the invite link/code an admin generated. Each invite can create one profile.</div>
        </div>
        <div class="alert alert-warning small">
            Starter PIN is <strong>0000</strong>. After creating the profile, sign in and use the profile details page to change it.
        </div>
        <button type="submit" class="btn btn-primary">Create profile</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
