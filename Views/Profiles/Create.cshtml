@model games_vault.Models.ViewModels.ProfileEditViewModel
@{
    ViewData["Title"] = "Create Profile";
    var avatarOptions = new[] { "🎮", "🕹️", "👾", "🎯", "🎲", "🎪", "🚀", "⭐", "🦊", "🐉", "🦅", "👑", "⚡", "🔥", "💎", "🎨" };
    var hasProfiles = ViewData["HasProfiles"] as bool? == true;
}

<h1>Create player profile</h1>
@if (hasProfiles)
{
    <p class="text-muted">Create a profile from an invite link.</p>
}
else
{
    <p class="text-muted">Set up the first profile — this account will be the vault administrator.</p>
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<form method="post" class="card" autocomplete="off">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label" asp-for="DisplayName"></label>
            <input class="form-control" asp-for="DisplayName" name="displayName" maxlength="80" required />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Username"></label>
            <input class="form-control" asp-for="Username" name="username" maxlength="32" autocapitalize="none" spellcheck="false" required />
            <div class="form-text">Usernames are lowercase on save and can use letters, numbers, periods, underscores, and hyphens.</div>
            <span class="text-danger" asp-validation-for="Username"></span>
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Password"></label>
            <input class="form-control" asp-for="Password" name="password" type="password" minlength="8" required />
            <span class="text-danger" asp-validation-for="Password"></span>
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="ConfirmPassword"></label>
            <input class="form-control" asp-for="ConfirmPassword" name="confirmPassword" type="password" minlength="8" required />
            <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Color"></label>
            <input class="form-control form-control-color" asp-for="Color" name="color" type="color" value="#0d6efd" />
        </div>
        <div class="mb-3">
            <label class="form-label">Avatar</label>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var emoji in avatarOptions)
                {
                    <label class="avatar-option" style="cursor:pointer;padding:0.5rem;border:2px solid transparent;border-radius:0.5rem;font-size:1.5rem;transition:border-color .15s;">
                        <input type="radio" name="avatarKey" value="@emoji" style="display:none"
                               onchange="this.parentElement.style.borderColor=this.checked?'var(--bs-primary)':'transparent'" />
                        <span>@emoji</span>
                    </label>
                }
            </div>
            <div class="form-text">Pick an icon for your profile.</div>
            <input type="hidden" name="avatarKey" id="avatarKeyHidden" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Bio">Bio</label>
            <textarea class="form-control" asp-for="Bio" name="bio" maxlength="500" rows="3" placeholder="A short bio or status line…"></textarea>
            <span class="text-danger" asp-validation-for="Bio"></span>
        </div>
        @if (hasProfiles)
        {
        <div class="mb-3">
            <label class="form-label" asp-for="InviteCode">Invite code</label>
            <input class="form-control" asp-for="InviteCode" name="inviteCode" maxlength="64" required />
            <div class="form-text">Each invite can create one profile.</div>
        </div>
        }
        else
        {
        <input type="hidden" name="inviteCode" value="" />
        }
        <button type="submit" class="btn btn-primary">Create profile</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('.avatar-option input').forEach(function(radio) {
            radio.addEventListener('change', function() {
                document.querySelectorAll('.avatar-option').forEach(function(opt) {
                    opt.style.borderColor = 'transparent';
                });
                if (this.checked) {
                    this.parentElement.style.borderColor = 'var(--bs-primary)';
                    document.getElementById('avatarKeyHidden').value = this.value;
                }
            });
        });
    </script>
}
