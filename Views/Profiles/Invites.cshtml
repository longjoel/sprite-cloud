@model games_vault.Models.ViewModels.ProfileInvitesViewModel
@{
    ViewData["Title"] = "Profile Invites";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="mb-1">Profile invite links</h1>
        <p class="text-muted mb-0">Generate one-time links for creating player profiles. Each invite lets the player choose a username and password during signup.</p>
    </div>
    <form method="post" asp-action="GenerateInvite">
        @Html.AntiForgeryToken()
        <button class="btn btn-primary">Generate invite link</button>
    </form>
</div>

@if (!string.IsNullOrWhiteSpace(Model.NewInviteLink))
{
    <div class="alert alert-success">
        <div class="fw-semibold mb-1">New invite link</div>
        <input class="form-control" readonly value="@Model.NewInviteLink" onclick="this.select()" />
        <div class="small mt-1">Send this link to the player. It can be used once.</div>
    </div>
}

@if (Model.Invites.Count == 0)
{
    <div class="text-center py-5 border rounded bg-light">
        <h2 class="h4">No invite links yet</h2>
        <p class="text-muted">Generate one when someone needs a profile.</p>
    </div>
}
else
{
    <div class="list-group">
        @foreach (var invite in Model.Invites)
        {
            <div class="list-group-item">
                <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <code>@invite.Code</code>
                            @if (invite.IsUsed)
                            {
                                <span class="badge text-bg-secondary">Used</span>
                            }
                            else
                            {
                                <span class="badge text-bg-success">Unused</span>
                            }
                        </div>
                        <input class="form-control form-control-sm" readonly value="@invite.InviteLink" onclick="this.select()" />
                        <div class="small text-muted mt-2">
                            Created @invite.CreatedUtc.ToLocalTime().ToString("g")
                            @if (invite.UsedUtc is not null)
                            {
                                <span> · Used @invite.UsedUtc.Value.ToLocalTime().ToString("g")</span>
                                @if (!string.IsNullOrWhiteSpace(invite.UsedByProfileName))
                                {
                                    <span> by @invite.UsedByProfileName</span>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
