@model games_vault.Models.ViewModels.ServerGamePlayViewModel
@{
    var hideSaveStateUi = Model.IsArcadeRoom;
    var canManageBatterySaves = !hideSaveStateUi
        && Model.File is not null
        && !string.IsNullOrWhiteSpace(Model.CurrentProfileDisplayName)
        && !Model.CurrentProfileIsEphemeralGuest;
}
@if (Model.CurrentRoomId is int advancedRoomId && canManageBatterySaves)
{
    <details class="border rounded-4 p-3 bg-body-tertiary" id="playserver-advanced-card">
        <summary>Advanced</summary>
        <div class="d-grid gap-3 mt-3 mb-2">
            <div>
                <div class="fw-semibold small mb-2">Battery saves</div>
                <div class="d-grid gap-2">
                    @if (!string.IsNullOrWhiteSpace(Model.SessionId) && !Model.IsSpectator)
                    {
                        <form asp-controller="Session" asp-action="FlushServerSessionSave" method="post">
                            <input type="hidden" name="roomId" value="@advancedRoomId" />
                            <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                            <button type="submit" class="btn btn-outline-warning w-100">Flush save</button>
                        </form>
                    }
                    <a class="btn btn-outline-primary w-100" asp-controller="ProfileBatterySaves" asp-action="Upload" asp-route-gameId="@Model.Game.Id" asp-route-gameFileId="@Model.File!.Id">Upload save</a>
                    <a class="btn btn-outline-secondary w-100" asp-controller="ProfileBatterySaves" asp-action="History" asp-route-gameId="@Model.Game.Id" asp-route-gameFileId="@Model.File!.Id">Save history</a>
                    <button type="button" class="btn btn-outline-success w-100" data-bs-toggle="modal" data-bs-target="#playServerSaveHistoryModal">Manage saves</button>
                </div>
            </div>
        </div>
    </details>
}
