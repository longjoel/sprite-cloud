@model games_vault.Models.ViewModels.ServerGamePlayViewModel

<div class="border rounded-4 p-3 bg-body-tertiary mb-3" id="room-chat-panel">
    <div class="d-flex flex-wrap justify-content-end gap-2 align-items-start mb-2">
        <div class="small text-muted" id="room-chat-status">Loading chat&hellip;</div>
    </div>
    <div class="border rounded bg-body p-2 mb-2 playserver-chat-log" id="room-chat-log">
        <ul class="list-unstyled mb-0 small" id="room-chat-messages">
            <li class="text-muted">Loading messages&hellip;</li>
        </ul>
    </div>
    @if (Model.CanChat)
    {
        <form action="@Url.Action("RoomChat", "Games", new { roomId = Model.CurrentRoomId })" method="post" asp-antiforgery="true" id="room-chat-form" class="d-flex gap-2 align-items-start flex-column flex-sm-row">
            @if (!string.IsNullOrWhiteSpace(Model.ChatIdentityLabel))
            {
                <div class="small text-muted w-100">@Model.ChatIdentityLabel</div>
            }
            <input class="form-control" type="text" name="message" maxlength="280" autocomplete="off" placeholder="Say something to the room&hellip;" required />
            <button type="submit" class="btn btn-primary text-nowrap">Send</button>
        </form>
    }
</div>
