@model games_vault.Models.ViewModels.GamesBankViewModel

@{
    var q = Model.Query;
    var pageSize = Model.PageSize;
    var returnUrl = (string?)ViewData["ReturnUrl"] ?? (Context.Request.Path + Context.Request.QueryString);
    var canManageLibrary = Model.CanManageLibrary;
}

@if (Model.Games.Count == 0)
{
    <div class="alert alert-info mb-0">
        @if (Model.Browse.PlayingNow)
        {
            <div class="fw-semibold mb-1">Nothing is being played right now.</div>
            <div>Clear the filter to browse the full library.</div>
            <div class="mt-3 d-flex gap-2 flex-wrap">
                <a class="btn btn-sm btn-primary" asp-controller="Arcade" asp-action="Index">Open arcade</a>
                <a class="btn btn-sm btn-outline-secondary" asp-action="Index" asp-route-pageSize="@pageSize">Clear filters</a>
            </div>
        }
        else if (Model.Browse.HasActiveFilters)
        {
            <div class="fw-semibold mb-1">No games match the current filters.</div>
            <div>Try a different search, system, player count, or clear filters to return to the full library.</div>
            <div class="mt-3">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Index" asp-route-pageSize="@pageSize">Clear filters</a>
            </div>
        }
        else
        {
            <div class="fw-semibold mb-1">No games yet.</div>
            <div>Use the Add / import tab to upload ROMs or pull them in from your sources.</div>
        }
    </div>
}
else
{
    var sections = Model.Sections.Count == 0
        ? new[] { new games_vault.Models.ViewModels.GamesLibraryGroupSection(null, Model.Games) }
        : Model.Sections;

    @foreach (var groupSection in sections)
    {
        if (!string.IsNullOrWhiteSpace(groupSection.Label))
        {
            <div class="games-library-group-heading d-flex align-items-center gap-2 mt-4 mb-2">
                <h2 class="h5 mb-0">@groupSection.Label</h2>
                <span class="games-meta-chip">@groupSection.Games.Count game@(groupSection.Games.Count == 1 ? "" : "s")</span>
            </div>
        }

        <div class="row row-cols-1 row-cols-xl-2 g-3">
        @foreach (var game in groupSection.Games)
        {
            var systemName = game.SystemName ?? "Unknown system";
            var missingInfo = Model.MissingSystemFilesBySystem.TryGetValue(systemName, out var missing) ? missing : null;
            var hasMissingSystemFiles = missingInfo is not null && missingInfo.MissingCount > 0;
            var missingSample = hasMissingSystemFiles && missingInfo!.SampleFiles.Count > 0 ? string.Join(", ", missingInfo.SampleFiles) : "";
            var missingMore = hasMissingSystemFiles && missingInfo!.MissingCount > missingInfo.SampleFiles.Count
                ? $" (+{missingInfo.MissingCount - missingInfo.SampleFiles.Count} more)"
                : "";
            var activeRooms = Model.ActiveRoomsByGameId.TryGetValue(game.Id, out var rooms)
                ? rooms
                : Array.Empty<games_vault.Models.ViewModels.GamesLibraryActiveRoomOption>();

            var artSeed = new string((systemName ?? string.Empty)
                .Split([' ', '-', '_', '/'], StringSplitOptions.RemoveEmptyEntries)
                .Select(part => char.ToUpperInvariant(part[0]))
                .Distinct()
                .Take(3)
                .ToArray());
            if (string.IsNullOrWhiteSpace(artSeed))
            {
                artSeed = "ROM";
            }
            var previewImage = !string.IsNullOrWhiteSpace(game.ScreenshotImagePath) ? game.ScreenshotImagePath : game.CoverImagePath;

            <div class="col">
                <div class="card games-card h-100 shadow-sm game-row" data-game-id="@game.Id">
                    <!-- System banner -->
                    <div class="games-card-banner">@artSeed</div>

                    <!-- Preview area -->
                    <div class="games-card-preview">
                        @if (!string.IsNullOrWhiteSpace(previewImage))
                        {
                            <img class="games-card-preview-image" src="@previewImage" alt="" loading="lazy" />
                        }
                        <div class="games-card-preview-text">@game.Name</div>
                    </div>

                    <div class="card-body">
                        <!-- Game name + badges -->
                        <div class="games-card-name-wrap">
                            <h3 class="games-card-name" title="@game.Name">@game.Name</h3>
                            @if (Model.ActiveGameIds.Contains(game.Id))
                            {
                                <span class="badge text-bg-success games-card-badge">Playing now</span>
                            }
                            @if (hasMissingSystemFiles)
                            {
                                <span class="badge text-bg-danger games-card-badge" title="Missing system files: @missingSample@missingMore">Missing BIOS</span>
                            }
                        </div>

                        @{
                            var isGuest = ViewData["CurrentProfileId"] is not int;
                            var isPinned = !isGuest && Model.PinnedGameIds.Contains(game.Id);
                        }

                        <!-- Footer: actions (left 1/3) + rooms (right 2/3) -->
                        <div class="games-card-footer">
                            <div class="games-card-footer-actions">
                                <a class="btn btn-primary btn-sm" asp-action="PlayServer" asp-route-id="@game.Id">@(isGuest ? "Watch" : "Play")</a>
                                @if (canManageLibrary)
                                {
                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@game.Id">Edit</a>
                                }
                                @if (!isGuest)
                                {
                                    <button class="btn btn-sm btn-outline-secondary pin-toggle @(isPinned ? "active" : "")"
                                            type="button"
                                            data-game-id="@game.Id"
                                            title="@(isPinned ? "Unpin from home screen" : "Pin to home screen")">📌</button>
                                }
                            </div>
                            <div class="games-card-footer-rooms">
                                @if (activeRooms.Count > 0)
                                {
                                    @foreach (var room in activeRooms)
                                    {
                                        <a class="games-card-room-row" asp-action="PlayServer" asp-route-id="@game.Id" asp-route-code="@room.Code">
                                            <span class="games-card-room-code">@room.Code</span>
                                            <span class="games-card-room-user">@room.PlayerName</span>
                                        </a>
                                    }
                                }
                            </div>
                        </div>

                        @if (hasMissingSystemFiles && !string.IsNullOrWhiteSpace(missingSample))
                        {
                            <div class="small text-danger mt-2">Missing: @missingSample@missingMore</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
    }

    @if (Model.PageCount > 1)
    {
        var start = Math.Max(1, Model.Page - 3);
        var end = Math.Min(Model.PageCount, start + 6);
        start = Math.Max(1, end - 6);

        <nav aria-label="Games pagination" class="mt-3">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-q="@Model.Browse.Q"
                       asp-route-system="@Model.Browse.System"
                       asp-route-players="@Model.Browse.Players"
                       asp-route-playingNow="@(Model.Browse.PlayingNow ? true : (bool?)null)"
                       asp-route-sort="@Model.Browse.Sort"
                       asp-route-group="@Model.Browse.Group"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-pageSize="@pageSize">Previous</a>
                </li>

                @for (var p = start; p <= end; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-q="@Model.Browse.Q"
                           asp-route-system="@Model.Browse.System"
                           asp-route-players="@Model.Browse.Players"
                           asp-route-playingNow="@(Model.Browse.PlayingNow ? true : (bool?)null)"
                           asp-route-sort="@Model.Browse.Sort"
                           asp-route-group="@Model.Browse.Group"
                           asp-route-page="@p"
                           asp-route-pageSize="@pageSize">@p</a>
                    </li>
                }

                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-q="@Model.Browse.Q"
                       asp-route-system="@Model.Browse.System"
                       asp-route-players="@Model.Browse.Players"
                       asp-route-playingNow="@(Model.Browse.PlayingNow ? true : (bool?)null)"
                       asp-route-sort="@Model.Browse.Sort"
                       asp-route-group="@Model.Browse.Group"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-pageSize="@pageSize">Next</a>
                </li>
            </ul>
        </nav>
    }
}
