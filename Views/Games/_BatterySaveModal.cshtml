@model games_vault.Models.ViewModels.ServerGamePlayViewModel
@{
    var game = Model.Game;
    var isArcadeRoom = Model.IsArcadeRoom;
    var hideSaveStateUi = isArcadeRoom;
    var canManageBatterySaves = !hideSaveStateUi && Model.File is not null && !string.IsNullOrWhiteSpace(Model.CurrentProfileDisplayName) && !Model.CurrentProfileIsEphemeralGuest;
}

@if (canManageBatterySaves)
{
    <div class="modal fade" id="playServerSaveHistoryModal" tabindex="-1" aria-labelledby="playServerSaveHistoryModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div><h5 class="modal-title" id="playServerSaveHistoryModalLabel">Battery save management</h5><div class="text-muted small">Open the full save manager without leaving the game page.</div></div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <iframe id="playServerSaveHistoryFrame" title="Battery save management" class="border-0 w-100" style="height:78vh;" loading="lazy" referrerpolicy="same-origin" data-src="@Url.Action("History", "ProfileBatterySaves", new { gameId = game.Id, gameFileId = Model.File!.Id })"></iframe>
                </div>
                <div class="modal-footer">
                    <a class="btn btn-outline-secondary" asp-controller="ProfileBatterySaves" asp-action="History" asp-route-gameId="@game.Id" asp-route-gameFileId="@Model.File!.Id">Open full page</a>
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Done</button>
                </div>
            </div>
        </div>
    </div>
}
