@model games_vault.Models.ViewModels.ServerGamePlayViewModel
<div id="nosebleed-player-log" class="player-log-panel d-none" aria-label="Nosebleed logging overlay" role="dialog" aria-modal="false">
    <div class="player-log-header">
        <div class="player-log-title">Logging overlay</div>
        <div class="player-log-actions">
            <button id="nosebleed-player-log-clear" type="button" class="player-log-action" aria-label="Clear logging overlay">Clear</button>
        </div>
    </div>
    <div class="player-log-body">
        <ul id="nosebleed-player-log-list" class="player-log-list list-unstyled mb-0" role="log" aria-live="polite" aria-relevant="additions text"></ul>
    </div>
</div>
