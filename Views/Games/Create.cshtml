@model games_vault.Models.ViewModels.GameUploadCreateViewModel

@{
    ViewData["Title"] = "Add game";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Games</h1>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<div class="modal fade" id="addGameModal" tabindex="-1" aria-labelledby="addGameModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5 mb-0" id="addGameModalLabel">Add game</h2>
                <a class="btn-close" asp-action="Index" aria-label="Close"></a>
            </div>
            <div class="modal-body">
                <partial name="_AddGameModalBody" model="Model" />
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var modalEl = document.getElementById("addGameModal");
        if (!modalEl || !window.bootstrap || !window.bootstrap.Modal) return;
        window.bootstrap.Modal.getOrCreateInstance(modalEl).show();
    });
</script>
