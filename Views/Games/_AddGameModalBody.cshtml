@model games_vault.Models.ViewModels.GameUploadCreateViewModel

@{
    var initialTab = "upload";
    if (Model.WebScanSessionId != Guid.Empty) initialTab = "web";
    else if (Model.NetworkScanSessionId != Guid.Empty) initialTab = "share";
    else if (Model.LocalScanSessionId != Guid.Empty) initialTab = "filesystem";
}

@if (!Model.LibretroAvailable)
{
    <div class="alert alert-warning">
        <div class="fw-semibold mb-1">Libretro database not synced yet</div>
        <div class="mb-2">
            Upload matching requires libretro-database `.dat` files. Start a sync job first, then come back here.
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <form asp-controller="Games" asp-action="StartLibretroSync" method="post" class="mb-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-primary">Start libretro sync</button>
            </form>
            <a class="btn btn-sm btn-outline-secondary" asp-controller="Jobs" asp-action="Index">View jobs</a>
            @if (Model.LibretroSyncJobId is not null)
            {
                <span class="text-muted">
                    Latest sync job: #@Model.LibretroSyncJobId (@Model.LibretroSyncStatus)
                </span>
            }
        </div>
    </div>
}

<ul class="nav nav-tabs" id="addgame-tabs" role="tablist" data-initial-tab="@initialTab">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="tab-upload" data-bs-toggle="tab" data-bs-target="#pane-upload" type="button" role="tab">Upload</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-web" data-bs-toggle="tab" data-bs-target="#pane-web" type="button" role="tab">Import From Web</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-share" data-bs-toggle="tab" data-bs-target="#pane-share" type="button" role="tab">Import From Share</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-filesystem" data-bs-toggle="tab" data-bs-target="#pane-filesystem" type="button" role="tab">Import From Filesystem</button>
    </li>
</ul>

<div class="tab-content pt-3">
    <div class="tab-pane fade show active" id="pane-upload" role="tabpanel" aria-labelledby="tab-upload">
        <form asp-controller="Games" asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Files" class="form-label"></label>
                <input asp-for="Files" type="file" multiple class="form-control" disabled="@(!Model.LibretroAvailable)" />
                <span asp-validation-for="Files" class="text-danger"></span>
                <div class="form-text">
                    Upload one or more ROM/track files, or a .zip. We'll scan files (and files inside zips) and match them against libretro-database.
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@(!Model.LibretroAvailable)">Save</button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </form>
    </div>

    <div class="tab-pane fade" id="pane-web" role="tabpanel" aria-labelledby="tab-web">
        @if (Model.WebSources.Count == 0)
        {
            <div class="alert alert-info mb-0">
                No web sources configured. Add one in <a asp-controller="Sources" asp-action="Index">Sources</a>.
            </div>
        }
        else
        {
            <form asp-controller="WebSourceImport" asp-action="StartScan" method="post" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sessionId" value="@Model.WebScanSessionId" />

                <div class="col-md-4">
                    <label class="form-label">Website</label>
                    <select name="webSourceId" class="form-select">
                        @foreach (var src in Model.WebSources)
                        {
                            <option value="@src.Id" selected="@(Model.SelectedWebSourceId == src.Id)">@src.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Search</label>
                    <input name="q" class="form-control" placeholder="Optional filename contains…" value="@Model.WebQuery" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100" disabled="@(!Model.LibretroAvailable)">Start scan (job)</button>
                </div>
            </form>

            <div class="mt-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="fw-semibold">Scan results</div>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Jobs" asp-action="Index">Jobs</a>
                </div>

                <div id="web-scan-status" class="text-muted mb-2">No scan yet.</div>

                <form id="web-scan-import-form" asp-controller="WebSourceImport" asp-action="Import" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sessionId" value="@Model.WebScanSessionId" />
                    <input type="hidden" id="web-scan-import-source-id" name="webSourceId" value="" />

                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle mb-2">
                            <thead>
                                <tr>
                                    <th style="width:2.5rem;"><input type="checkbox" class="form-check-input" id="web-scan-select-all" /></th>
                                    <th>File</th>
                                    <th>URL</th>
                                </tr>
                            </thead>
                            <tbody id="web-scan-results-body">
                                <tr><td colspan="3" class="text-muted">No results.</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="web-scan-prev" disabled>Previous</button>
                        <div class="text-muted small" id="web-scan-page"></div>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="web-scan-next" disabled>Next</button>
                    </div>

                    <div class="d-flex align-items-center justify-content-between">
                        <div class="text-muted small" id="web-scan-selected-count"></div>
                        <button type="submit" id="web-scan-import-btn" class="btn btn-sm btn-primary" disabled>Import selected</button>
                    </div>
                </form>
            </div>

            <script>
                (function () {
                    var sessionId = "@Model.WebScanSessionId";
                    var statusEl = document.getElementById("web-scan-status");
                    var body = document.getElementById("web-scan-results-body");
                    var importBtn = document.getElementById("web-scan-import-btn");
                    var countEl = document.getElementById("web-scan-selected-count");
                    var selectAll = document.getElementById("web-scan-select-all");
                    var sourceIdInput = document.getElementById("web-scan-import-source-id");
                    var pagerEl = document.getElementById("web-scan-page");
                    var prevBtn = document.getElementById("web-scan-prev");
                    var nextBtn = document.getElementById("web-scan-next");
                    var form = document.getElementById("web-scan-import-form");

                    var selected = new Set();
                    var lastRenderKey = "";
                    var lastRunId = null;
                    var pauseUntil = 0;
                    var page = 1;
                    var pageSize = 100;
                    var pageCount = 1;

                    function setPaused(ms) {
                        pauseUntil = Math.max(pauseUntil, Date.now() + ms);
                    }

                    function updatePager() {
                        if (pagerEl) {
                            pagerEl.textContent = pageCount > 0 ? ("Page " + page + " / " + pageCount) : "";
                        }
                        if (prevBtn) prevBtn.disabled = page <= 1;
                        if (nextBtn) nextBtn.disabled = pageCount <= 1 || page >= pageCount;
                    }

                    function updateBulk() {
                        var checks = Array.prototype.slice.call(document.querySelectorAll("input.web-scan-select"));
                        var checkedOnPage = checks.filter(function (c) { return c.checked; }).length;
                        var count = selected.size;
                        if (importBtn) importBtn.disabled = count === 0;
                        if (countEl) countEl.textContent = count === 0 ? "" : (count + " selected");
                        if (selectAll) selectAll.checked = checkedOnPage > 0 && checkedOnPage === checks.length;
                    }

                    if (selectAll) {
                        selectAll.addEventListener("change", function () {
                            var checks = Array.prototype.slice.call(document.querySelectorAll("input.web-scan-select"));
                            checks.forEach(function (c) {
                                c.checked = selectAll.checked;
                                var id = parseInt(c.value, 10);
                                if (Number.isFinite(id)) {
                                    if (c.checked) selected.add(id); else selected.delete(id);
                                }
                            });
                            updateBulk();
                        });
                    }

                    if (prevBtn) {
                        prevBtn.addEventListener("click", function () {
                            page = Math.max(1, page - 1);
                            setPaused(250);
                            poll();
                        });
                    }

                    if (nextBtn) {
                        nextBtn.addEventListener("click", function () {
                            page = Math.min(pageCount, page + 1);
                            setPaused(250);
                            poll();
                        });
                    }

                    if (form) {
                        form.addEventListener("submit", function () {
                            Array.prototype.slice.call(form.querySelectorAll("input.web-scan-result-hidden")).forEach(function (n) { n.remove(); });
                            Array.from(selected.values()).forEach(function (id) {
                                var input = document.createElement("input");
                                input.type = "hidden";
                                input.name = "resultIds";
                                input.value = String(id);
                                input.className = "web-scan-result-hidden";
                                form.appendChild(input);
                            });
                        });
                    }

                    function render(results) {
                        if (!body) return;
                        if (Date.now() < pauseUntil) return;
                        body.innerHTML = "";
                        if (!results || results.length === 0) {
                            body.innerHTML = "<tr><td colspan='3' class='text-muted'>No results.</td></tr>";
                            updateBulk();
                            return;
                        }

                        var frag = document.createDocumentFragment();
                        results.forEach(function (r) {
                            var tr = document.createElement("tr");

                            var tdCheck = document.createElement("td");
                            var check = document.createElement("input");
                            check.type = "checkbox";
                            check.className = "form-check-input web-scan-select";
                            check.value = String(r.id);
                            check.checked = selected.has(r.id);
                            check.addEventListener("change", function () {
                                var id = parseInt(check.value, 10);
                                if (Number.isFinite(id)) {
                                    if (check.checked) selected.add(id); else selected.delete(id);
                                }
                                updateBulk();
                            });
                            tdCheck.appendChild(check);

                            var tdName = document.createElement("td");
                            tdName.className = "text-truncate";
                            tdName.style.maxWidth = "24rem";
                            tdName.textContent = r.fileName || "";

                            var tdUrl = document.createElement("td");
                            tdUrl.className = "text-truncate text-muted";
                            tdUrl.style.maxWidth = "34rem";
                            tdUrl.textContent = r.url || "";

                            tr.appendChild(tdCheck);
                            tr.appendChild(tdName);
                            tr.appendChild(tdUrl);
                            frag.appendChild(tr);
                        });
                        body.appendChild(frag);
                        updateBulk();
                    }

                    if (body) {
                        body.addEventListener("pointerdown", function () { setPaused(1500); });
                        body.addEventListener("keydown", function () { setPaused(1500); });
                        body.addEventListener("pointerenter", function () { setPaused(500); });
                    }

                    async function poll() {
                        try {
                            var res = await fetch("/WebSourceImport/Results?sessionId=" + encodeURIComponent(sessionId) + "&page=" + encodeURIComponent(String(page)) + "&pageSize=" + encodeURIComponent(String(pageSize)), { cache: "no-store" });
                            if (!res.ok) return;
                            var data = await res.json();
                            if (!data.found) return;
                            if (data.runId && String(data.runId) !== String(lastRunId || "")) {
                                lastRunId = data.runId;
                                selected.clear();
                                page = 1;
                                lastRenderKey = "";
                            }
                            if (data.page != null && page === 1 && data.page !== 1) {
                                setTimeout(poll, 0);
                                return;
                            }
                            if (sourceIdInput && data.webSourceId) sourceIdInput.value = data.webSourceId;
                            if (statusEl) {
                                var p = data.progressPermille != null ? (" - " + (data.progressPermille / 10.0).toFixed(1) + "%") : "";
                                statusEl.textContent = "Latest scan (" + data.sourceName + "): job #" + data.jobId + " - " + data.status + p;
                            }
                            if (data.page != null) page = data.page;
                            if (data.pageCount != null) pageCount = data.pageCount;
                            updatePager();
                            var ids = (data.results || []).map(function (r) { return r.id; });
                            var key = String(data.runId || "") + ":" + String(ids.length) + ":" + ids.join(",");
                            if (key !== lastRenderKey) {
                                lastRenderKey = key;
                                render(data.results);
                            }
                        } catch {
                        }
                    }

                    poll();
                    setInterval(poll, 2000);
                })();
            </script>
        }
    </div>

    <div class="tab-pane fade" id="pane-share" role="tabpanel" aria-labelledby="tab-share">
        @if (Model.NetworkShares.Count == 0)
        {
            <div class="alert alert-info mb-0">
                No network shares configured. Add one in <a asp-controller="Sources" asp-action="Index">Sources</a>.
            </div>
        }
        else
        {
            <form asp-controller="NetworkImport" asp-action="StartScan" method="post" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sessionId" value="@Model.NetworkScanSessionId" />

                <div class="col-md-4">
                    <label class="form-label">Share</label>
                    <select name="networkShareId" class="form-select">
                        @foreach (var share in Model.NetworkShares)
                        {
                            <option value="@share.Id" selected="@(Model.SelectedNetworkShareId == share.Id)">@share.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label">Search</label>
                    <input name="q" class="form-control" placeholder="Optional filename contains…" value="@Model.NetworkQuery" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary w-100" disabled="@(!Model.LibretroAvailable)">Start scan (job)</button>
                </div>
            </form>

            <div class="mt-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="fw-semibold">Scan results</div>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Jobs" asp-action="Index">Jobs</a>
                </div>

                <div id="scan-status" class="text-muted mb-2">No scan yet.</div>

                <form id="scan-import-form" asp-controller="NetworkImport" asp-action="Import" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sessionId" value="@Model.NetworkScanSessionId" />
                    <input type="hidden" id="scan-import-share-id" name="networkShareId" value="" />

                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle mb-2">
                            <thead>
                                <tr>
                                    <th style="width:2.5rem;"><input type="checkbox" class="form-check-input" id="scan-select-all" /></th>
                                    <th>File</th>
                                    <th class="text-end">Size</th>
                                    <th>Modified</th>
                                </tr>
                            </thead>
                            <tbody id="scan-results-body">
                                <tr><td colspan="4" class="text-muted">Start a scan to see results.</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="scan-prev" disabled>Previous</button>
                        <div class="text-muted small" id="scan-page"></div>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="scan-next" disabled>Next</button>
                    </div>

                    <div class="d-flex align-items-center justify-content-between">
                        <div class="text-muted small" id="scan-selected-count"></div>
                        <button type="submit" class="btn btn-sm btn-primary" id="scan-import-btn" disabled>Import selected</button>
                    </div>
                </form>
            </div>

            <script>
                (function () {
                    var sessionId = "@Model.NetworkScanSessionId";
                    var statusEl = document.getElementById("scan-status");
                    var body = document.getElementById("scan-results-body");
                    var selectAll = document.getElementById("scan-select-all");
                    var importBtn = document.getElementById("scan-import-btn");
                    var countEl = document.getElementById("scan-selected-count");
                    var shareIdInput = document.getElementById("scan-import-share-id");
                    var pagerEl = document.getElementById("scan-page");
                    var prevBtn = document.getElementById("scan-prev");
                    var nextBtn = document.getElementById("scan-next");
                    var form = document.getElementById("scan-import-form");
                    var selected = new Set();
                    var pauseUntil = 0;
                    var lastRenderKey = "";
                    var lastRunId = null;
                    var page = 1;
                    var pageSize = 100;
                    var pageCount = 1;

                    function setPaused(ms) {
                        pauseUntil = Math.max(pauseUntil, Date.now() + ms);
                    }

                    function updatePager() {
                        if (pagerEl) {
                            pagerEl.textContent = pageCount > 0 ? ("Page " + page + " / " + pageCount) : "";
                        }
                        if (prevBtn) prevBtn.disabled = page <= 1;
                        if (nextBtn) nextBtn.disabled = pageCount <= 1 || page >= pageCount;
                    }

                    function updateBulk() {
                        var checks = Array.prototype.slice.call(document.querySelectorAll("input.scan-select"));
                        var checkedOnPage = checks.filter(function (c) { return c.checked; }).length;
                        var count = selected.size;
                        if (importBtn) importBtn.disabled = count === 0;
                        if (countEl) countEl.textContent = count === 0 ? "" : (count + " selected");
                        if (selectAll) selectAll.checked = checkedOnPage > 0 && checkedOnPage === checks.length;
                    }

                    if (selectAll) {
                        selectAll.addEventListener("change", function () {
                            var checks = Array.prototype.slice.call(document.querySelectorAll("input.scan-select"));
                            checks.forEach(function (c) {
                                c.checked = selectAll.checked;
                                var id = parseInt(c.value, 10);
                                if (Number.isFinite(id)) {
                                    if (c.checked) selected.add(id); else selected.delete(id);
                                }
                            });
                            updateBulk();
                        });
                    }

                    if (prevBtn) {
                        prevBtn.addEventListener("click", function () {
                            page = Math.max(1, page - 1);
                            setPaused(250);
                            poll();
                        });
                    }

                    if (nextBtn) {
                        nextBtn.addEventListener("click", function () {
                            page = Math.min(pageCount, page + 1);
                            setPaused(250);
                            poll();
                        });
                    }

                    if (form) {
                        form.addEventListener("submit", function () {
                            Array.prototype.slice.call(form.querySelectorAll("input.scan-result-hidden")).forEach(function (n) { n.remove(); });
                            Array.from(selected.values()).forEach(function (id) {
                                var input = document.createElement("input");
                                input.type = "hidden";
                                input.name = "resultIds";
                                input.value = String(id);
                                input.className = "scan-result-hidden";
                                form.appendChild(input);
                            });
                        });
                    }

                    function render(results) {
                        if (!body) return;
                        if (Date.now() < pauseUntil) return;
                        body.innerHTML = "";
                        if (!results || results.length === 0) {
                            body.innerHTML = "<tr><td colspan='4' class='text-muted'>No results.</td></tr>";
                            updateBulk();
                            return;
                        }

                        var frag = document.createDocumentFragment();
                        results.forEach(function (r) {
                            var tr = document.createElement("tr");

                            var tdCheck = document.createElement("td");
                            var check = document.createElement("input");
                            check.type = "checkbox";
                            check.className = "form-check-input scan-select";
                            check.value = String(r.id);
                            check.checked = selected.has(r.id);
                            check.addEventListener("change", function () {
                                var id = parseInt(check.value, 10);
                                if (Number.isFinite(id)) {
                                    if (check.checked) selected.add(id); else selected.delete(id);
                                }
                                updateBulk();
                            });
                            tdCheck.appendChild(check);

                            var tdName = document.createElement("td");
                            tdName.className = "text-truncate";
                            tdName.style.maxWidth = "38rem";
                            tdName.textContent = r.fileName || "";

                            var tdSize = document.createElement("td");
                            tdSize.className = "text-end";
                            tdSize.textContent = r.sizeBytes != null ? String(r.sizeBytes) : "";

                            var tdMod = document.createElement("td");
                            tdMod.textContent = r.lastWriteUtc ? String(r.lastWriteUtc) : "";

                            tr.appendChild(tdCheck);
                            tr.appendChild(tdName);
                            tr.appendChild(tdSize);
                            tr.appendChild(tdMod);
                            frag.appendChild(tr);
                        });
                        body.appendChild(frag);
                        updateBulk();
                    }

                    if (body) {
                        body.addEventListener("pointerdown", function () { setPaused(1500); });
                        body.addEventListener("keydown", function () { setPaused(1500); });
                        body.addEventListener("pointerenter", function () { setPaused(500); });
                    }

                    async function poll() {
                        try {
                            var res = await fetch("/NetworkImport/Results?sessionId=" + encodeURIComponent(sessionId) + "&page=" + encodeURIComponent(String(page)) + "&pageSize=" + encodeURIComponent(String(pageSize)), { cache: "no-store" });
                            if (!res.ok) return;
                            var data = await res.json();
                            if (!data.found) return;
                            if (data.runId && String(data.runId) !== String(lastRunId || "")) {
                                lastRunId = data.runId;
                                selected.clear();
                                page = 1;
                                lastRenderKey = "";
                            }
                            if (data.page != null && page === 1 && data.page !== 1) {
                                setTimeout(poll, 0);
                                return;
                            }
                            if (shareIdInput && data.networkShareId) shareIdInput.value = data.networkShareId;
                            if (statusEl) {
                                var p = data.progressPermille != null ? (" - " + (data.progressPermille / 10.0).toFixed(1) + "%") : "";
                                statusEl.textContent = "Latest scan (" + data.shareName + "): job #" + data.jobId + " - " + data.status + p;
                            }
                            if (data.page != null) page = data.page;
                            if (data.pageCount != null) pageCount = data.pageCount;
                            updatePager();
                            var ids = (data.results || []).map(function (r) { return r.id; });
                            var key = String(data.runId || "") + ":" + String(ids.length) + ":" + ids.join(",");
                            if (key !== lastRenderKey) {
                                lastRenderKey = key;
                                render(data.results);
                            }
                        } catch (e) { }
                    }

                    setInterval(poll, 2000);
                    poll();
                })();
            </script>
        }
    </div>

    <div class="tab-pane fade" id="pane-filesystem" role="tabpanel" aria-labelledby="tab-filesystem">
        @if (Model.LocalFolders.Count == 0)
        {
            <div class="alert alert-info mb-0">
                No local folders configured. Add one in <a asp-controller="Sources" asp-action="Index">Sources</a>.
            </div>
        }
        else
        {
            <form asp-controller="LocalFolderImport" asp-action="StartScan" method="post" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sessionId" value="@Model.LocalScanSessionId" />

                <div class="col-md-4">
                    <label class="form-label">Folder</label>
                    <select name="localFolderId" class="form-select">
                        @foreach (var f in Model.LocalFolders)
                        {
                            <option value="@f.Id" selected="@(Model.SelectedLocalFolderId == f.Id)">@f.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Search</label>
                    <input name="q" class="form-control" placeholder="Optional filename contains…" value="@Model.LocalQuery" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100" disabled="@(!Model.LibretroAvailable)">Start scan (job)</button>
                </div>
            </form>

            <div class="mt-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="fw-semibold">Scan results</div>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Jobs" asp-action="Index">Jobs</a>
                </div>

                <div id="local-scan-status" class="text-muted mb-2">No scan yet.</div>

                <form id="local-scan-import-form" asp-controller="LocalFolderImport" asp-action="Import" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sessionId" value="@Model.LocalScanSessionId" />
                    <input type="hidden" id="local-scan-import-folder-id" name="localFolderId" value="" />

                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mode" id="local-import-copy" value="copy" checked />
                            <label class="form-check-label" for="local-import-copy">Copy into library</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mode" id="local-import-link" value="link" />
                            <label class="form-check-label" for="local-import-link">Link to files (no copy)</label>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle mb-2">
                            <thead>
                                <tr>
                                    <th style="width:2.5rem;"><input type="checkbox" class="form-check-input" id="local-scan-select-all" /></th>
                                    <th>File</th>
                                    <th class="text-end">Size</th>
                                    <th>Modified</th>
                                    <th>Path</th>
                                </tr>
                            </thead>
                            <tbody id="local-scan-results-body">
                                <tr><td colspan="5" class="text-muted">No results.</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="local-scan-prev" disabled>Previous</button>
                        <div class="text-muted small" id="local-scan-page"></div>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="local-scan-next" disabled>Next</button>
                    </div>

                    <div class="d-flex align-items-center justify-content-between">
                        <div class="text-muted small" id="local-scan-selected-count"></div>
                        <button type="submit" id="local-scan-import-btn" class="btn btn-sm btn-primary" disabled>Import selected</button>
                    </div>
                </form>
            </div>

            <script>
                (function () {
                    var sessionId = "@Model.LocalScanSessionId";
                    var statusEl = document.getElementById("local-scan-status");
                    var body = document.getElementById("local-scan-results-body");
                    var importBtn = document.getElementById("local-scan-import-btn");
                    var countEl = document.getElementById("local-scan-selected-count");
                    var selectAll = document.getElementById("local-scan-select-all");
                    var folderIdInput = document.getElementById("local-scan-import-folder-id");
                    var pagerEl = document.getElementById("local-scan-page");
                    var prevBtn = document.getElementById("local-scan-prev");
                    var nextBtn = document.getElementById("local-scan-next");
                    var form = document.getElementById("local-scan-import-form");

                    var selected = new Set();
                    var lastRenderKey = "";
                    var lastRunId = null;
                    var pauseUntil = 0;
                    var page = 1;
                    var pageSize = 100;
                    var pageCount = 1;

                    function setPaused(ms) { pauseUntil = Math.max(pauseUntil, Date.now() + ms); }

                    function updatePager() {
                        if (pagerEl) {
                            pagerEl.textContent = pageCount > 0 ? ("Page " + page + " / " + pageCount) : "";
                        }
                        if (prevBtn) prevBtn.disabled = page <= 1;
                        if (nextBtn) nextBtn.disabled = pageCount <= 1 || page >= pageCount;
                    }

                    function updateBulk() {
                        var checks = Array.prototype.slice.call(document.querySelectorAll("input.local-scan-select"));
                        var checkedOnPage = checks.filter(function (c) { return c.checked; }).length;
                        var count = selected.size;
                        if (importBtn) importBtn.disabled = count === 0;
                        if (countEl) countEl.textContent = count === 0 ? "" : (count + " selected");
                        if (selectAll) selectAll.checked = checkedOnPage > 0 && checkedOnPage === checks.length;
                    }

                    if (selectAll) {
                        selectAll.addEventListener("change", function () {
                            var checks = Array.prototype.slice.call(document.querySelectorAll("input.local-scan-select"));
                            checks.forEach(function (c) {
                                c.checked = selectAll.checked;
                                var id = parseInt(c.value, 10);
                                if (Number.isFinite(id)) {
                                    if (c.checked) selected.add(id); else selected.delete(id);
                                }
                            });
                            updateBulk();
                        });
                    }

                    if (prevBtn) {
                        prevBtn.addEventListener("click", function () {
                            page = Math.max(1, page - 1);
                            setPaused(250);
                            poll();
                        });
                    }

                    if (nextBtn) {
                        nextBtn.addEventListener("click", function () {
                            page = Math.min(pageCount, page + 1);
                            setPaused(250);
                            poll();
                        });
                    }

                    if (form) {
                        form.addEventListener("submit", function () {
                            Array.prototype.slice.call(form.querySelectorAll("input.local-scan-result-hidden")).forEach(function (n) { n.remove(); });
                            Array.from(selected.values()).forEach(function (id) {
                                var input = document.createElement("input");
                                input.type = "hidden";
                                input.name = "resultIds";
                                input.value = String(id);
                                input.className = "local-scan-result-hidden";
                                form.appendChild(input);
                            });
                        });
                    }

                    function render(results) {
                        if (!body) return;
                        if (Date.now() < pauseUntil) return;
                        body.innerHTML = "";
                        if (!results || results.length === 0) {
                            body.innerHTML = "<tr><td colspan='5' class='text-muted'>No results.</td></tr>";
                            updateBulk();
                            return;
                        }

                        var frag = document.createDocumentFragment();
                        results.forEach(function (r) {
                            var tr = document.createElement("tr");

                            var tdCheck = document.createElement("td");
                            var check = document.createElement("input");
                            check.type = "checkbox";
                            check.className = "form-check-input local-scan-select";
                            check.value = String(r.id);
                            check.checked = selected.has(r.id);
                            check.addEventListener("change", function () {
                                var id = parseInt(check.value, 10);
                                if (Number.isFinite(id)) {
                                    if (check.checked) selected.add(id); else selected.delete(id);
                                }
                                updateBulk();
                            });
                            tdCheck.appendChild(check);

                            var tdName = document.createElement("td");
                            tdName.className = "text-truncate";
                            tdName.style.maxWidth = "18rem";
                            tdName.textContent = r.fileName || "";

                            var tdSize = document.createElement("td");
                            tdSize.className = "text-end";
                            tdSize.textContent = r.sizeBytes != null ? String(r.sizeBytes) : "";

                            var tdMod = document.createElement("td");
                            tdMod.textContent = r.lastWriteUtc ? String(r.lastWriteUtc) : "";

                            var tdPath = document.createElement("td");
                            tdPath.className = "text-truncate text-muted";
                            tdPath.style.maxWidth = "32rem";
                            tdPath.textContent = r.fullPath || "";

                            tr.appendChild(tdCheck);
                            tr.appendChild(tdName);
                            tr.appendChild(tdSize);
                            tr.appendChild(tdMod);
                            tr.appendChild(tdPath);
                            frag.appendChild(tr);
                        });
                        body.appendChild(frag);
                        updateBulk();
                    }

                    if (body) {
                        body.addEventListener("pointerdown", function () { setPaused(1500); });
                        body.addEventListener("keydown", function () { setPaused(1500); });
                        body.addEventListener("pointerenter", function () { setPaused(500); });
                    }

                    async function poll() {
                        try {
                            var res = await fetch("/LocalFolderImport/Results?sessionId=" + encodeURIComponent(sessionId) + "&page=" + encodeURIComponent(String(page)) + "&pageSize=" + encodeURIComponent(String(pageSize)), { cache: "no-store" });
                            if (!res.ok) return;
                            var data = await res.json();
                            if (!data.found) return;
                            if (data.runId && String(data.runId) !== String(lastRunId || "")) {
                                lastRunId = data.runId;
                                selected.clear();
                                page = 1;
                                lastRenderKey = "";
                            }
                            if (data.page != null && page === 1 && data.page !== 1) {
                                setTimeout(poll, 0);
                                return;
                            }
                            if (folderIdInput && data.localFolderId) folderIdInput.value = data.localFolderId;
                            if (statusEl) {
                                var p = data.progressPermille != null ? (" - " + (data.progressPermille / 10.0).toFixed(1) + "%") : "";
                                statusEl.textContent = "Latest scan (" + data.folderName + "): job #" + data.jobId + " - " + data.status + p;
                            }
                            if (data.page != null) page = data.page;
                            if (data.pageCount != null) pageCount = data.pageCount;
                            updatePager();
                            var ids = (data.results || []).map(function (r) { return r.id; });
                            var key = String(data.runId || "") + ":" + String(ids.length) + ":" + ids.join(",");
                            if (key !== lastRenderKey) {
                                lastRenderKey = key;
                                render(data.results);
                            }
                        } catch {
                        }
                    }

                    poll();
                    setInterval(poll, 2000);
                })();
            </script>
        }
    </div>
</div>

<script>
    (function () {
        function showInitialTab() {
            var tabs = document.getElementById("addgame-tabs");
            if (!tabs) return;

            var initial = tabs.getAttribute("data-initial-tab") || "upload";
            var id = initial === "web"
                ? "tab-web"
                : initial === "share"
                    ? "tab-share"
                    : initial === "filesystem"
                        ? "tab-filesystem"
                        : "tab-upload";

            var btn = document.getElementById(id);
            if (!btn) return;

            try {
                if (window.bootstrap && window.bootstrap.Tab) {
                    window.bootstrap.Tab.getOrCreateInstance(btn).show();
                } else {
                    btn.click();
                }
            } catch { }
        }

        // This partial renders before `bootstrap.bundle.min.js` is loaded (see `_Layout.cshtml`),
        // so we wait for DOMContentLoaded to ensure Bootstrap tab behavior is registered.
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", showInitialTab);
        } else {
            showInitialTab();
        }
    })();
</script>
