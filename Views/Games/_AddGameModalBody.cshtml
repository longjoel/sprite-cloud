@model games_vault.Models.ViewModels.GameUploadCreateViewModel

@{
    var inlineAddGame = ViewData["InlineAddGame"] as bool? == true;
}

@if (!Model.LibretroAvailable)
{
    <div class="alert alert-warning">
        <div class="fw-semibold mb-1">Libretro database not synced yet</div>
        <div class="mb-2">
            Upload matching requires libretro-database `.dat` files. Start a sync job first, then come back here.
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <form asp-controller="Games" asp-action="StartLibretroSync" method="post" class="mb-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-primary">Start libretro sync</button>
            </form>
        </div>
    </div>
}

<form asp-controller="Games" asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Files" class="form-label"></label>
        <input asp-for="Files"
               type="file"
               multiple
               class="form-control"
               accept=".zip,.7z,.z64,.n64,.v64,.nes,.fds,.sfc,.smc,.gb,.gbc,.gba,.nds,.bin,.cue,.chd,.iso,.md,.gen,.32x,.sms,.gg,.pce,.sg"
               disabled="@(!Model.LibretroAvailable)" />
        <span asp-validation-for="Files" class="text-danger"></span>
        <div class="form-text">
            Upload one or more ROM/track files, or a .zip. We'll scan files (and files inside zips) and match them against libretro-database.
        </div>
        <div class="form-text">
            On phones/tablets, use your device's <span class="fw-semibold">Files</span> picker if the media picker opens first — archive uploads like <code>.zip</code> and N64 ROM files are allowed here.
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" disabled="@(!Model.LibretroAvailable)">Save</button>
        @if (inlineAddGame)
        {
            <a class="btn btn-outline-secondary" asp-controller="Games" asp-action="Index">Back to browse</a>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
        }
    </div>
</form>
