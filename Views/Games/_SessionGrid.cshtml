@model games_vault.Models.ViewModels.ServerGamePlayViewModel
@{
    var hasLiveSession = string.IsNullOrWhiteSpace(Model.Error) && !string.IsNullOrWhiteSpace(Model.BaseUrl);
}

@if (hasLiveSession)
{
    <div id="playserver-session-grid" class="playserver-live-grid">
        <div class="playserver-main-column">

<div id="server-player-shell" class="server-player-shell bg-dark rounded p-2" tabindex="0" aria-label="Game player surface">
    <canvas id="nosebleed-screen" class="rounded border border-secondary"></canvas>
    <video id="nosebleed-screen-video" class="rounded border border-secondary d-none" autoplay playsinline webkit-playsinline muted></video>
    <audio id="nosebleed-rtc-audio" class="d-none" autoplay playsinline webkit-playsinline muted></audio>
    @await Html.PartialAsync("~/Views/Games/_PlayerHUD.cshtml", Model)
    @await Html.PartialAsync("~/Views/Games/_ConnectionDiagnostics.cshtml", Model)
    @await Html.PartialAsync("~/Views/Games/_TouchLayout.cshtml", Model)
</div>

        </div>

        <aside class="playserver-sidebar-column">
            @await Html.PartialAsync("~/Views/Games/_ArcadeSeatPanel.cshtml", Model)
            @await Html.PartialAsync("~/Views/Games/_RoomChat.cshtml", Model)
            @await Html.PartialAsync("~/Views/Games/_SessionConfig.cshtml", Model)
        </aside>

    </div>
}
else
{
    <div class="text-muted">Once configured, the server-side player will appear here.</div>
}
