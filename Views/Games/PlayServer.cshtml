@model games_vault.Models.ViewModels.ServerGamePlayViewModel

@{
    var game = Model.Game;
    var systemName = game.SystemName ?? string.Empty;
    var isGameGear = systemName.Equals("Sega - Game Gear", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("Game Gear", StringComparison.OrdinalIgnoreCase);
    var isGenesis = systemName.Equals("Sega - Mega Drive - Genesis", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("Mega Drive", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("Genesis", StringComparison.OrdinalIgnoreCase);
    var isArcade = systemName.Contains("Arcade", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("MAME", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("FinalBurn", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("FBNeo", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("Neo Geo", StringComparison.OrdinalIgnoreCase);
    var touchLayoutName = isGameGear
        ? "Sega Game Gear"
        : isGenesis
            ? "Sega Genesis"
            : isArcade
                ? "Arcade 4-Button"
                : "Generic Retropad";
    var hasLiveSession = string.IsNullOrWhiteSpace(Model.Error) && !string.IsNullOrWhiteSpace(Model.BaseUrl);
    var sessionTitle = game.Name;
    ViewData["Title"] = sessionTitle;
    var sessionStateLabel = Model.IsSpectator
        ? "Watching"
        : Model.PlayerNumber is int playerNumber
            ? $"Player {playerNumber}"
            : "Ready";
}

<div class="playserver-hero d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">@sessionTitle</h1>
    </div>
    <div class="d-flex flex-wrap gap-2 align-items-center justify-content-end">
        <span class="badge text-bg-success-subtle border border-success-subtle">@sessionStateLabel</span>
    </div>
</div>

@if (Model.ShowRoomControls)
{
    <div class="card mb-3">
        <div class="card-body d-flex flex-wrap align-items-center gap-2 justify-content-between">
            <div>
                <div class="fw-semibold">Play</div>
                <div class="text-muted small">Open a fresh session from this game page whenever you want a new instance.</div>
            </div>
            <form asp-action="CreateRoom" asp-route-id="@game.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-success">Play</button>
            </form>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-warning">
        <div class="fw-semibold mb-1">Player is not ready</div>
        <div>@Model.Error</div>
        <div class="mt-2 text-muted small">
            Expected setup: Nosebleed binary installed, native libretro core mapped for this system, and ROM readable from local storage.
        </div>
    </div>
}

<div class="card playserver-session-surface">
    <div class="card-body p-lg-4">
        @if (hasLiveSession)
        {
            <div id="playserver-session-grid" class="playserver-live-grid">
                <div class="playserver-main-column">
            <style>
                .server-player-shell {
                    position: relative;
                    overflow: hidden;
                    touch-action: none;
                    user-select: none;
                }

                #nosebleed-screen {
                    display: block;
                    image-rendering: pixelated;
                    background: #000;
                    max-width: 100%;
                    max-height: 70vh;
                    width: auto;
                    height: auto;
                    margin-inline: auto;
                    touch-action: none;
                    object-fit: contain;
                }

                .server-player-shell:fullscreen,
                .server-player-shell.is-ios-fullscreen {
                    width: 100vw;
                    height: 100vh;
                    height: 100dvh;
                    border-radius: 0 !important;
                    padding: 0 !important;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: #000 !important;
                }

                .server-player-shell.is-ios-fullscreen {
                    position: fixed;
                    inset: 0;
                    z-index: 2147483000;
                }

                html.games-vault-player-fullscreen,
                body.games-vault-player-fullscreen {
                    overflow: hidden !important;
                    overscroll-behavior: none;
                }

                .server-player-shell:fullscreen #nosebleed-screen,
                .server-player-shell.is-ios-fullscreen #nosebleed-screen {
                    width: 100vw !important;
                    height: 100vh !important;
                    height: 100dvh !important;
                    max-height: none !important;
                    object-fit: contain;
                    border: 0 !important;
                    border-radius: 0 !important;
                }

                .touch-gamepad {
                    position: absolute;
                    inset: 0;
                    display: none;
                    pointer-events: none;
                    z-index: 5;
                }

                .touch-gamepad.is-visible {
                    display: block;
                }

                .touch-gamepad .pad-cluster,
                .touch-gamepad .face-cluster,
                .touch-gamepad .menu-cluster {
                    position: absolute;
                    pointer-events: auto;
                }

                .touch-gamepad .pad-cluster {
                    left: max(1rem, env(safe-area-inset-left));
                    bottom: max(1rem, env(safe-area-inset-bottom));
                    width: 9.5rem;
                    height: 9.5rem;
                }

                .touch-gamepad .face-cluster {
                    right: max(1rem, env(safe-area-inset-right));
                    bottom: max(1.2rem, env(safe-area-inset-bottom));
                    width: 10.5rem;
                    height: 8rem;
                }

                .touch-gamepad .menu-cluster {
                    left: 50%;
                    bottom: max(1rem, env(safe-area-inset-bottom));
                    transform: translateX(-50%);
                    display: flex;
                    gap: .75rem;
                }

                .touch-btn {
                    position: absolute;
                    border: 1px solid rgba(255,255,255,.55);
                    background: rgba(15, 23, 42, .58);
                    color: rgba(255,255,255,.9);
                    backdrop-filter: blur(4px);
                    box-shadow: 0 .25rem 1rem rgba(0,0,0,.35);
                    touch-action: none;
                    -webkit-user-select: none;
                    user-select: none;
                }

                .touch-btn.is-pressed {
                    background: rgba(13, 110, 253, .76);
                    transform: scale(.96);
                }

                .touch-btn.dpad {
                    width: 3.1rem;
                    height: 3.1rem;
                    border-radius: .85rem;
                    font-weight: 700;
                }

                .touch-btn.face {
                    width: 4rem;
                    height: 4rem;
                    border-radius: 999px;
                    font-weight: 800;
                    font-size: 1.2rem;
                }

                .touch-btn.menu {
                    position: static;
                    min-width: 4.5rem;
                    border-radius: 999px;
                    padding: .55rem .85rem;
                    font-weight: 700;
                }

                .touch-btn[data-button="up"] { left: 3.2rem; top: 0; }
                .touch-btn[data-button="left"] { left: 0; top: 3.2rem; }
                .touch-btn[data-button="right"] { right: 0; top: 3.2rem; }
                .touch-btn[data-button="down"] { left: 3.2rem; bottom: 0; }
                .touch-btn[data-button="b"] { left: 0; bottom: 0; }
                .touch-btn[data-button="a"] { right: 0; bottom: 1.4rem; }
                .touch-btn[data-button="y"] { left: 1.4rem; top: 0; }
                .touch-btn[data-button="x"] { right: 1.4rem; top: 0; }

                .touch-gamepad.layout-game-gear .face-cluster {
                    width: 9rem;
                    height: 5rem;
                    bottom: max(1.65rem, env(safe-area-inset-bottom));
                }

                .touch-gamepad.layout-game-gear .touch-btn.face {
                    width: 4.35rem;
                    height: 4.35rem;
                    font-size: 1.35rem;
                }

                .touch-gamepad.layout-game-gear .touch-btn[data-button="b"] { left: 0; bottom: 0; }
                .touch-gamepad.layout-game-gear .touch-btn[data-button="a"] { right: 0; bottom: 0; }

                .touch-gamepad.layout-game-gear .menu-cluster {
                    left: auto;
                    right: max(1.25rem, env(safe-area-inset-right));
                    bottom: max(6.55rem, calc(env(safe-area-inset-bottom) + 6.55rem));
                    transform: none;
                }

                .touch-gamepad.layout-game-gear .touch-btn.menu {
                    min-width: 4rem;
                    padding: .4rem .75rem;
                    font-size: .9rem;
                    opacity: .82;
                }

                .touch-gamepad.layout-genesis .face-cluster {
                    position: static;
                    pointer-events: none;
                }

                .touch-gamepad.layout-genesis .touch-btn.face {
                    width: 4.25rem;
                    height: 4.25rem;
                    font-size: 1.32rem;
                    pointer-events: auto;
                }

                .touch-gamepad.layout-genesis .touch-btn.face[data-button="y"] { left: auto; right: 9.9rem; bottom: max(1.35rem, env(safe-area-inset-bottom)); }
                .touch-gamepad.layout-genesis .touch-btn.face[data-button="b"] { left: auto; right: 5.45rem; bottom: max(2.75rem, calc(env(safe-area-inset-bottom) + 1.4rem)); }
                .touch-gamepad.layout-genesis .touch-btn.face[data-button="a"] { left: auto; right: max(1rem, env(safe-area-inset-right)); bottom: max(4.15rem, calc(env(safe-area-inset-bottom) + 2.8rem)); }

                .touch-gamepad.layout-genesis .menu-cluster {
                    left: 50%;
                    bottom: max(1rem, env(safe-area-inset-bottom));
                    transform: translateX(-50%);
                }

                .touch-gamepad.layout-genesis .touch-btn.menu[data-button="start"] {
                    min-width: 5rem;
                }

                .touch-gamepad.layout-arcade .face-cluster {
                    width: 16rem;
                    height: 6.8rem;
                    right: max(.75rem, env(safe-area-inset-right));
                    bottom: max(1.1rem, env(safe-area-inset-bottom));
                }

                .touch-gamepad.layout-arcade .touch-btn.face {
                    width: 3.8rem;
                    height: 3.8rem;
                    font-size: 1.15rem;
                }

                .touch-gamepad.layout-arcade .touch-btn.face[data-button="b"] { left: 0; bottom: 0; }
                .touch-gamepad.layout-arcade .touch-btn.face[data-button="a"] { left: 3.9rem; bottom: .65rem; }
                .touch-gamepad.layout-arcade .touch-btn.face[data-button="y"] { left: 7.8rem; bottom: 1.3rem; }
                .touch-gamepad.layout-arcade .touch-btn.face[data-button="x"] { left: 11.7rem; bottom: 1.95rem; }

                .touch-gamepad.layout-arcade .menu-cluster {
                    gap: .55rem;
                }

                .touch-gamepad.layout-arcade .touch-btn.menu {
                    min-width: 4rem;
                    padding: .45rem .72rem;
                    font-size: .9rem;
                }

                .player-overlay-action {
                    position: absolute;
                    top: max(.75rem, env(safe-area-inset-top));
                    right: max(1rem, env(safe-area-inset-right));
                    z-index: 7;
                    border: 1px solid rgba(255,255,255,.45);
                    background: rgba(15, 23, 42, .58);
                    color: rgba(255,255,255,.92);
                    border-radius: 999px;
                    padding: .38rem .72rem;
                    font-size: .84rem;
                    font-weight: 700;
                    backdrop-filter: blur(4px);
                    box-shadow: 0 .25rem 1rem rgba(0,0,0,.35);
                    touch-action: none;
                }

                .player-overlay-action.is-on {
                    background: rgba(25, 135, 84, .7);
                }

                .layout-lock-action {
                    left: max(1rem, env(safe-area-inset-left));
                    right: auto;
                }

                .layout-reset-action {
                    top: max(3.35rem, calc(env(safe-area-inset-top) + 3.35rem));
                    left: max(1rem, env(safe-area-inset-left));
                    right: auto;
                    padding-inline: .62rem;
                }

                .player-hud {
                    position: absolute;
                    top: max(.72rem, env(safe-area-inset-top));
                    left: 50%;
                    transform: translateX(-50%);
                    z-index: 6;
                    display: flex;
                    flex-wrap: wrap;
                    justify-content: center;
                    gap: .35rem;
                    max-width: min(68vw, 34rem);
                    pointer-events: none;
                }

                .player-hud-chip {
                    display: inline-flex;
                    align-items: center;
                    gap: .3rem;
                    min-height: 1.65rem;
                    border: 1px solid rgba(255,255,255,.32);
                    border-radius: 999px;
                    padding: .2rem .55rem;
                    background: rgba(15, 23, 42, .56);
                    color: rgba(255,255,255,.9);
                    font-size: .72rem;
                    font-weight: 800;
                    letter-spacing: .01em;
                    line-height: 1;
                    backdrop-filter: blur(4px);
                    box-shadow: 0 .25rem .9rem rgba(0,0,0,.3);
                    white-space: nowrap;
                }

                .player-hud-chip .chip-dot {
                    width: .48rem;
                    height: .48rem;
                    border-radius: 999px;
                    background: rgba(255,255,255,.45);
                    box-shadow: 0 0 .65rem rgba(255,255,255,.2);
                }

                .player-hud-chip.is-good .chip-dot { background: #20c997; box-shadow: 0 0 .65rem rgba(32,201,151,.75); }
                .player-hud-chip.is-warn .chip-dot { background: #ffc107; box-shadow: 0 0 .65rem rgba(255,193,7,.75); }
                .player-hud-chip.is-bad .chip-dot { background: #dc3545; box-shadow: 0 0 .65rem rgba(220,53,69,.75); }

                .player-hud-chip.status-chip {
                    max-width: 15rem;
                    overflow: hidden;
                    text-overflow: ellipsis;
                }

                @@media (max-width: 768px) {
                    .player-hud {
                        top: max(.48rem, env(safe-area-inset-top));
                        max-width: 58vw;
                        gap: .25rem;
                    }

                    .player-hud-chip {
                        min-height: 1.45rem;
                        padding: .16rem .42rem;
                        font-size: .64rem;
                    }

                    .player-hud-chip.status-chip {
                        max-width: 10rem;
                    }
                }

                .server-player-shell.layout-editing [data-control-group] {
                    outline: 2px dashed rgba(255,255,255,.75);
                    outline-offset: .3rem;
                    cursor: grab;
                }

                .server-player-shell.layout-editing [data-control-group].is-dragging {
                    cursor: grabbing;
                    opacity: .86;
                }

                .server-player-shell.overlays-hidden .player-hud,
                .server-player-shell.overlays-hidden .touch-gamepad,
                .server-player-shell.overlays-hidden .player-overlay-action {
                    display: none !important;
                }

                .playserver-session-surface {
                    border-radius: 1.5rem;
                    overflow: hidden;
                }

                .playserver-live-grid {
                    display: grid;
                    gap: 1.25rem;
                    grid-template-columns: minmax(0, 1.5fr) minmax(18rem, .9fr);
                    align-items: start;
                }

                .playserver-main-column,
                .playserver-sidebar-column {
                    min-width: 0;
                }

                .playserver-seat-strip {
                    display: grid;
                    grid-template-columns: repeat(4, minmax(0, 1fr));
                    gap: .75rem;
                }

                .playserver-utility-strip {
                    display: flex;
                    flex-wrap: wrap;
                    justify-content: space-between;
                    align-items: center;
                    gap: .75rem;
                }

                .playserver-utility-actions {
                    display: flex;
                    flex-wrap: wrap;
                    gap: .75rem;
                    align-items: center;
                }

                .playserver-advanced-controls {
                    border: 1px solid var(--bs-border-color);
                    border-radius: 1rem;
                    background: var(--bs-tertiary-bg);
                    padding: .85rem 1rem;
                }

                .playserver-advanced-controls > summary {
                    cursor: pointer;
                    font-weight: 600;
                    user-select: none;
                }

                .playserver-advanced-controls-body {
                    display: grid;
                    gap: .75rem;
                    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
                    align-items: start;
                }

                .playserver-chat-log {
                    max-height: 18rem;
                    overflow-y: auto;
                }

                @@media (max-width: 991.98px) {
                    .playserver-live-grid {
                        grid-template-columns: 1fr;
                    }

                    .playserver-seat-strip {
                        grid-template-columns: repeat(2, minmax(0, 1fr));
                    }
                }

                @@media (max-width: 575.98px) {
                    .playserver-seat-strip,
                    .playserver-advanced-controls-body {
                        grid-template-columns: 1fr;
                    }
                }

                @@media (hover: hover) and (pointer: fine) {
                    .touch-gamepad:not(.force-visible) { display: none !important; }
                }
            </style>

            <div id="server-player-shell" class="server-player-shell bg-dark rounded p-2">
                <canvas id="nosebleed-screen" class="rounded border border-secondary"></canvas>
                <video id="nosebleed-screen-video" class="rounded border border-secondary d-none" autoplay playsinline muted></video>
                <audio id="nosebleed-rtc-audio" class="d-none" autoplay playsinline muted></audio>
                <div id="nosebleed-player-hud" class="player-hud" aria-live="polite">
                    <span id="nosebleed-video-chip" class="player-hud-chip is-warn"><span class="chip-dot" aria-hidden="true"></span><span class="chip-label">Video idle</span></span>
                    <span id="nosebleed-input-chip" class="player-hud-chip is-warn"><span class="chip-dot" aria-hidden="true"></span><span class="chip-label">@(Model.IsSpectator ? "Spectator" : "Input idle")</span></span>
                    <span id="nosebleed-pad-chip" class="player-hud-chip"><span class="chip-dot" aria-hidden="true"></span><span class="chip-label">Pad none</span></span>
                    <span id="nosebleed-fps-chip" class="player-hud-chip"><span class="chip-dot" aria-hidden="true"></span><span class="chip-label">0 fps</span></span>
                    <span id="nosebleed-status-chip" class="player-hud-chip status-chip is-warn"><span class="chip-dot" aria-hidden="true"></span><span class="chip-label">Ready</span></span>
                </div>
                @if (!Model.IsSpectator)
                {
                    <div id="touch-gamepad" class="touch-gamepad is-visible @(isGameGear ? "layout-game-gear" : isGenesis ? "layout-genesis" : isArcade ? "layout-arcade" : "layout-generic")" aria-label="On-screen @touchLayoutName gamepad">
                        <div class="pad-cluster" data-control-group="dpad" aria-label="Directional pad">
                            <button class="touch-btn dpad" type="button" data-button="up" aria-label="Up">▲</button>
                            <button class="touch-btn dpad" type="button" data-button="left" aria-label="Left">◀</button>
                            <button class="touch-btn dpad" type="button" data-button="right" aria-label="Right">▶</button>
                            <button class="touch-btn dpad" type="button" data-button="down" aria-label="Down">▼</button>
                        </div>
                        <div class="face-cluster" @(isGenesis ? "" : "data-control-group=\"face\"") aria-label="Action buttons">
                            @if (isGameGear)
                            {
                                <button class="touch-btn face" type="button" data-button="b" aria-label="Button 1">1</button>
                                <button class="touch-btn face" type="button" data-button="a" aria-label="Button 2">2</button>
                            }
                            else if (isGenesis)
                            {
                                <button class="touch-btn face" type="button" data-button="y" data-control-group="genesis-a" aria-label="Genesis A">A</button>
                                <button class="touch-btn face" type="button" data-button="b" data-control-group="genesis-b" aria-label="Genesis B">B</button>
                                <button class="touch-btn face" type="button" data-button="a" data-control-group="genesis-c" aria-label="Genesis C">C</button>
                            }
                            else if (isArcade)
                            {
                                <button class="touch-btn face" type="button" data-button="b" aria-label="Arcade button 1">1</button>
                                <button class="touch-btn face" type="button" data-button="a" aria-label="Arcade button 2">2</button>
                                <button class="touch-btn face" type="button" data-button="y" aria-label="Arcade button 3">3</button>
                                <button class="touch-btn face" type="button" data-button="x" aria-label="Arcade button 4">4</button>
                            }
                            else
                            {
                                <button class="touch-btn face" type="button" data-button="y" aria-label="Y">Y</button>
                                <button class="touch-btn face" type="button" data-button="x" aria-label="X">X</button>
                                <button class="touch-btn face" type="button" data-button="b" aria-label="B">B</button>
                                <button class="touch-btn face" type="button" data-button="a" aria-label="A">A</button>
                            }
                        </div>
                        <div class="menu-cluster" data-control-group="menu" aria-label="Menu buttons">
                            @if (isArcade)
                            {
                                <button class="touch-btn menu" type="button" data-command="insert_coin" aria-label="Insert coin">Coin</button>
                                <button class="touch-btn menu" type="button" data-button="start" aria-label="Start">Start</button>
                                <button class="touch-btn menu" type="button" data-command="reset" aria-label="Reset machine">Reset</button>
                            }
                            else if (!isGameGear && !isGenesis)
                            {
                                <button class="touch-btn menu" type="button" data-button="select" aria-label="Select">Select</button>
                                <button class="touch-btn menu" type="button" data-button="start" aria-label="Start">Start</button>
                            }
                            else
                            {
                                <button class="touch-btn menu" type="button" data-button="start" aria-label="Start">Start</button>
                            }
                        </div>
                    </div>
                }
                <button id="nosebleed-layout-lock" class="player-overlay-action layout-lock-action" type="button" aria-label="Unlock control layout">Unlock layout</button>
                <button id="nosebleed-layout-reset" class="player-overlay-action layout-reset-action" type="button" aria-label="Reset control layout">Reset</button>
                <button id="nosebleed-audio-overlay" class="player-overlay-action" type="button" data-control-group="sound" aria-label="Enable sound">Sound</button>
            </div>
            <div class="playserver-seat-panel border rounded-4 p-3 mt-3 bg-body-tertiary" id="room-presence-panel">
                <div class="d-flex flex-wrap justify-content-between gap-2 align-items-center mb-2">
                    <div class="fw-semibold">Seats</div>
                    <div class="small text-muted" id="room-presence-summary">Loading presence…</div>
                </div>
                <div class="playserver-seat-strip" id="room-seat-strip">
                    <div class="border rounded px-3 py-2 small text-muted bg-body" data-seat-placeholder="true">Loading seats…</div>
                </div>
            </div>

            <div class="playserver-utility-strip mt-3">
                <div class="playserver-utility-actions">
                    <button id="nosebleed-audio" class="btn btn-outline-secondary" type="button">Enable audio</button>
                    <button id="nosebleed-fullscreen" class="btn btn-outline-secondary" type="button">Fullscreen</button>
                    @if (!Model.IsSpectator && !string.IsNullOrWhiteSpace(Model.SessionId))
                    {
                        <form asp-controller="Games" asp-action="LeaveServerSession" method="post" class="d-inline-flex">
                            <input type="hidden" name="sessionId" value="@Model.SessionId" />
                            @if (!string.IsNullOrWhiteSpace(Model.LeaveSessionReturnUrl))
                            {
                                <input type="hidden" name="returnUrl" value="@Model.LeaveSessionReturnUrl" />
                            }
                            <button type="submit" class="btn btn-outline-warning">Leave seat</button>
                        </form>
                    }
                </div>
                <div id="nosebleed-status" class="small text-muted">Ready.</div>
            </div>

            <details class="playserver-advanced-controls mt-3">
                <summary>Player controls</summary>
                <div class="playserver-advanced-controls-body mt-3">
                    <button id="nosebleed-connect" class="btn btn-primary" type="button">Reconnect stream</button>
                    <button id="nosebleed-overlay-toggle" class="btn btn-outline-secondary" type="button" aria-pressed="false">Hide overlay</button>
                    @if (!Model.IsSpectator)
                    {
                        <button id="nosebleed-touch-toggle" class="btn btn-outline-secondary" type="button">Toggle @touchLayoutName controls</button>
                        <label class="visually-hidden" for="nosebleed-gamepad-select">Hardware gamepad</label>
                        <select id="nosebleed-gamepad-select" class="form-select form-select-sm" aria-label="Hardware gamepad">
                            <option value="">Auto / keyboard</option>
                        </select>
                        <button id="nosebleed-pad-test-toggle" class="btn btn-outline-secondary" type="button" aria-expanded="false" aria-controls="nosebleed-pad-test-panel">Pad test</button>
                    }
                    <label class="visually-hidden" for="nosebleed-video-transport">Video transport</label>
                    <select id="nosebleed-video-transport" class="form-select form-select-sm" aria-label="Video transport">
                        <option value="webrtc-track">WebRTC track</option>
                        <option value="webrtc">WebRTC data channel</option>
                        <option value="websocket">WebSocket</option>
                    </select>
                    <label class="visually-hidden" for="nosebleed-video-compression">Video compression</label>
                    <select id="nosebleed-video-compression" class="form-select form-select-sm" aria-label="Video compression">
                        <option value="raw">Raw frames</option>
                        <option value="crisp">JPEG crisp</option>
                        <option value="balanced">JPEG balanced</option>
                        <option value="compact">JPEG compact</option>
                    </select>
                </div>
            </details>
            @if (!Model.IsSpectator)
            {
                <div id="nosebleed-pad-test-panel" class="border rounded bg-body-tertiary p-2 mt-2 small d-none">
                    <div class="fw-semibold mb-1">Hardware gamepad tester</div>
                    <div id="nosebleed-pad-test-summary" class="text-muted">No hardware gamepad detected yet.</div>
                    <div id="nosebleed-pad-test-buttons" class="mt-1 text-break"></div>
                    <div id="nosebleed-pad-test-axes" class="mt-1 font-monospace text-muted"></div>
                </div>
            }
                </div>
                <aside class="playserver-sidebar-column">
                    <div class="border rounded-4 p-3 bg-body-tertiary mb-3" id="playserver-roster-card">
                        <ul class="list-unstyled mb-0 small" id="room-presence-players">
                            <li class="text-muted">Loading players…</li>
                        </ul>
                        <ul class="list-unstyled mb-0 mt-2 small" id="room-presence-watchers"></ul>
                    </div>
                    <div class="border rounded-4 p-3 bg-body-tertiary mb-3" id="room-chat-panel">
                        <div class="d-flex flex-wrap justify-content-end gap-2 align-items-start mb-2">
                            <div class="small text-muted" id="room-chat-status">Loading chat…</div>
                        </div>
                        <div class="border rounded bg-body p-2 mb-2 playserver-chat-log" id="room-chat-log">
                            <ul class="list-unstyled mb-0 small" id="room-chat-messages">
                                <li class="text-muted">Loading messages…</li>
                            </ul>
                        </div>
                        @if (Model.CanChat)
                        {
                            <form asp-action="RoomChat" asp-route-roomId="@Model.CurrentRoomId" method="post" asp-antiforgery="true" id="room-chat-form" class="d-flex gap-2 align-items-start flex-column flex-sm-row">
                                @if (!string.IsNullOrWhiteSpace(Model.ChatIdentityLabel))
                                {
                                    <div class="small text-muted w-100">@Model.ChatIdentityLabel</div>
                                }
                                <input class="form-control" type="text" name="message" maxlength="280" autocomplete="off" placeholder="Say something to the room…" required />
                                <button type="submit" class="btn btn-primary text-nowrap">Send</button>
                            </form>
                        }
                    </div>
                    @if (Model.CurrentRoomId is not null && Model.CanCreateShareLinks)
                    {
                        <details class="border rounded-4 p-3 bg-body-tertiary" id="playserver-share-card">
                            <summary>Share</summary>
                            <div class="d-grid gap-2 mt-3 mb-2">
                                <form asp-action="CreateRoomShareLink" method="post" asp-antiforgery="true">
                                    <input type="hidden" name="roomId" value="@Model.CurrentRoomId" />
                                    <input type="hidden" name="grantMode" value="Spectator" />
                                    <button type="submit" class="btn btn-outline-secondary w-100">Spectator link</button>
                                </form>
                                <form asp-action="CreateRoomShareLink" method="post" asp-antiforgery="true">
                                    <input type="hidden" name="roomId" value="@Model.CurrentRoomId" />
                                    <input type="hidden" name="grantMode" value="Player" />
                                    <button type="submit" class="btn btn-outline-primary w-100">Player link</button>
                                </form>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.GeneratedShareLink))
                            {
                                <div class="small mt-2">
                                    <code class="user-select-all">@Model.GeneratedShareLink</code>
                                </div>
                            }
                        </details>
                    }
                </aside>

            </div>
        }
        else
        {
            <div class="text-muted">Once configured, the server-side player will appear here.</div>
        }
    </div>
</div>

@section Scripts {
@if (string.IsNullOrWhiteSpace(Model.Error) && !string.IsNullOrWhiteSpace(Model.BaseUrl))
{
<script type="application/json" id="nosebleed-player-config">
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
{
    baseUrl = (string?)null,
    token = (string?)null,
    websocketUrls = new
    {
        video = Url.Action("NosebleedProxy", "Games", new { sessionId = Model.SessionId, channel = "video" }),
        audio = Url.Action("NosebleedProxy", "Games", new { sessionId = Model.SessionId, channel = "audio" }),
        input = Url.Action("NosebleedProxy", "Games", new { sessionId = Model.SessionId, channel = "input" })
    },
    webrtcSessionUrl = Url.Action("NosebleedWebRtcSession", "Games", new { sessionId = Model.SessionId }),
    assignedPort = Model.AssignedPort,
    isSpectator = Model.IsSpectator,
    sessionId = Model.SessionId,
    touchLayoutName,
    keepAliveUrl = Url.Action("KeepAliveServerSession", "Games"),
    roomPresenceUrl = Model.CurrentRoomId is null ? null : Url.Action("RoomPresence", "Games", new { roomId = Model.CurrentRoomId }),
    roomChatUrl = Model.CurrentRoomId is null ? null : Url.Action("RoomChat", "Games", new { roomId = Model.CurrentRoomId })
}))
</script>
<script src="~/js/nosebleed-player/input-helpers.js" asp-append-version="true"></script>
<script src="~/js/nosebleed-player/server-player-helpers.js" asp-append-version="true"></script>
<script src="~/js/nosebleed-player/server-player.js" asp-append-version="true"></script>
<script>
(() => {
    const configEl = document.getElementById('nosebleed-player-config');
    if (!configEl) {
        return;
    }

    let config;
    try {
        config = JSON.parse(configEl.textContent || '{}');
    } catch {
        return;
    }

    const presenceSummaryEl = document.getElementById('room-presence-summary');
    const presencePlayersEl = document.getElementById('room-presence-players');
    const presenceWatchersEl = document.getElementById('room-presence-watchers');
    const seatStripEl = document.getElementById('room-seat-strip');
    const chatStatusEl = document.getElementById('room-chat-status');
    const chatMessagesEl = document.getElementById('room-chat-messages');
    const chatLogEl = document.getElementById('room-chat-log');
    const chatFormEl = document.getElementById('room-chat-form');

    const clearChildren = (el) => {
        while (el && el.firstChild) {
            el.removeChild(el.firstChild);
        }
    };

    const appendMutedListItem = (el, text) => {
        if (!el) {
            return;
        }

        const item = document.createElement('li');
        item.className = 'text-muted';
        item.textContent = text;
        el.appendChild(item);
    };

    const buildSeatCard = (playerNumber, occupant, statusText, tone) => {
        const card = document.createElement('div');
        card.className = `border rounded px-3 py-2 small bg-body ${tone}`.trim();
        card.style.minWidth = '9rem';

        const seatLabel = document.createElement('div');
        seatLabel.className = 'text-uppercase text-muted fw-semibold';
        seatLabel.textContent = `Player ${playerNumber}`;

        const occupantEl = document.createElement('div');
        occupantEl.className = 'fw-semibold';
        occupantEl.textContent = occupant;

        const statusEl = document.createElement('div');
        statusEl.className = 'text-muted';
        statusEl.textContent = statusText;

        card.appendChild(seatLabel);
        card.appendChild(occupantEl);
        card.appendChild(statusEl);
        return card;
    };

    const renderPresence = (payload) => {
        if (!presenceSummaryEl || !presencePlayersEl) {
            return;
        }

        const players = Array.isArray(payload.players) ? payload.players : [];
        const watchers = Array.isArray(payload.watchers) ? payload.watchers : [];
        presenceSummaryEl.textContent = `${payload.totalConnected ?? 0} connected · ${payload.watcherCount ?? 0} watching`;
        clearChildren(presencePlayersEl);
        clearChildren(presenceWatchersEl);
        clearChildren(seatStripEl);

        if (players.length === 0) {
            appendMutedListItem(presencePlayersEl, 'No players connected right now.');
        } else {
            for (const player of players) {
                const item = document.createElement('li');
                const label = document.createElement('span');
                label.className = 'fw-semibold';
                label.textContent = `P${player.playerNumber}`;
                item.appendChild(label);
                item.append(` — ${player.displayName ?? 'Viewer'}${Number.isInteger(player.port) ? ` · Input ${player.port + 1}` : ''}`);
                presencePlayersEl.appendChild(item);
            }
        }

        if (watchers.length === 0) {
            if (presenceWatchersEl) {
                presenceWatchersEl.classList.add('d-none');
            }
        } else {
            presenceWatchersEl?.classList.remove('d-none');
            for (const watcher of watchers) {
                const item = document.createElement('li');
                item.className = 'text-muted';
                item.textContent = watcher.displayName ?? 'Viewer';
                presenceWatchersEl.appendChild(item);
            }
        }

        if (seatStripEl) {
            const playersByNumber = new Map(players
                .filter((player) => Number.isInteger(player.playerNumber))
                .map((player) => [player.playerNumber, player]));
            for (let playerNumber = 1; playerNumber <= 4; playerNumber += 1) {
                const player = playersByNumber.get(playerNumber);
                if (player) {
                    seatStripEl.appendChild(buildSeatCard(playerNumber, player.displayName ?? 'Viewer', `Input ${Number.isInteger(player.port) ? player.port + 1 : playerNumber}`, 'border-success-subtle'));
                } else {
                    seatStripEl.appendChild(buildSeatCard(playerNumber, 'Open seat', 'Waiting for a player', ''));
                }
            }
        }
    };

    const renderChat = (payload) => {
        if (!chatStatusEl || !chatMessagesEl) {
            return;
        }

        const messages = Array.isArray(payload.messages) ? payload.messages : [];
        chatStatusEl.textContent = messages.length === 0 ? 'No messages yet.' : `${messages.length} recent message${messages.length === 1 ? '' : 's'}`;
        clearChildren(chatMessagesEl);
        if (messages.length === 0) {
            appendMutedListItem(chatMessagesEl, 'No one has chatted yet.');
            return;
        }

        for (const entry of messages) {
            const item = document.createElement('li');
            item.className = 'mb-2';

            const meta = document.createElement('div');
            meta.className = 'text-muted';
            const timestamp = entry.createdUtc ? new Date(entry.createdUtc) : null;
            const timeLabel = timestamp && !Number.isNaN(timestamp.valueOf())
                ? timestamp.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })
                : '';
            meta.textContent = `${entry.displayName ?? 'Viewer'}${timeLabel ? ` · ${timeLabel}` : ''}`;

            const body = document.createElement('div');
            body.className = 'text-break';
            body.textContent = entry.message ?? '';

            item.appendChild(meta);
            item.appendChild(body);
            chatMessagesEl.appendChild(item);
        }

        if (chatLogEl) {
            chatLogEl.scrollTop = chatLogEl.scrollHeight;
        }
    };

    const loadPresence = async () => {
        if (!config.roomPresenceUrl) {
            return;
        }

        try {
            const response = await fetch(config.roomPresenceUrl, { credentials: 'same-origin', cache: 'no-store' });
            if (!response.ok) {
                throw new Error(`presence ${response.status}`);
            }

            renderPresence(await response.json());
        } catch {
            if (presenceSummaryEl && presencePlayersEl) {
                presenceSummaryEl.textContent = 'Presence unavailable right now.';
                clearChildren(presencePlayersEl);
                clearChildren(presenceWatchersEl);
                clearChildren(seatStripEl);
                appendMutedListItem(presencePlayersEl, 'Could not load presence.');
                if (seatStripEl) {
                    const placeholder = document.createElement('div');
                    placeholder.className = 'border rounded px-3 py-2 small text-muted bg-body';
                    placeholder.textContent = 'Seat map unavailable.';
                    seatStripEl.appendChild(placeholder);
                }
            }
        }
    };

    const loadChat = async () => {
        if (!config.roomChatUrl) {
            return;
        }

        try {
            const response = await fetch(config.roomChatUrl, { credentials: 'same-origin', cache: 'no-store' });
            if (!response.ok) {
                throw new Error(`chat ${response.status}`);
            }

            renderChat(await response.json());
        } catch {
            if (chatStatusEl && chatMessagesEl) {
                chatStatusEl.textContent = 'Chat unavailable right now.';
                clearChildren(chatMessagesEl);
                appendMutedListItem(chatMessagesEl, 'Could not load chat.');
            }
        }
    };

    if (chatFormEl && config.roomChatUrl) {
        chatFormEl.addEventListener('submit', async (event) => {
            event.preventDefault();
            const submitButton = chatFormEl.querySelector('button[type="submit"]');
            const input = chatFormEl.querySelector('input[name="message"]');
            if (!(input instanceof HTMLInputElement)) {
                return;
            }

            submitButton?.setAttribute('disabled', 'disabled');
            if (chatStatusEl) {
                chatStatusEl.textContent = 'Sending…';
            }

            try {
                const response = await fetch(chatFormEl.action, {
                    method: 'POST',
                    body: new FormData(chatFormEl),
                    credentials: 'same-origin'
                });

                const payload = await response.json().catch(() => ({}));
                if (!response.ok) {
                    throw new Error(payload.error || `chat ${response.status}`);
                }

                input.value = '';
                await loadChat();
            } catch (error) {
                if (chatStatusEl) {
                    chatStatusEl.textContent = error instanceof Error ? error.message : 'Could not send chat message.';
                }
            } finally {
                submitButton?.removeAttribute('disabled');
            }
        });
    }

    loadPresence();
    loadChat();
    window.setInterval(loadPresence, 3000);
    window.setInterval(loadChat, 3000);
})();
</script>
}
}
