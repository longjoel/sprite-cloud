@model games_vault.Models.ViewModels.ServerGamePlayViewModel
@inject games_vault.Nosebleed.NosebleedStreamSettingsStore StreamSettingsStore

@{
    var game = Model.Game;
    var systemName = game.SystemName ?? string.Empty;
    var isGameGear = systemName.Equals("Sega - Game Gear", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("Game Gear", StringComparison.OrdinalIgnoreCase);
    var isGenesis = systemName.Equals("Sega - Mega Drive - Genesis", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("Mega Drive", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("Genesis", StringComparison.OrdinalIgnoreCase);
    var isArcadeSystem = systemName.Contains("Arcade", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("MAME", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("FinalBurn", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("FBNeo", StringComparison.OrdinalIgnoreCase)
        || systemName.Contains("Neo Geo", StringComparison.OrdinalIgnoreCase);
    var isArcadeRoom = Model.IsArcadeRoom;
    var hideSaveStateUi = isArcadeRoom;
    var streamSettings = StreamSettingsStore.Get();
    var touchLayoutName = isGameGear
        ? "Sega Game Gear"
        : isGenesis
            ? "Sega Genesis"
            : isArcadeSystem
                ? "Arcade 4-Button"
                : "Generic Retropad";
    var hasLiveSession = string.IsNullOrWhiteSpace(Model.Error) && !string.IsNullOrWhiteSpace(Model.BaseUrl);
    var sessionTitle = game.Name;
    var canManageBatterySaves = !hideSaveStateUi
        && Model.File is not null
        && !string.IsNullOrWhiteSpace(Model.CurrentProfileDisplayName)
        && !Model.CurrentProfileIsEphemeralGuest;
    ViewData["Title"] = sessionTitle;
}

<div class="playserver-hero mb-4">
    <div class="d-flex flex-wrap justify-content-between gap-3 align-items-start">
        <div>
            <h1 class="h2 mb-1">@sessionTitle</h1>
        </div>
        @if (Model.CurrentRoomId is int shareRoomId && Model.CanCreateShareLinks)
        {
            <div class="playserver-invite-links border rounded-4 p-3 bg-body-tertiary" id="playserver-invite-links">
                <div class="fw-semibold small mb-2">Invite links</div>
                <div class="d-flex flex-wrap gap-2">
                    <form asp-action="CreateRoomShareLink" method="post" asp-antiforgery="true" data-share-link-form>
                        <input type="hidden" name="roomId" value="@shareRoomId" />
                        <input type="hidden" name="grantMode" value="Spectator" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Spectator link</button>
                    </form>
                    <form asp-action="CreateRoomShareLink" method="post" asp-antiforgery="true" data-share-link-form>
                        <input type="hidden" name="roomId" value="@shareRoomId" />
                        <input type="hidden" name="grantMode" value="Player" />
                        <button type="submit" class="btn btn-sm btn-outline-primary">Player link</button>
                    </form>
                </div>
                <div class="input-group input-group-sm mt-2@(string.IsNullOrWhiteSpace(Model.GeneratedShareLink) ? " d-none" : string.Empty)" data-share-link-copy-row>
                    <input class="form-control font-monospace" type="text" value="@Model.GeneratedShareLink" readonly aria-label="Generated @Model.GeneratedShareGrantMode invite link" data-share-link-copy-value />
                    <button type="button" class="btn btn-outline-success" data-share-link-copy-button>Copy</button>
                </div>
                <div class="small text-muted mt-1" data-share-link-status></div>
            </div>
        }
    </div>
</div>

@if (TempData["Message"] is string message && !string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @message
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (canManageBatterySaves)
{
    <div class="modal fade" id="playServerSaveHistoryModal" tabindex="-1" aria-labelledby="playServerSaveHistoryModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title" id="playServerSaveHistoryModalLabel">Battery save management</h5>
                        <div class="text-muted small">Open the full save manager without leaving the game page.</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <iframe
                        id="playServerSaveHistoryFrame"
                        title="Battery save management"
                        class="border-0 w-100"
                        style="height: 78vh;"
                        loading="lazy"
                        referrerpolicy="same-origin"
                        data-src="@Url.Action("History", "ProfileBatterySaves", new { gameId = game.Id, gameFileId = Model.File!.Id })">
                    </iframe>
                </div>
                <div class="modal-footer">
                    <a class="btn btn-outline-secondary" asp-controller="ProfileBatterySaves" asp-action="History" asp-route-gameId="@game.Id" asp-route-gameFileId="@Model.File!.Id">Open full page</a>
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Done</button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-warning">
        <div class="fw-semibold mb-1">Player is not ready</div>
        <div>@Model.Error</div>
        <div class="mt-2 text-muted small">
            Expected setup: Nosebleed binary installed, native libretro core mapped for this system, and ROM readable from local storage.
        </div>
    </div>
}

<div class="card playserver-session-surface">
    <div class="card-body p-lg-4">
        @if (hasLiveSession)
        {
            <div id="playserver-session-grid" class="playserver-live-grid">
                <div class="playserver-main-column">
            <style>
                .server-player-shell {
                    position: relative;
                    overflow: hidden;
                    touch-action: none;
                    user-select: none;
                }

                #nosebleed-screen {
                    display: block;
                    image-rendering: pixelated;
                    background: #000;
                    max-width: 100%;
                    max-height: 70vh;
                    width: auto;
                    height: auto;
                    margin-inline: auto;
                    touch-action: none;
                    object-fit: contain;
                }

                .server-player-shell:fullscreen,
                .server-player-shell.is-ios-fullscreen {
                    width: 100vw;
                    height: 100vh;
                    height: 100dvh;
                    border-radius: 0 !important;
                    padding: 0 !important;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: #000 !important;
                }

                .server-player-shell.is-ios-fullscreen {
                    position: fixed;
                    inset: 0;
                    z-index: 2147483000;
                }

                html.games-vault-player-fullscreen,
                body.games-vault-player-fullscreen {
                    overflow: hidden !important;
                    overscroll-behavior: none;
                }

                .server-player-shell:fullscreen #nosebleed-screen,
                .server-player-shell.is-ios-fullscreen #nosebleed-screen {
                    width: 100vw !important;
                    height: 100vh !important;
                    height: 100dvh !important;
                    max-height: none !important;
                    object-fit: contain;
                    border: 0 !important;
                    border-radius: 0 !important;
                }

                .touch-gamepad {
                    position: absolute;
                    inset: 0;
                    display: none;
                    pointer-events: none;
                    z-index: 5;
                }

                .touch-gamepad.is-visible {
                    display: block;
                }

                .touch-gamepad .pad-cluster,
                .touch-gamepad .face-cluster,
                .touch-gamepad .menu-cluster {
                    position: absolute;
                    pointer-events: auto;
                }

                .touch-gamepad .pad-cluster {
                    left: max(1rem, env(safe-area-inset-left));
                    bottom: max(1rem, env(safe-area-inset-bottom));
                    width: 9.5rem;
                    height: 9.5rem;
                }

                .touch-gamepad .face-cluster {
                    right: max(1rem, env(safe-area-inset-right));
                    bottom: max(1.2rem, env(safe-area-inset-bottom));
                    width: 10.5rem;
                    height: 8rem;
                }

                .touch-gamepad .menu-cluster {
                    left: 50%;
                    bottom: max(1rem, env(safe-area-inset-bottom));
                    transform: translateX(-50%);
                    display: flex;
                    gap: .75rem;
                }

                .touch-btn {
                    position: absolute;
                    border: 1px solid rgba(255,255,255,.55);
                    background: rgba(15, 23, 42, .58);
                    color: rgba(255,255,255,.9);
                    backdrop-filter: blur(4px);
                    box-shadow: 0 .25rem 1rem rgba(0,0,0,.35);
                    touch-action: none;
                    -webkit-user-select: none;
                    user-select: none;
                }

                .touch-btn.is-pressed {
                    background: rgba(13, 110, 253, .76);
                    transform: scale(.96);
                }

                .touch-btn.dpad {
                    width: 3.1rem;
                    height: 3.1rem;
                    border-radius: .85rem;
                    font-weight: 700;
                }

                .touch-btn.face {
                    width: 4rem;
                    height: 4rem;
                    border-radius: 999px;
                    font-weight: 800;
                    font-size: 1.2rem;
                }

                .touch-btn.menu {
                    position: static;
                    min-width: 4.5rem;
                    border-radius: 999px;
                    padding: .55rem .85rem;
                    font-weight: 700;
                }

                .touch-btn[data-button="up"] { left: 3.2rem; top: 0; }
                .touch-btn[data-button="left"] { left: 0; top: 3.2rem; }
                .touch-btn[data-button="right"] { right: 0; top: 3.2rem; }
                .touch-btn[data-button="down"] { left: 3.2rem; bottom: 0; }
                .touch-btn[data-button="b"] { left: 0; bottom: 0; }
                .touch-btn[data-button="a"] { right: 0; bottom: 1.4rem; }
                .touch-btn[data-button="y"] { left: 1.4rem; top: 0; }
                .touch-btn[data-button="x"] { right: 1.4rem; top: 0; }

                .touch-gamepad.layout-game-gear .face-cluster {
                    width: 9rem;
                    height: 5rem;
                    bottom: max(1.65rem, env(safe-area-inset-bottom));
                }

                .touch-gamepad.layout-game-gear .touch-btn.face {
                    width: 4.35rem;
                    height: 4.35rem;
                    font-size: 1.35rem;
                }

                .touch-gamepad.layout-game-gear .touch-btn[data-button="b"] { left: 0; bottom: 0; }
                .touch-gamepad.layout-game-gear .touch-btn[data-button="a"] { right: 0; bottom: 0; }

                .touch-gamepad.layout-game-gear .menu-cluster {
                    left: auto;
                    right: max(1.25rem, env(safe-area-inset-right));
                    bottom: max(6.55rem, calc(env(safe-area-inset-bottom) + 6.55rem));
                    transform: none;
                }

                .touch-gamepad.layout-game-gear .touch-btn.menu {
                    min-width: 4rem;
                    padding: .4rem .75rem;
                    font-size: .9rem;
                    opacity: .82;
                }

                .touch-gamepad.layout-genesis .face-cluster {
                    position: static;
                    pointer-events: none;
                }

                .touch-gamepad.layout-genesis .touch-btn.face {
                    width: 4.25rem;
                    height: 4.25rem;
                    font-size: 1.32rem;
                    pointer-events: auto;
                }

                .touch-gamepad.layout-genesis .touch-btn.face[data-button="y"] { left: auto; right: 9.9rem; bottom: max(1.35rem, env(safe-area-inset-bottom)); }
                .touch-gamepad.layout-genesis .touch-btn.face[data-button="b"] { left: auto; right: 5.45rem; bottom: max(2.75rem, calc(env(safe-area-inset-bottom) + 1.4rem)); }
                .touch-gamepad.layout-genesis .touch-btn.face[data-button="a"] { left: auto; right: max(1rem, env(safe-area-inset-right)); bottom: max(4.15rem, calc(env(safe-area-inset-bottom) + 2.8rem)); }

                .touch-gamepad.layout-genesis .menu-cluster {
                    left: 50%;
                    bottom: max(1rem, env(safe-area-inset-bottom));
                    transform: translateX(-50%);
                }

                .touch-gamepad.layout-genesis .touch-btn.menu[data-button="start"] {
                    min-width: 5rem;
                }

                .touch-gamepad.layout-arcade .face-cluster {
                    width: 16rem;
                    height: 6.8rem;
                    right: max(.75rem, env(safe-area-inset-right));
                    bottom: max(1.1rem, env(safe-area-inset-bottom));
                }

                .touch-gamepad.layout-arcade .touch-btn.face {
                    width: 3.8rem;
                    height: 3.8rem;
                    font-size: 1.15rem;
                }

                .touch-gamepad.layout-arcade .touch-btn.face[data-button="b"] { left: 0; bottom: 0; }
                .touch-gamepad.layout-arcade .touch-btn.face[data-button="a"] { left: 3.9rem; bottom: .65rem; }
                .touch-gamepad.layout-arcade .touch-btn.face[data-button="y"] { left: 7.8rem; bottom: 1.3rem; }
                .touch-gamepad.layout-arcade .touch-btn.face[data-button="x"] { left: 11.7rem; bottom: 1.95rem; }

                .touch-gamepad.layout-arcade .menu-cluster {
                    gap: .55rem;
                }

                .touch-gamepad.layout-arcade .touch-btn.menu {
                    min-width: 4rem;
                    padding: .45rem .72rem;
                    font-size: .9rem;
                }

                .player-overlay-action {
                    position: absolute;
                    top: max(.75rem, env(safe-area-inset-top));
                    right: max(1rem, env(safe-area-inset-right));
                    z-index: 7;
                    border: 1px solid rgba(255,255,255,.45);
                    background: rgba(15, 23, 42, .58);
                    color: rgba(255,255,255,.92);
                    border-radius: 999px;
                    padding: .38rem .72rem;
                    font-size: .84rem;
                    font-weight: 700;
                    backdrop-filter: blur(4px);
                    box-shadow: 0 .25rem 1rem rgba(0,0,0,.35);
                    touch-action: none;
                }

                .player-overlay-action.is-on {
                    background: rgba(25, 135, 84, .7);
                }

                .layout-lock-action {
                    left: max(1rem, env(safe-area-inset-left));
                    right: auto;
                }

                .layout-reset-action {
                    top: max(3.35rem, calc(env(safe-area-inset-top) + 3.35rem));
                    left: max(1rem, env(safe-area-inset-left));
                    right: auto;
                    padding-inline: .62rem;
                }

                .player-state-pill {
                    position: absolute;
                    left: max(1rem, env(safe-area-inset-left));
                    bottom: max(1rem, env(safe-area-inset-bottom));
                    z-index: 7;
                    display: inline-flex;
                    align-items: center;
                    gap: .45rem;
                    padding: .42rem .5rem;
                    border: 1px solid rgba(255,255,255,.16);
                    border-radius: 999px;
                    background: rgba(15, 23, 42, .62);
                    color: rgba(255,255,255,.95);
                    backdrop-filter: blur(8px);
                    box-shadow: 0 .25rem 1rem rgba(0,0,0,.35);
                    pointer-events: auto;
                }

                .player-state-slot,
                .player-state-action {
                    border: 1px solid rgba(255,255,255,.18);
                    background: rgba(15, 23, 42, .72);
                    color: rgba(255,255,255,.95);
                    border-radius: 999px;
                    font-weight: 700;
                    height: 2.2rem;
                }

                .player-state-slot {
                    min-width: 6.5rem;
                    padding-inline: .75rem 1.85rem .75rem .8rem;
                }

                .player-state-action {
                    padding: 0 .85rem;
                    min-width: 4.25rem;
                }

                .player-state-action.is-primary {
                    background: rgba(13, 110, 253, .35);
                }

                .player-state-action.is-success {
                    background: rgba(25, 135, 84, .35);
                }

                .player-state-action:hover,
                .player-state-action:focus-visible,
                .player-state-slot:hover,
                .player-state-slot:focus-visible {
                    border-color: rgba(255,255,255,.4);
                    outline: none;
                }

                .player-chrome-hidden .player-state-pill {
                    opacity: 0;
                    pointer-events: none;
                }

                .player-chrome-hidden .player-state-pill,
                .player-chrome-hidden .player-log-panel {
                    transition: opacity .18s ease;
                }

                .player-chrome {
                    position: absolute;
                    inset: 0;
                    z-index: 8;
                    pointer-events: none;
                }

                .player-chrome-gradient-top,
                .player-chrome-gradient-bottom {
                    position: absolute;
                    left: 0;
                    right: 0;
                    pointer-events: none;
                    opacity: 1;
                    transition: opacity .18s ease;
                }

                .player-chrome-gradient-top {
                    top: 0;
                    height: 18%;
                    background: linear-gradient(180deg, rgba(0,0,0,.45), transparent);
                }

                .player-chrome-gradient-bottom {
                    bottom: 0;
                    height: 36%;
                    background: linear-gradient(0deg, rgba(0,0,0,.88), transparent);
                }

                .player-bottom-bar {
                    position: absolute;
                    left: 1rem;
                    right: 1rem;
                    bottom: max(.85rem, env(safe-area-inset-bottom));
                    display: flex;
                    justify-content: center;
                    pointer-events: auto;
                    transition: opacity .18s ease, transform .18s ease;
                }

                .player-prompt,
                .player-control-cluster,
                .player-control-button {
                    backdrop-filter: blur(10px);
                    box-shadow: 0 .55rem 1.4rem rgba(0,0,0,.34);
                }

                .player-control-cluster,
                .player-view-mode-buttons {
                    display: flex;
                    align-items: center;
                    gap: .55rem;
                    flex-wrap: wrap;
                }

                .player-control-cluster {
                    justify-content: center;
                    border-radius: 999px;
                    border: 1px solid rgba(255,255,255,.14);
                    background: rgba(15, 23, 42, .52);
                    padding: .55rem;
                    max-width: min(100%, 64rem);
                }

                .player-control-button {
                    border: 1px solid rgba(255,255,255,.18);
                    border-radius: 999px;
                    background: rgba(15, 23, 42, .72);
                    color: rgba(255,255,255,.96);
                    padding: .62rem .95rem;
                    font-size: .9rem;
                    font-weight: 700;
                }

                .player-control-button.primary {
                    background: rgba(59, 130, 246, .3);
                }

                .player-control-button.is-on {
                    background: rgba(25, 135, 84, .3);
                    border-color: rgba(25, 135, 84, .5);
                }

                .player-control-icon {
                    width: 1.1rem;
                    height: 1.1rem;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                }

                .player-control-icon svg {
                    width: 100%;
                    height: 100%;
                    display: block;
                    stroke: currentColor;
                    fill: none;
                    stroke-width: 1.8;
                    stroke-linecap: round;
                    stroke-linejoin: round;
                    vector-effect: non-scaling-stroke;
                }

                .player-audio-controls {
                    display: inline-flex;
                    align-items: center;
                    gap: .55rem;
                }

                .player-volume-slider {
                    --volume-fill: 100%;
                    position: relative;
                    width: min(7rem, 26vw);
                    height: 1.7rem;
                    cursor: pointer;
                    touch-action: none;
                    user-select: none;
                }

                .player-volume-slider:focus-visible {
                    outline: 2px solid rgba(248, 250, 252, .88);
                    outline-offset: .28rem;
                    border-radius: 999px;
                }

                .player-volume-track {
                    position: absolute;
                    left: 0;
                    right: 0;
                    top: 50%;
                    height: .24rem;
                    border-radius: 999px;
                    transform: translateY(-50%);
                    background: rgba(255, 255, 255, .28);
                    overflow: hidden;
                }

                .player-volume-fill {
                    display: block;
                    width: var(--volume-fill);
                    height: 100%;
                    border-radius: inherit;
                    background: rgba(248, 250, 252, .96);
                }

                .player-volume-thumb {
                    position: absolute;
                    left: var(--volume-fill);
                    top: 50%;
                    width: .82rem;
                    height: .82rem;
                    border-radius: 50%;
                    transform: translate(-50%, -50%);
                    background: #f8fafc;
                    box-shadow: 0 .15rem .55rem rgba(0, 0, 0, .38);
                }

                .player-audio-icon .audio-mute-cross {
                    display: none;
                }

                .player-control-button.is-muted .player-audio-icon .audio-wave {
                    display: none;
                }

                .player-control-button.is-muted .player-audio-icon .audio-mute-cross {
                    display: block;
                }

                .player-prompt-wrap {
                    position: absolute;
                    inset: 0;
                    display: grid;
                    place-items: center;
                    pointer-events: none;
                }

                .player-prompt {
                    border-radius: 999px;
                    border: 1px solid rgba(255,255,255,.14);
                    background: rgba(15, 23, 42, .76);
                    color: rgba(255,255,255,.96);
                    padding: .7rem 1rem;
                    font-size: .9rem;
                    font-weight: 700;
                    opacity: 0;
                    transform: translateY(.4rem) scale(.98);
                    transition: opacity .18s ease, transform .18s ease;
                }

                .player-prompt.show {
                    opacity: 1;
                    transform: translateY(0) scale(1);
                }

                .player-status-corner {
                    position: absolute;
                    top: max(.8rem, env(safe-area-inset-top));
                    right: max(1rem, env(safe-area-inset-right));
                    pointer-events: auto;
                    transition: opacity .18s ease, transform .18s ease;
                }

                .player-health {
                    display: inline-flex;
                    align-items: center;
                    gap: .45rem;
                    border-radius: 999px;
                    border: 1px solid rgba(255,255,255,.18);
                    background: rgba(15, 23, 42, .72);
                    color: rgba(255,255,255,.92);
                    padding: .6rem .9rem;
                    font-size: .84rem;
                    font-weight: 700;
                    backdrop-filter: blur(10px);
                    box-shadow: 0 .55rem 1.4rem rgba(0,0,0,.34);
                }

                .player-health-dot {
                    width: .58rem;
                    height: .58rem;
                    border-radius: 999px;
                    background: #20c997;
                    box-shadow: 0 0 .65rem rgba(32,201,151,.75);
                }

                .player-health.is-warn .player-health-dot { background: #ffc107; box-shadow: 0 0 .65rem rgba(255,193,7,.75); }
                .player-health.is-bad .player-health-dot { background: #dc3545; box-shadow: 0 0 .65rem rgba(220,53,69,.75); }

                .player-events {
                    position: absolute;
                    top: max(4.9rem, calc(env(safe-area-inset-top) + 4.9rem));
                    left: 50%;
                    width: min(38rem, calc(100% - 2rem));
                    transform: translateX(-50%);
                    display: grid;
                    gap: .5rem;
                    pointer-events: none;
                    z-index: 9;
                }

                .player-event {
                    display: grid;
                    gap: .18rem;
                    border-radius: 1rem;
                    border: 1px solid rgba(255,255,255,.15);
                    background: rgba(15, 23, 42, .82);
                    color: rgba(255,255,255,.96);
                    padding: .7rem .9rem;
                    box-shadow: 0 .6rem 1.4rem rgba(0,0,0,.34);
                    backdrop-filter: blur(10px);
                    transform: translateY(-.25rem);
                    opacity: 0;
                    transition: opacity .18s ease, transform .18s ease;
                }

                .player-event.show {
                    opacity: 1;
                    transform: translateY(0);
                }

                .player-event.is-good { border-color: rgba(25, 135, 84, .5); }
                .player-event.is-warn { border-color: rgba(255, 193, 7, .5); }
                .player-event.is-bad { border-color: rgba(220, 53, 69, .55); }

                .player-event-title,
                .player-log-entry-title {
                    font-size: .74rem;
                    font-weight: 800;
                    letter-spacing: .04em;
                    text-transform: uppercase;
                    color: rgba(226, 232, 240, .84);
                }

                .player-event-body,
                .player-log-entry-body {
                    font-size: .9rem;
                    line-height: 1.35;
                    word-break: break-word;
                }

                .player-log-panel {
                    position: absolute;
                    top: max(.9rem, env(safe-area-inset-top));
                    left: max(.9rem, env(safe-area-inset-left));
                    width: min(24rem, calc(100% - 1.8rem));
                    max-height: min(42vh, 24rem);
