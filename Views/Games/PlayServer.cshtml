@model games_vault.Models.ViewModels.ServerGamePlayViewModel
@inject games_vault.Nosebleed.NosebleedStreamSettingsStore StreamSettingsStore

@{
    var game = Model.Game;
    var systemName = game.SystemName ?? string.Empty;
    var isGameGear = systemName.Contains("Game Gear", StringComparison.OrdinalIgnoreCase);
    var isGenesis = systemName.Contains("Mega Drive", StringComparison.OrdinalIgnoreCase) || systemName.Contains("Genesis", StringComparison.OrdinalIgnoreCase);
    var isArcadeSystem = systemName.Contains("Arcade", StringComparison.OrdinalIgnoreCase) || systemName.Contains("MAME", StringComparison.OrdinalIgnoreCase) || systemName.Contains("FinalBurn", StringComparison.OrdinalIgnoreCase) || systemName.Contains("FBNeo", StringComparison.OrdinalIgnoreCase) || systemName.Contains("Neo Geo", StringComparison.OrdinalIgnoreCase);
    var isNes = systemName.Contains("Nintendo Entertainment System", StringComparison.OrdinalIgnoreCase);
    var isSnes = systemName.Contains("Super Nintendo", StringComparison.OrdinalIgnoreCase);
    var streamSettings = StreamSettingsStore.Get();
    var touchLayoutName = isGameGear ? "Sega Game Gear" : isGenesis ? "Sega Genesis" : isArcadeSystem ? "Arcade 4-Button" : isNes ? "Nintendo NES" : isSnes ? "Nintendo SNES" : "Generic Retropad";
    var sessionTitle = game.Name;
    ViewData["Title"] = sessionTitle;
}

<div class="playserver-hero mb-4">
    <meta name="game-system" content="@systemName" />
    @Html.AntiForgeryToken()
    <div class="d-flex flex-wrap justify-content-between gap-3 align-items-start">
        <div><h1 class="h2 mb-1">@sessionTitle</h1></div>
        @await Html.PartialAsync("~/Views/Games/_InviteLinks.cshtml", Model)
    </div>
</div>

@if (TempData["Message"] is string msg && !string.IsNullOrWhiteSpace(msg))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">@msg<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
}

@await Html.PartialAsync("~/Views/Games/_BatterySaveModal.cshtml", Model)

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-warning">
        <div class="fw-semibold mb-1">Player is not ready</div>
        <div>@Model.Error</div>
        <div class="mt-2 text-muted small">Expected setup: Nosebleed binary installed, native libretro core mapped for this system, and ROM readable from local storage.</div>
    </div>
}

<link rel="stylesheet" href="~/css/playserver.css" asp-append-version="true" />

<div class="card playserver-session-surface">
    <div class="card-body p-lg-4">
        @await Html.PartialAsync("~/Views/Games/_SessionGrid.cshtml", Model)
    </div>
</div>

@section Scripts {
@if (string.IsNullOrWhiteSpace(Model.Error) && !string.IsNullOrWhiteSpace(Model.BaseUrl))
{
<script type="application/json" id="nosebleed-player-config">
@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
{
    baseUrl = (string?)null,
    token = (string?)null,
    websocketUrls = new
    {
        video = Url.Action("NosebleedProxy", "Games", new { sessionId = Model.SessionId, channel = "video" }),
        audio = Url.Action("NosebleedProxy", "Games", new { sessionId = Model.SessionId, channel = "audio" }),
        input = Url.Action("NosebleedProxy", "Games", new { sessionId = Model.SessionId, channel = "input" })
    },
    webrtcSessionUrl = Url.Action("NosebleedWebRtcSession", "Games", new { sessionId = Model.SessionId }),
    assignedPort = Model.AssignedPort,
    isSpectator = Model.IsSpectator,
    sessionId = Model.SessionId,
    touchLayoutName,
    streamDefaults = new
    {
        videoTransport = streamSettings.PreferredVideoTransport
    },
    keepAliveUrl = Url.Action("KeepAliveServerSession", "Games"),
    roomPresenceUrl = Model.CurrentRoomId is null ? null : Url.Action("RoomPresence", "Games", new { roomId = Model.CurrentRoomId }),
    roomChatUrl = Model.CurrentRoomId is null ? null : Url.Action("RoomChat", "Games", new { roomId = Model.CurrentRoomId }),
    roomKickUrl = Model.CurrentRoomId is null ? null : Url.Action("KickRoomPlayer", "Games", new { roomId = Model.CurrentRoomId }),
    canKickPlayers = !Model.IsSpectator && Model.PlayerNumber == 1,
    playerNumber = Model.PlayerNumber,
    batterySaveDiagnostics = Model.BatterySaveDiagnostics
}))
</script>
<script src="~/js/nosebleed-player/input-helpers.js" asp-append-version="true"></script>
<script src="~/js/nosebleed-player/server-player-helpers.js" asp-append-version="true"></script>
<script src="~/js/nosebleed-player/server-player.js" asp-append-version="true"></script>
<script src="~/js/nosebleed-player/room-utils.js" asp-append-version="true"></script>
<script src="~/js/nosebleed-player/playserver-extras.js" asp-append-version="true"></script>
}
}
