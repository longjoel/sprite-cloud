@model games_vault.Models.Game

@{
    ViewData["Title"] = "Edit game";
}

<h1 class="h3">Edit game</h1>

<form asp-action="Edit" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="SystemName" class="form-label"></label>
        <input asp-for="SystemName" class="form-control" />
        <span asp-validation-for="SystemName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="ReleaseDate" class="form-label"></label>
            <input asp-for="ReleaseDate" class="form-control" type="date" />
            <span asp-validation-for="ReleaseDate" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="NumberOfPlayers" class="form-label"></label>
            <input asp-for="NumberOfPlayers" class="form-control" type="number" min="1" />
            <span asp-validation-for="NumberOfPlayers" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Genre" class="form-label"></label>
            <input asp-for="Genre" class="form-control" />
            <span asp-validation-for="Genre" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="CriticRating" class="form-label"></label>
            <input asp-for="CriticRating" class="form-control" type="number" min="0" max="100" step="0.01" />
            <span asp-validation-for="CriticRating" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="UserRating" class="form-label"></label>
            <input asp-for="UserRating" class="form-control" type="number" min="0" max="100" step="0.01" />
            <span asp-validation-for="UserRating" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="CriticGenre" class="form-label"></label>
            <input asp-for="CriticGenre" class="form-control" />
            <span asp-validation-for="CriticGenre" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-link" asp-action="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
