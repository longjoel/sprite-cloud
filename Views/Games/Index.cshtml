@model games_vault.Models.ViewModels.GamesIndexViewModel

@{
    ViewData["Title"] = "Games";
    var q = Model.Query;
    var currentPage = Model.Page;
    var pageSize = Model.PageSize;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var addTabActive = Model.OpenAddGameModal;
    var browseTabActive = !addTabActive;

    var bankModel = new games_vault.Models.ViewModels.GamesBankViewModel
    {
        Games = Model.Games,
        Query = q,
        Page = currentPage,
        PageSize = pageSize,
        TotalCount = Model.TotalCount,
        BatchId = Model.BatchId,
        BatchGameIds = Model.BatchGameIds,
        MissingSystemFilesBySystem = Model.MissingSystemFilesBySystem
    };
}

@if (TempData["Message"] is string message && !string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success">@message</div>
}

<div class="mb-4">
    <div class="games-shell-hero rounded-4 p-4 p-lg-5 mb-3 shadow-sm">
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
            <div>
                <div class="games-card-kicker mb-2">Playable library</div>
                <h1 class="h2 mb-2">Games</h1>
                <div class="text-muted">Browse your library, jump straight into a server-side session, or add/import new ROMs without leaving the page.</div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 text-muted small">
            <span class="games-meta-chip">@Model.TotalCount game@(Model.TotalCount == 1 ? "" : "s")</span>
            <span class="games-meta-chip">@pageSize per page</span>
        </div>
    </div>

    <ul class="nav nav-tabs mb-3" id="games-page-tabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(browseTabActive ? "active" : "")" id="games-browse-tab" data-bs-toggle="tab" data-bs-target="#games-browse-pane" type="button" role="tab" aria-controls="games-browse-pane" aria-selected="@(browseTabActive ? "true" : "false")">Browse library</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(addTabActive ? "active" : "")" id="games-add-tab" data-bs-toggle="tab" data-bs-target="#games-add-pane" type="button" role="tab" aria-controls="games-add-pane" aria-selected="@(addTabActive ? "true" : "false")">Add / import games</button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade @(browseTabActive ? "show active" : "")" id="games-browse-pane" role="tabpanel" aria-labelledby="games-browse-tab" tabindex="0">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <form id="games-search-form" asp-action="Index" method="get" class="d-flex flex-wrap gap-2 align-items-center">
                    <input id="games-search" name="q" value="@q" class="form-control" placeholder="Search games, systems, or CRC…" autocomplete="off" />
                    <input type="hidden" name="page" value="@currentPage" />
                    <select id="games-page-size" name="pageSize" class="form-select" style="width: 8rem;">
                        @foreach (var size in new[] { 10, 25, 50, 100 })
                        {
                            <option value="@size" selected="@(size == pageSize)">@size / page</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-outline-secondary">Search</button>
                    @if (!string.IsNullOrWhiteSpace(q))
                    {
                        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-pageSize="@pageSize">Clear</a>
                    }
                </form>

                <div class="text-muted" id="games-total-count">
                    @Model.TotalCount total
                </div>
            </div>

            <div class="row g-3">
    <div class="col-12 games-bank-column">
        <div id="games-bank-container">
            <partial name="_GamesBank" model="bankModel" />
        </div>
    </div>
</div>
        </div>

        <div class="tab-pane fade @(addTabActive ? "show active" : "")" id="games-add-pane" role="tabpanel" aria-labelledby="games-add-tab" tabindex="0">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
                        <div>
                            <h2 class="h5 mb-1">Add or import games</h2>
                            <div class="text-muted">Upload ROMs directly, or pull from the web, a network share, or a local filesystem source using the existing import tools.</div>
                        </div>
                        <a class="btn btn-outline-secondary" asp-action="Index">Back to browse</a>
                    </div>
                    <partial name="_AddGameModalBody" model="Model.AddGame" view-data='new ViewDataDictionary(ViewData) { ["InlineAddGame"] = true }' />
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var form = document.getElementById('games-search-form');
            var input = document.getElementById('games-search');
            var browseTabButton = document.getElementById('games-browse-tab');
            var addTabButton = document.getElementById('games-add-tab');
            var pageInput = form ? form.querySelector('input[name="page"]') : null;
            var pageSize = document.getElementById('games-page-size');
            var bankContainer = document.getElementById('games-bank-container');
            var totalCountEl = document.getElementById('games-total-count');

            function getParams() {
                return {
                    q: input ? input.value : "",
                    page: pageInput ? pageInput.value : "1",
                    pageSize: pageSize ? pageSize.value : "25"
                };
            }

            function setUrl(params) {
                var url = new URL(window.location.href);
                if (params.q) url.searchParams.set('q', params.q); else url.searchParams.delete('q');
                if (params.page) url.searchParams.set('page', params.page); else url.searchParams.delete('page');
                if (params.pageSize) url.searchParams.set('pageSize', params.pageSize); else url.searchParams.delete('pageSize');
                window.history.replaceState({}, "", url.toString());
            }

            function setSurfaceInUrl(surface) {
                var url = new URL(window.location.href);
                if (surface === 'add') url.searchParams.set('openAdd', 'true');
                else url.searchParams.delete('openAdd');
                window.history.replaceState({}, '', url.toString());
            }

            async function loadBank(params) {
                if (!bankContainer) return;
                var qs = new URLSearchParams();
                if (params.q) qs.set('q', params.q);
                if (params.page) qs.set('page', params.page);
                if (params.pageSize) qs.set('pageSize', params.pageSize);

                try {
                    var res = await fetch('/Games/Bank?' + qs.toString(), { cache: 'no-store', credentials: 'same-origin' });
                    if (!res.ok) return;
                    var html = await res.text();
                    bankContainer.innerHTML = html;
                    var total = res.headers.get('X-Games-TotalCount');
                    if (totalCountEl && total) totalCountEl.textContent = total + " total";
                } catch (e) { }
            }

            // Live search: debounce and update the bank only, keeping input focus.
            if (form && input && pageInput) {
                var t = null;
                input.addEventListener('input', function () {
                    if (t) clearTimeout(t);
                    t = setTimeout(function () {
                        pageInput.value = "1";
                        var params = getParams();
                        params.page = "1";
                        setUrl(params);
                        loadBank(params);
                    }, 250);
                });
            }

            if (form) {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    if (pageInput) pageInput.value = "1";
                    var params = getParams();
                    params.page = "1";
                    setUrl(params);
                    loadBank(params);
                });
            }

            if (form && pageSize && pageInput) {
                pageSize.addEventListener('change', function () {
                    pageInput.value = "1";
                    var params = getParams();
                    params.page = "1";
                    setUrl(params);
                    loadBank(params);
                });
            }

            if (browseTabButton) {
                browseTabButton.addEventListener('shown.bs.tab', function () {
                    setSurfaceInUrl('browse');
                });
            }

            if (addTabButton) {
                addTabButton.addEventListener('shown.bs.tab', function () {
                    setSurfaceInUrl('add');
                });
            }

            // Intercept pagination clicks to update bank without losing focus.
            if (bankContainer) {
                bankContainer.addEventListener('click', function (e) {
                    var a = e.target && e.target.closest ? e.target.closest('a.page-link') : null;
                    if (!a || !a.getAttribute) return;
                    var href = a.getAttribute('href');
                    if (!href || href[0] === '#') return;
                    if (href.indexOf('/Games') !== 0) return;
                    if (href.indexOf('page=') < 0) return;
                    e.preventDefault();

                    var url = new URL(href, window.location.origin);
                    var params = {
                        q: url.searchParams.get('q') || "",
                        page: url.searchParams.get('page') || "1",
                        pageSize: url.searchParams.get('pageSize') || (pageSize ? pageSize.value : "25")
                    };
                    if (pageInput) pageInput.value = params.page;
                    setUrl(params);
                    loadBank(params);
                });
            }
        })();
    </script>
}
