@model games_vault.Models.ViewModels.GamesIndexViewModel

@{
    ViewData["Title"] = "Games";
    var browse = Model.Browse;
    var q = browse.Q;
    var currentPage = Model.Page;
    var pageSize = Model.PageSize;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var addTabActive = Model.OpenAddGameModal;
    var browseTabActive = !addTabActive;

    var bankModel = new games_vault.Models.ViewModels.GamesBankViewModel
    {
        Games = Model.Games,
        Browse = browse,
        Query = q,
        Page = currentPage,
        PageSize = pageSize,
        TotalCount = Model.TotalCount,
        SystemOptions = Model.SystemOptions,
        PlayerOptions = Model.PlayerOptions,
        Sections = Model.Sections,
        ActiveGameIds = Model.ActiveGameIds,
        BatchId = Model.BatchId,
        BatchGameIds = Model.BatchGameIds,
        MissingSystemFilesBySystem = Model.MissingSystemFilesBySystem
    };
}

@if (TempData["Message"] is string message && !string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success">@message</div>
}

<div class="mb-4">
    <div class="games-shell-hero rounded-4 p-4 p-lg-5 mb-3 shadow-sm">
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
            <div class="games-library-hero-copy">
                <div class="games-card-kicker mb-2">Playable library</div>
                <h1 class="display-6 mb-2">Browse your library</h1>
                <div class="lead text-muted">Search your collection, jump into recently played favorites, find active rooms, or browse by system like a personal Steam shelf for ROMs.</div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 text-muted small">
            <span class="games-meta-chip">@Model.TotalCount game@(Model.TotalCount == 1 ? "" : "s")</span>
            <span class="games-meta-chip">@Model.SystemCount system@(Model.SystemCount == 1 ? "" : "s")</span>
            <span class="games-meta-chip">@Model.ActiveNowCount playing now</span>
            <span class="games-meta-chip">@Model.PlayedThisWeekCount played this week</span>
            <span class="games-meta-chip">@pageSize per page</span>
        </div>
    </div>

    <ul class="nav nav-tabs mb-3" id="games-page-tabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(browseTabActive ? "active" : "")" id="games-browse-tab" data-bs-toggle="tab" data-bs-target="#games-browse-pane" type="button" role="tab" aria-controls="games-browse-pane" aria-selected="@(browseTabActive ? "true" : "false")">Browse library</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(addTabActive ? "active" : "")" id="games-add-tab" data-bs-toggle="tab" data-bs-target="#games-add-pane" type="button" role="tab" aria-controls="games-add-pane" aria-selected="@(addTabActive ? "true" : "false")">Add / import games</button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade @(browseTabActive ? "show active" : "")" id="games-browse-pane" role="tabpanel" aria-labelledby="games-browse-tab" tabindex="0">
            <div class="card border-0 shadow-sm mb-3 games-library-controls">
                <div class="card-body p-3 p-lg-4">
                    <form id="games-search-form" asp-action="Index" method="get" class="row g-3 align-items-end">
                        <div class="col-12 col-lg-4">
                            <label class="form-label fw-semibold" for="games-search">Search library</label>
                            <input id="games-search" name="q" value="@q" class="form-control form-control-lg" placeholder="Search games, systems, files, CRC…" autocomplete="off" />
                        </div>
                        <input type="hidden" name="page" value="@currentPage" />
                        <div class="col-6 col-md-4 col-lg-2">
                            <label class="form-label" for="games-system-filter">System</label>
                            <select id="games-system-filter" name="system" class="form-select games-browse-control">
                                <option value="">All systems</option>
                                @foreach (var option in Model.SystemOptions)
                                {
                                    <option value="@option.Name" selected="@(string.Equals(option.Name, browse.System, StringComparison.OrdinalIgnoreCase))">@option.Name (@option.Count)</option>
                                }
                            </select>
                        </div>
                        <div class="col-6 col-md-4 col-lg-2">
                            <label class="form-label" for="games-players-filter">Players</label>
                            <select id="games-players-filter" name="players" class="form-select games-browse-control">
                                <option value="">Any players</option>
                                @foreach (var option in Model.PlayerOptions)
                                {
                                    <option value="@option.Players" selected="@(browse.Players == option.Players)">@option.Players player@(option.Players == 1 ? "" : "s") (@option.Count)</option>
                                }
                            </select>
                        </div>
                        <div class="col-6 col-md-4 col-lg-2">
                            <label class="form-label" for="games-sort">Sort</label>
                            <select id="games-sort" name="sort" class="form-select games-browse-control">
                                <option value="RecentlyAdded" selected="@(browse.Sort == games_vault.Models.ViewModels.GamesLibrarySort.RecentlyAdded)">Recently added</option>
                                <option value="AlphabeticalAsc" selected="@(browse.Sort == games_vault.Models.ViewModels.GamesLibrarySort.AlphabeticalAsc)">Alphabetical A-Z</option>
                                <option value="AlphabeticalDesc" selected="@(browse.Sort == games_vault.Models.ViewModels.GamesLibrarySort.AlphabeticalDesc)">Alphabetical Z-A</option>
                                <option value="RecentlyPlayed" selected="@(browse.Sort == games_vault.Models.ViewModels.GamesLibrarySort.RecentlyPlayed)">Recently played</option>
                                <option value="MostPlayedAllTime" selected="@(browse.Sort == games_vault.Models.ViewModels.GamesLibrarySort.MostPlayedAllTime)">Most played all time</option>
                                <option value="MostPlayedThisWeek" selected="@(browse.Sort == games_vault.Models.ViewModels.GamesLibrarySort.MostPlayedThisWeek)">Most played this week</option>
                                <option value="NumberOfPlayers" selected="@(browse.Sort == games_vault.Models.ViewModels.GamesLibrarySort.NumberOfPlayers)">Number of players</option>
                                <option value="System" selected="@(browse.Sort == games_vault.Models.ViewModels.GamesLibrarySort.System)">System</option>
                            </select>
                        </div>
                        <div class="col-6 col-md-4 col-lg-2">
                            <label class="form-label" for="games-group">Group</label>
                            <select id="games-group" name="group" class="form-select games-browse-control">
                                <option value="None" selected="@(browse.Group == games_vault.Models.ViewModels.GamesLibraryGroup.None)">No grouping</option>
                                <option value="System" selected="@(browse.Group == games_vault.Models.ViewModels.GamesLibraryGroup.System)">System</option>
                                <option value="Alphabetical" selected="@(browse.Group == games_vault.Models.ViewModels.GamesLibraryGroup.Alphabetical)">Alphabetical</option>
                                <option value="NumberOfPlayers" selected="@(browse.Group == games_vault.Models.ViewModels.GamesLibraryGroup.NumberOfPlayers)">Number of players</option>
                                <option value="CurrentlyPlaying" selected="@(browse.Group == games_vault.Models.ViewModels.GamesLibraryGroup.CurrentlyPlaying)">Playing now</option>
                            </select>
                        </div>
                        <div class="col-6 col-md-4 col-lg-2">
                            <label class="form-label" for="games-page-size">Page size</label>
                            <select id="games-page-size" name="pageSize" class="form-select games-browse-control">
                                @foreach (var size in new[] { 10, 25, 50, 100 })
                                {
                                    <option value="@size" selected="@(size == pageSize)">@size / page</option>
                                }
                            </select>
                        </div>
                        <div class="col-12 col-md-8 col-lg-4 d-flex flex-wrap gap-2 align-items-center">
                            <div class="form-check form-switch me-auto">
                                <input class="form-check-input games-browse-control" type="checkbox" role="switch" id="games-playing-now" name="playingNow" value="true" checked="@(browse.PlayingNow)">
                                <label class="form-check-label" for="games-playing-now">What's being played right now</label>
                            </div>
                            <button type="submit" class="btn btn-primary">Search</button>
                            <a class="btn btn-outline-secondary" asp-action="Index" asp-route-pageSize="@pageSize">Clear filters</a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <div class="text-muted" id="games-total-count">
                    @Model.TotalCount total
                </div>
            </div>

            <div class="row g-3">
    <div class="col-12 games-bank-column">
        <div id="games-bank-container">
            <partial name="_GamesBank" model="bankModel" />
        </div>
    </div>
</div>
        </div>

        <div class="tab-pane fade @(addTabActive ? "show active" : "")" id="games-add-pane" role="tabpanel" aria-labelledby="games-add-tab" tabindex="0">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
                        <div>
                            <h2 class="h5 mb-1">Add or import games</h2>
                            <div class="text-muted">Upload ROMs directly, or pull from the web, a network share, or a local filesystem source using the existing import tools.</div>
                        </div>
                        <a class="btn btn-outline-secondary" asp-action="Index">Back to browse</a>
                    </div>
                    <partial name="_AddGameModalBody" model="Model.AddGame" view-data='new ViewDataDictionary(ViewData) { ["InlineAddGame"] = true }' />
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var form = document.getElementById('games-search-form');
            var input = document.getElementById('games-search');
            var browseTabButton = document.getElementById('games-browse-tab');
            var addTabButton = document.getElementById('games-add-tab');
            var pageInput = form ? form.querySelector('input[name="page"]') : null;
            var pageSize = document.getElementById('games-page-size');
            var browseControls = form ? Array.from(form.querySelectorAll('.games-browse-control')) : [];
            var bankContainer = document.getElementById('games-bank-container');
            var totalCountEl = document.getElementById('games-total-count');

            function getParams() {
                var data = new FormData(form || undefined);
                return {
                    q: data.get('q') || "",
                    system: data.get('system') || "",
                    players: data.get('players') || "",
                    playingNow: data.get('playingNow') || "",
                    sort: data.get('sort') || "RecentlyAdded",
                    group: data.get('group') || "None",
                    page: pageInput ? pageInput.value : "1",
                    pageSize: pageSize ? pageSize.value : "25"
                };
            }

            function writeParams(searchParams, params) {
                ['q', 'system', 'players', 'playingNow', 'sort', 'group', 'page', 'pageSize'].forEach(function (key) {
                    var value = params[key];
                    var isDefault = (key === 'sort' && value === 'RecentlyAdded') || (key === 'group' && value === 'None') || (key === 'page' && value === '1');
                    if (value && !isDefault) searchParams.set(key, value);
                    else searchParams.delete(key);
                });
            }

            function setUrl(params) {
                var url = new URL(window.location.href);
                writeParams(url.searchParams, params);
                window.history.replaceState({}, "", url.toString());
            }

            function setSurfaceInUrl(surface) {
                var url = new URL(window.location.href);
                if (surface === 'add') url.searchParams.set('openAdd', 'true');
                else url.searchParams.delete('openAdd');
                window.history.replaceState({}, '', url.toString());
            }

            async function loadBank(params) {
                if (!bankContainer) return;
                var qs = new URLSearchParams();
                writeParams(qs, params);

                try {
                    var res = await fetch('/Games/Bank?' + qs.toString(), { cache: 'no-store', credentials: 'same-origin' });
                    if (!res.ok) return;
                    var html = await res.text();
                    bankContainer.innerHTML = html;
                    var total = res.headers.get('X-Games-TotalCount');
                    if (totalCountEl && total) totalCountEl.textContent = total + " total";
                } catch (e) { }
            }

            // Live search: debounce and update the bank only, keeping input focus.
            if (form && input && pageInput) {
                var t = null;
                input.addEventListener('input', function () {
                    if (t) clearTimeout(t);
                    t = setTimeout(function () {
                        pageInput.value = "1";
                        var params = getParams();
                        params.page = "1";
                        setUrl(params);
                        loadBank(params);
                    }, 250);
                });
            }

            if (form) {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    if (pageInput) pageInput.value = "1";
                    var params = getParams();
                    params.page = "1";
                    setUrl(params);
                    loadBank(params);
                });
            }

            if (form && browseControls.length && pageInput) {
                browseControls.forEach(function (control) {
                    control.addEventListener('change', function () {
                        pageInput.value = "1";
                        var params = getParams();
                        params.page = "1";
                        setUrl(params);
                        loadBank(params);
                    });
                });
            }

            if (browseTabButton) {
                browseTabButton.addEventListener('shown.bs.tab', function () {
                    setSurfaceInUrl('browse');
                });
            }

            if (addTabButton) {
                addTabButton.addEventListener('shown.bs.tab', function () {
                    setSurfaceInUrl('add');
                });
            }

            // Intercept pagination clicks to update bank without losing focus.
            if (bankContainer) {
                bankContainer.addEventListener('click', function (e) {
                    var a = e.target && e.target.closest ? e.target.closest('a.page-link') : null;
                    if (!a || !a.getAttribute) return;
                    var href = a.getAttribute('href');
                    if (!href || href[0] === '#') return;
                    if (href.indexOf('/Games') !== 0) return;
                    if (href.indexOf('page=') < 0) return;
                    e.preventDefault();

                    var url = new URL(href, window.location.origin);
                    var params = {
                        q: url.searchParams.get('q') || "",
                        system: url.searchParams.get('system') || "",
                        players: url.searchParams.get('players') || "",
                        playingNow: url.searchParams.get('playingNow') || "",
                        sort: url.searchParams.get('sort') || "RecentlyAdded",
                        group: url.searchParams.get('group') || "None",
                        page: url.searchParams.get('page') || "1",
                        pageSize: url.searchParams.get('pageSize') || (pageSize ? pageSize.value : "25")
                    };
                    if (pageInput) pageInput.value = params.page;
                    setUrl(params);
                    loadBank(params);
                });
            }
        })();
    </script>
}
