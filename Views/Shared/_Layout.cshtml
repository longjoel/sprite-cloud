<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - games_vault</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/games_vault.styles.css" asp-append-version="true" />
    <style>
        /* Prevent FOUC — hide page until fonts load */
        html { font-family: 'Inter', system-ui, sans-serif; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">games_vault</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @{
                            var canManageLibrary = ViewData["CanManageLibrary"] as bool? == true;
                            var isSignedIn = ViewData["CurrentProfileId"] is int;
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Arcade" asp-action="Index">Arcade</a>
                        </li>
                        @if (isSignedIn)
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Games" asp-action="Index">Games</a>
                        </li>
                        }
                        @if (canManageLibrary)
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Admin" asp-action="Index">Admin</a>
                        </li>
                        }
                    </ul>
                    <div class="navbar-nav ms-auto">
                        @if (ViewData["CurrentProfileName"] is string profileName && !string.IsNullOrWhiteSpace(profileName))
                        {
                            <a class="btn-sign-in" asp-controller="Profiles" asp-action="Index">
                                <span>@profileName</span>
                            </a>
                        }
                        else
                        {
                            <button type="button" class="btn-sign-in" data-bs-toggle="modal" data-bs-target="#signInModal">
                                Sign in
                            </button>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["Message"] is string message && !string.IsNullOrWhiteSpace(message))
            {
                <div class="alert alert-info alert-dismissible fade show mt-3" role="alert">
                    @message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <div id="site-warning-banner" class="site-warning-banner" role="region" aria-label="Site warning" hidden>
        <div class="container">
            <div class="site-warning-banner__body shadow-lg rounded-4 border border-warning-subtle bg-dark text-light p-3 p-lg-4">
                <div class="d-flex flex-column flex-lg-row gap-3 align-items-lg-center justify-content-between">
                    <div>
                        <div class="text-uppercase small fw-semibold text-warning mb-2">Warning / cookie notice</div>
                        <div class="fw-semibold mb-2">This site may be dangerous, stores cookies on your computer, may track basic metrics, and probably causes cancer in the state of California.</div>
                        <div class="small text-light-emphasis">By continuing, you acknowledge the risks, the cookies, the metrics, and the general arcade gremlin energy of this vault.</div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 justify-content-lg-end">
                        <button type="button" id="site-warning-accept" class="btn btn-warning text-dark fw-semibold">Acknowledge the danger</button>
                        <button type="button" id="site-warning-dismiss" class="btn btn-outline-light">Dismiss for now</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <partial name="_SignInModal" />

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - games_vault
        </div>
    </footer>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/gv.tables.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
