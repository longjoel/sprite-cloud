<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - games_vault</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/games_vault.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">games_vault</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @{
                            var canManageLibrary = ViewData["CanManageLibrary"] as bool? == true;
                            var isSignedIn = ViewData["CurrentProfileId"] is int;
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Arcade" asp-action="Index">Arcade</a>
                        </li>
                        @if (isSignedIn)
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Games" asp-action="Index">Games</a>
                        </li>
                        }
                        @if (canManageLibrary)
                        {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="admin-nav-dropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Admin</a>
                            <ul class="dropdown-menu" aria-labelledby="admin-nav-dropdown">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Profiles" asp-action="Index">Profiles</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="GameFiles" asp-action="Index">Game Files</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="SystemFiles" asp-action="Index">System Files</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="SystemCoreMappings" asp-action="Index">Core Mappings</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Profiles" asp-action="Invites">Profile Invites</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Sources" asp-action="Index">Sources</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Jobs" asp-action="Index">Jobs</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Downloads" asp-action="Index">Downloads</a></li>
                            </ul>
                        </li>
                        }
                    </ul>
                    <div class="navbar-nav ms-auto">
                        <a class="nav-link text-dark" asp-controller="Profiles" asp-action="Index">
                            @if (ViewData["CurrentProfileName"] is string profileName && !string.IsNullOrWhiteSpace(profileName))
                            {
                                <span>Playing as <strong>@profileName</strong></span>
                            }
                            else
                            {
                                <span>Sign in</span>
                            }
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["Message"] is string message && !string.IsNullOrWhiteSpace(message))
            {
                <div class="alert alert-info mt-3" role="alert">@message</div>
            }
            @RenderBody()
        </main>
    </div>

    <div id="site-warning-banner" class="site-warning-banner" role="region" aria-label="Site warning" hidden>
        <div class="container">
            <div class="site-warning-banner__body shadow-lg rounded-4 border border-warning-subtle bg-dark text-light p-3 p-lg-4">
                <div class="d-flex flex-column flex-lg-row gap-3 align-items-lg-center justify-content-between">
                    <div>
                        <div class="text-uppercase small fw-semibold text-warning mb-2">Warning / cookie notice</div>
                        <div class="fw-semibold mb-2">This site may be dangerous, stores cookies on your computer, may track basic metrics, and probably causes cancer in the state of California.</div>
                        <div class="small text-light-emphasis">By continuing, you acknowledge the risks, the cookies, the metrics, and the general arcade gremlin energy of this vault.</div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 justify-content-lg-end">
                        <button type="button" id="site-warning-accept" class="btn btn-warning text-dark fw-semibold">Acknowledge the danger</button>
                        <button type="button" id="site-warning-dismiss" class="btn btn-outline-light">Dismiss for now</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - games_vault
        </div>
    </footer>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/gv.tables.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
