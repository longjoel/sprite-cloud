@model games_vault.Models.ViewModels.ProfileBatterySaveUploadViewModel

@{
    ViewData["Title"] = "Upload battery save";
}

<div class="d-flex align-items-center justify-content-between gap-3 mb-3 flex-wrap">
    <div>
        <h1 class="h3 mb-0">Upload battery save</h1>
        <div class="text-muted">@Model.GameName · @Model.SystemName</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary" asp-controller="Games" asp-action="PlayServer" asp-route-id="@Model.GameId">Back to game</a>
        <a class="btn btn-outline-primary" asp-action="History" asp-route-gameId="@Model.GameId" asp-route-gameFileId="@Model.GameFileId">Save history</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Upload" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="GameId" />
            <input type="hidden" asp-for="GameFileId" />
            <input type="hidden" asp-for="GameName" />
            <input type="hidden" asp-for="GameFileName" />
            <input type="hidden" asp-for="SystemName" />
            <input type="hidden" asp-for="ReturnUrl" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Key" class="form-label"></label>
                    <input asp-for="Key" class="form-control" placeholder="default" />
                    <span asp-validation-for="Key" class="text-danger"></span>
                    <div class="form-text">Leave this as <code>default</code> unless you know the save stream uses a different key.</div>
                </div>

                <div class="col-md-4">
                    <label asp-for="FileName" class="form-label"></label>
                    <input asp-for="FileName" class="form-control" placeholder="e.g. sonic.srm" />
                    <span asp-validation-for="FileName" class="text-danger"></span>
                    <div class="form-text">If blank, the uploaded file name is used.</div>
                </div>

                <div class="col-md-4">
                    <label asp-for="Upload" class="form-label"></label>
                    <input asp-for="Upload" type="file" class="form-control" accept=".sav,.srm" />
                    <span asp-validation-for="Upload" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Upload save</button>
                <a class="btn btn-outline-secondary" asp-controller="Games" asp-action="PlayServer" asp-route-id="@Model.GameId">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
