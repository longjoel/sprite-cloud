@model games_vault.Models.ViewModels.WebSourceEditViewModel

@{
    ViewData["Title"] = "Edit web source";
}

<h1 class="h3">Edit web source</h1>

<form asp-action="Edit" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="IndexUrl" class="form-label"></label>
        <input asp-for="IndexUrl" class="form-control" />
        <span asp-validation-for="IndexUrl" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AllowedExtensions" class="form-label"></label>
        <input asp-for="AllowedExtensions" class="form-control" placeholder=".zip,.7z,.nes,.gb,.gbc,.gba" />
        <span asp-validation-for="AllowedExtensions" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Enabled" class="form-check-input" />
        <label asp-for="Enabled" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-link">Cancel</a>
</form>

