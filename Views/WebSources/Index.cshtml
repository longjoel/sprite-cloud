@model games_vault.Models.ViewModels.WebSourcesIndexViewModel

@{
    ViewData["Title"] = "Web sources";
    var pageSize = Model.PageSize;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Web sources</h1>
    <a class="btn btn-primary" asp-action="Create">Add website</a>
</div>

@if (Model.Sources.Count == 0)
{
    <div class="alert alert-info mb-0">No web sources configured.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Index URL</th>
                    <th>Extensions</th>
                    <th>Enabled</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var src in Model.Sources)
            {
                <tr>
                    <td>@src.Name</td>
                    <td class="text-truncate" style="max-width: 40rem;">@src.IndexUrl</td>
                    <td class="text-truncate" style="max-width: 20rem;">@(string.IsNullOrWhiteSpace(src.AllowedExtensions) ? "Any" : src.AllowedExtensions)</td>
                    <td>@(src.Enabled ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@src.Id">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@src.Id">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        var start = Math.Max(1, Model.Page - 3);
        var end = Math.Min(Model.PageCount, start + 6);
        start = Math.Max(1, end - 6);

        <nav aria-label="Web sources pagination" class="mt-3">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-pageSize="@pageSize">Previous</a>
                </li>

                @for (var p = start; p <= end; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@p"
                           asp-route-pageSize="@pageSize">@p</a>
                    </li>
                }

                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-pageSize="@pageSize">Next</a>
                </li>
            </ul>
        </nav>
    }
}
