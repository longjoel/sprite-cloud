@model games_vault.Models.ViewModels.HomeIndexViewModel

@{
    ViewData["Title"] = "Games Vault";
    var canManageLibrary = Model.CanManageLibrary;
    var arcadeSessions = Model.ActiveArcadeCabinets;
}

@functions {
    private static string FormatDuration(TimeSpan value)
    {
        if (value.TotalDays >= 1) return $"{(int)value.TotalDays}d {value.Hours}h";
        if (value.TotalHours >= 1) return $"{(int)value.TotalHours}h {value.Minutes}m";
        if (value.TotalMinutes >= 1) return $"{(int)value.TotalMinutes}m";
        return $"{Math.Max(0, (int)value.TotalSeconds)}s";
    }

    private static string FormatSessionLabel(games_vault.Models.ViewModels.ActiveNosebleedSessionViewModel session)
    {
        return session.IsArcadeCabinet
            ? $"Arcade cabinet · {session.ArcadeCabinetName ?? session.GameName}"
            : "Library session";
    }

    private static string ShortSystemName(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "ROM";
        var initials = new string(name
            .Split([' ', '-', '_', '/'], StringSplitOptions.RemoveEmptyEntries)
            .Select(p => char.ToUpperInvariant(p[0]))
            .Distinct()
            .Take(3)
            .ToArray());
        return string.IsNullOrWhiteSpace(initials) ? "ROM" : initials;
    }
}

@* ── Guest Hero — clean, dark, focused ── *@
@if (Model.CurrentProfileId is null)
{
    <section class="guest-hero">
        <div>
            <h1>Games Vault</h1>
            <p>Watch live arcades or sign in to play.</p>
            <div class="d-flex gap-3 justify-content-center">
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#signInModal">Sign in / join</button>
                <a class="btn btn-outline-secondary" asp-controller="Arcade" asp-action="Index">Watch active machines</a>
            </div>
        </div>
    </section>

    @if (Model.ActiveArcadeCabinets.Count > 0)
    {
        <section class="guest-machines">
            <div class="container">
                <h2>Running now</h2>
                <div class="row g-3">
                    @foreach (var session in Model.ActiveArcadeCabinets)
                    {
                        <div class="col-lg-4 col-md-6">
                            <div class="guest-machine-card" data-nosebleed-preview-card data-preview-url="@Url.Action("NosebleedPreviewVideo", "Home", new { sessionId = session.SessionId })" data-stream-url="@Url.Action("NosebleedPreviewStream", "Home", new { sessionId = session.SessionId })">
                                <div class="ratio ratio-16x9">
                                    <canvas data-nosebleed-preview-canvas class="w-100 h-100" style="image-rendering: pixelated;"></canvas>
                                </div>
                                <div class="card-body">
                                    <h3>@(session.ArcadeCabinetName ?? session.GameName)</h3>
                                    <div class="meta">@(session.IsArcadeCabinet ? "Arcade" : "Library") · @FormatDuration(session.Runtime)</div>
                                    <div class="mt-2 d-flex gap-2 flex-wrap">
                                        <a class="btn btn-sm btn-primary" asp-controller="Games" asp-action="PlayServer" asp-route-id="@session.GameId" asp-route-code="@session.RoomCode">Watch</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
}

@if (Model.CurrentProfileId is not null && Model.ShowDashboard)
{
    @if (Model.PinnedGames.Count > 0)
    {
        <section class="mb-4">
            <h2 class="h5 mb-3">Pinned</h2>
            <div class="row row-cols-2 row-cols-md-4 g-2">
                @foreach (var game in Model.PinnedGames)
                {
                    var shortSystem = ShortSystemName(game.SystemName);
                    var previewImage = !string.IsNullOrWhiteSpace(game.ScreenshotImagePath) ? game.ScreenshotImagePath : game.CoverImagePath;
                    <div class="col">
                        <div class="card games-card games-card-sm h-100 shadow-sm">
                            <div class="games-card-banner">@shortSystem</div>
                            <div class="games-card-preview games-card-preview-sm">
                                @if (!string.IsNullOrWhiteSpace(previewImage))
                                {
                                    <img class="games-card-preview-image" src="@previewImage" alt="" loading="lazy" />
                                }
                                <div class="games-card-preview-text games-card-preview-text-sm">@game.GameName</div>
                            </div>
                            <div class="card-body">
                                <div class="games-card-name-wrap">
                                    <h3 class="games-card-name games-card-name-sm" title="@game.GameName">@game.GameName</h3>
                                </div>
                                <div class="games-card-footer">
                                    <div class="games-card-footer-actions" style="width:100%;">
                                        <a class="btn btn-primary btn-sm" asp-controller="Games" asp-action="PlayServer" asp-route-id="@game.GameId">Play</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <section class="mb-4">
        <h2 class="h5 mb-3">Continue playing</h2>
        <div class="row row-cols-2 row-cols-md-4 g-2">
            @foreach (var session in Model.RecentSessions.Take(6))
            {
                var shortSystem = ShortSystemName(session.SystemName);
                var previewImage = !string.IsNullOrWhiteSpace(session.ScreenshotImagePath) ? session.ScreenshotImagePath : session.CoverImagePath;
                <div class="col">
                    <div class="card games-card games-card-sm h-100 shadow-sm">
                        <div class="games-card-banner">@shortSystem</div>
                        <div class="games-card-preview games-card-preview-sm">
                            @if (!string.IsNullOrWhiteSpace(previewImage))
                            {
                                <img class="games-card-preview-image" src="@previewImage" alt="" loading="lazy" />
                            }
                            <div class="games-card-preview-text games-card-preview-text-sm">@session.GameName</div>
                        </div>
                        <div class="card-body">
                            <div class="games-card-name-wrap">
                                <h3 class="games-card-name games-card-name-sm" title="@session.GameName">@session.GameName</h3>
                                <span class="small text-muted">@FormatDuration(session.Duration)</span>
                            </div>
                            <div class="games-card-footer">
                                <div class="games-card-footer-actions" style="width:100%;">
                                    <a class="btn btn-primary btn-sm" asp-controller="Games" asp-action="PlayServer" asp-route-id="@session.GameId">Play</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <section id="home-active-machines" class="mb-4">
        <div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-3">
            <div>
                <div class="text-uppercase text-muted small fw-semibold mb-1">Live now</div>
                <h2 class="h3 mb-1">Active machines</h2>
                <div class="text-muted">Live cabinets and sessions.</div>
            </div>
            <a class="btn btn-outline-secondary" asp-controller="Arcade" asp-action="Index">Open arcade</a>
        </div>
        @if (arcadeSessions.Count == 0)
        {
            <p class="text-muted">No active machines right now.</p>
            <a class="btn btn-primary" asp-controller="Games" asp-action="Index">Browse games</a>
        }
        else
        {
            <div class="row g-2">
                @foreach (var session in arcadeSessions)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="card games-card h-100 shadow-sm" data-nosebleed-preview-card data-preview-url="@Url.Action("NosebleedPreviewVideo", "Home", new { sessionId = session.SessionId })" data-stream-url="@Url.Action("NosebleedPreviewStream", "Home", new { sessionId = session.SessionId })">
                            <div class="ratio ratio-16x9 bg-dark rounded-top overflow-hidden">
                                <canvas data-nosebleed-preview-canvas class="w-100 h-100" style="image-rendering: pixelated;"></canvas>
                            </div>
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                    <div>
                                        <h3 class="h5 mb-1">@(session.ArcadeCabinetName ?? session.GameName)</h3>
                                        <div class="small text-muted">@FormatSessionLabel(session)</div>
                                    </div>
                                    <span class="badge @(session.IsArcadeCabinet ? "text-bg-primary" : "text-bg-secondary")">@(session.IsArcadeCabinet ? "Arcade" : "Library")</span>
                                </div>
                                <div class="small text-muted mb-3">Runtime @FormatDuration(session.Runtime)</div>
                                <div class="games-card-footer">
                                    <div class="games-card-footer-actions">
                                        @if (session.IsArcadeCabinet && session.ArcadeCabinetId is not null)
                                        {
                                            <a class="btn btn-sm btn-primary" href="@Url.RouteUrl("ArcadeSession", new { sessionId = session.SessionId })">Watch</a>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(session.RoomCode))
                                        {
                                            <a class="btn btn-sm btn-primary" asp-controller="Games" asp-action="PlayServer" asp-route-id="@session.GameId" asp-route-code="@session.RoomCode">Play</a>
                                        }
                                        else
                                        {
                                            <a class="btn btn-sm btn-outline-secondary" asp-controller="Games" asp-action="Details" asp-route-id="@session.GameId">Details</a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
}

@section Scripts {
    @if (Model.ActiveArcadeCabinets.Count > 0)
    {
        <script src="~/js/nosebleed-player/preview.js" asp-append-version="true"></script>
    }
}
