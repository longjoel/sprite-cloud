@model games_vault.Models.GameFile

@{
    var game = ViewData["Game"] as games_vault.Models.Game;
    ViewData["Title"] = "Add file";
}

<h1 class="h3">Add file</h1>

@if (game is not null)
{
    <div class="text-muted">@game.Name (@game.SystemName)</div>
}

<form asp-action="Create" method="post" class="mt-3">
    <input type="hidden" asp-for="GameId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Crc32" class="form-label"></label>
        <input asp-for="Crc32" class="form-control" />
        <span asp-validation-for="Crc32" class="text-danger"></span>
        <div class="form-text">8 hex characters, e.g. 1A2B3C4D.</div>
    </div>

    <div class="mb-3">
        <label asp-for="SizeBytes" class="form-label"></label>
        <input asp-for="SizeBytes" class="form-control" />
        <span asp-validation-for="SizeBytes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-link" asp-controller="Games" asp-action="Details" asp-route-id="@Model.GameId">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
