@model games_vault.Models.ViewModels.SourcesIndexViewModel

@{
    ViewData["Title"] = "Sources";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Sources</h1>
</div>

<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="tab-shares" data-bs-toggle="tab" data-bs-target="#pane-shares" type="button" role="tab">Shares (@Model.NetworkSharesTotalCount)</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-local" data-bs-toggle="tab" data-bs-target="#pane-local" type="button" role="tab">Local folders (@Model.LocalFoldersTotalCount)</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-web" data-bs-toggle="tab" data-bs-target="#pane-web" type="button" role="tab">Web sources (@Model.WebSourcesTotalCount)</button>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade show active" id="pane-shares" role="tabpanel" aria-labelledby="tab-shares">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="fw-semibold">Network shares</div>
            <a class="btn btn-sm btn-primary" asp-controller="NetworkShares" asp-action="Create">Add share</a>
        </div>

        @if (Model.NetworkShares.Count == 0)
        {
            <div class="alert alert-info mb-0">No shares configured.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Path</th>
                            <th>Enabled</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var share in Model.NetworkShares)
                    {
                        <tr>
                            <td>@share.Name</td>
                            <td class="text-truncate" style="max-width: 40rem;">@share.RootPath</td>
                            <td>@(share.Enabled ? "Yes" : "No")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-controller="NetworkShares" asp-action="Edit" asp-route-id="@share.Id">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="NetworkShares" asp-action="Delete" asp-route-id="@share.Id">Delete</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            @if (Model.NetworkSharesPageCount > 1)
            {
                var start = Math.Max(1, Model.NetworkSharesPage - 3);
                var end = Math.Min(Model.NetworkSharesPageCount, start + 6);
                start = Math.Max(1, end - 6);

                <nav aria-label="Shares pagination" class="mt-3">
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.NetworkSharesHasPrevious ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-sharesPage="@(Model.NetworkSharesPage - 1)"
                               asp-route-sharesPageSize="@Model.NetworkSharesPageSize"
                               asp-route-localPage="@Model.LocalFoldersPage"
                               asp-route-localPageSize="@Model.LocalFoldersPageSize"
                               asp-route-webPage="@Model.WebSourcesPage"
                               asp-route-webPageSize="@Model.WebSourcesPageSize">Previous</a>
                        </li>

                        @for (var p = start; p <= end; p++)
                        {
                            <li class="page-item @(p == Model.NetworkSharesPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-sharesPage="@p"
                                   asp-route-sharesPageSize="@Model.NetworkSharesPageSize"
                                   asp-route-localPage="@Model.LocalFoldersPage"
                                   asp-route-localPageSize="@Model.LocalFoldersPageSize"
                                   asp-route-webPage="@Model.WebSourcesPage"
                                   asp-route-webPageSize="@Model.WebSourcesPageSize">@p</a>
                            </li>
                        }

                        <li class="page-item @(Model.NetworkSharesHasNext ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-sharesPage="@(Model.NetworkSharesPage + 1)"
                               asp-route-sharesPageSize="@Model.NetworkSharesPageSize"
                               asp-route-localPage="@Model.LocalFoldersPage"
                               asp-route-localPageSize="@Model.LocalFoldersPageSize"
                               asp-route-webPage="@Model.WebSourcesPage"
                               asp-route-webPageSize="@Model.WebSourcesPageSize">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>

    <div class="tab-pane fade" id="pane-local" role="tabpanel" aria-labelledby="tab-local">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="fw-semibold">Local folders</div>
            <a class="btn btn-sm btn-primary" asp-controller="LocalFolders" asp-action="Create">Add folder</a>
        </div>

        @if (Model.LocalFolders.Count == 0)
        {
            <div class="alert alert-info mb-0">No folders configured.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Path</th>
                            <th>Enabled</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var f in Model.LocalFolders)
                    {
                        <tr>
                            <td>@f.Name</td>
                            <td class="text-truncate" style="max-width: 40rem;">@f.RootPath</td>
                            <td>@(f.Enabled ? "Yes" : "No")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-controller="LocalFolders" asp-action="Edit" asp-route-id="@f.Id">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="LocalFolders" asp-action="Delete" asp-route-id="@f.Id">Delete</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            @if (Model.LocalFoldersPageCount > 1)
            {
                var start = Math.Max(1, Model.LocalFoldersPage - 3);
                var end = Math.Min(Model.LocalFoldersPageCount, start + 6);
                start = Math.Max(1, end - 6);

                <nav aria-label="Local folders pagination" class="mt-3">
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.LocalFoldersHasPrevious ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-sharesPage="@Model.NetworkSharesPage"
                               asp-route-sharesPageSize="@Model.NetworkSharesPageSize"
                               asp-route-localPage="@(Model.LocalFoldersPage - 1)"
                               asp-route-localPageSize="@Model.LocalFoldersPageSize"
                               asp-route-webPage="@Model.WebSourcesPage"
                               asp-route-webPageSize="@Model.WebSourcesPageSize">Previous</a>
                        </li>

                        @for (var p = start; p <= end; p++)
                        {
                            <li class="page-item @(p == Model.LocalFoldersPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-sharesPage="@Model.NetworkSharesPage"
                                   asp-route-sharesPageSize="@Model.NetworkSharesPageSize"
                                   asp-route-localPage="@p"
                                   asp-route-localPageSize="@Model.LocalFoldersPageSize"
                                   asp-route-webPage="@Model.WebSourcesPage"
                                   asp-route-webPageSize="@Model.WebSourcesPageSize">@p</a>
                            </li>
                        }

                        <li class="page-item @(Model.LocalFoldersHasNext ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-sharesPage="@Model.NetworkSharesPage"
                               asp-route-sharesPageSize="@Model.NetworkSharesPageSize"
                               asp-route-localPage="@(Model.LocalFoldersPage + 1)"
                               asp-route-localPageSize="@Model.LocalFoldersPageSize"
                               asp-route-webPage="@Model.WebSourcesPage"
                               asp-route-webPageSize="@Model.WebSourcesPageSize">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>

    <div class="tab-pane fade" id="pane-web" role="tabpanel" aria-labelledby="tab-web">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="fw-semibold">Web sources</div>
            <a class="btn btn-sm btn-primary" asp-controller="WebSources" asp-action="Create">Add website</a>
        </div>

        @if (Model.WebSources.Count == 0)
        {
            <div class="alert alert-info mb-0">No web sources configured.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Index URL</th>
                            <th>Extensions</th>
                            <th>Enabled</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var src in Model.WebSources)
                    {
                        <tr>
                            <td>@src.Name</td>
                            <td class="text-truncate" style="max-width: 40rem;">@src.IndexUrl</td>
                            <td class="text-truncate" style="max-width: 20rem;">@(string.IsNullOrWhiteSpace(src.AllowedExtensions) ? "Any" : src.AllowedExtensions)</td>
                            <td>@(src.Enabled ? "Yes" : "No")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-controller="WebSources" asp-action="Edit" asp-route-id="@src.Id">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-controller="WebSources" asp-action="Delete" asp-route-id="@src.Id">Delete</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            @if (Model.WebSourcesPageCount > 1)
            {
                var start = Math.Max(1, Model.WebSourcesPage - 3);
                var end = Math.Min(Model.WebSourcesPageCount, start + 6);
                start = Math.Max(1, end - 6);

                <nav aria-label="Web sources pagination" class="mt-3">
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.WebSourcesHasPrevious ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-sharesPage="@Model.NetworkSharesPage"
                               asp-route-sharesPageSize="@Model.NetworkSharesPageSize"
                               asp-route-localPage="@Model.LocalFoldersPage"
                               asp-route-localPageSize="@Model.LocalFoldersPageSize"
                               asp-route-webPage="@(Model.WebSourcesPage - 1)"
                               asp-route-webPageSize="@Model.WebSourcesPageSize">Previous</a>
                        </li>

                        @for (var p = start; p <= end; p++)
                        {
                            <li class="page-item @(p == Model.WebSourcesPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-sharesPage="@Model.NetworkSharesPage"
                                   asp-route-sharesPageSize="@Model.NetworkSharesPageSize"
                                   asp-route-localPage="@Model.LocalFoldersPage"
                                   asp-route-localPageSize="@Model.LocalFoldersPageSize"
                                   asp-route-webPage="@p"
                                   asp-route-webPageSize="@Model.WebSourcesPageSize">@p</a>
                            </li>
                        }

                        <li class="page-item @(Model.WebSourcesHasNext ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-sharesPage="@Model.NetworkSharesPage"
                               asp-route-sharesPageSize="@Model.NetworkSharesPageSize"
                               asp-route-localPage="@Model.LocalFoldersPage"
                               asp-route-localPageSize="@Model.LocalFoldersPageSize"
                               asp-route-webPage="@(Model.WebSourcesPage + 1)"
                               asp-route-webPageSize="@Model.WebSourcesPageSize">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>

