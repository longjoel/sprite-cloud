@model games_vault.Models.ViewModels.SystemFilesMissingViewModel

@{
    ViewData["Title"] = "Missing system files";
}

<h1 class="h3">Missing system files</h1>

@if (Model.Groups.Count == 0)
{
    <p class="text-muted">No missing system files.</p>
}
else
{
    @foreach (var group in Model.Groups)
    {
        <div class="card mb-3">
            <div class="card-header fw-semibold">@group.System</div>
            <ul class="list-group list-group-flush">
                @foreach (var item in group.Missing)
                {
                    <li class="list-group-item font-monospace small">
                        @item.RelativePath
                        <span class="text-muted ms-2">CRC32: @item.Crc32</span>
                    </li>
                }
            </ul>
        </div>
    }
}

<div class="mt-3">
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>
