@{
    ViewData["Title"] = "Import system files from source";
    var localFolders = ViewData["LocalFolders"] as IReadOnlyList<games_vault.Models.LocalFolder> ?? [];
    var networkShares = ViewData["NetworkShares"] as IReadOnlyList<games_vault.Models.NetworkShare> ?? [];
}

<h1 class="h3">Import from source</h1>

<p class="text-muted">Import missing system files from configured local folders and network shares.</p>

@if (localFolders.Count == 0 && networkShares.Count == 0)
{
    <div class="alert alert-warning">No local folders or network shares configured.</div>
}
else
{
    <form asp-action="ImportSource" method="post">
        @Html.AntiForgeryToken()

        @if (localFolders.Count > 0)
        {
            <div class="card mb-3">
                <div class="card-header fw-semibold">Local folders</div>
                <ul class="list-group list-group-flush">
                    @foreach (var folder in localFolders)
                    {
                        <li class="list-group-item">
                            <span class="font-monospace">@folder.RootPath</span>
                            <span class="text-muted ms-2">@folder.Name</span>
                        </li>
                    }
                </ul>
            </div>
        }

        @if (networkShares.Count > 0)
        {
            <div class="card mb-3">
                <div class="card-header fw-semibold">Network shares</div>
                <ul class="list-group list-group-flush">
                    @foreach (var share in networkShares)
                    {
                        <li class="list-group-item">
                            <span class="font-monospace">@share.RootPath</span>
                            <span class="text-muted ms-2">@share.Name</span>
                        </li>
                    }
                </ul>
            </div>
        }

        <button type="submit" class="btn btn-primary">Run import</button>
    </form>
}

<div class="mt-3">
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>
