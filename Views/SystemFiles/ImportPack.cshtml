@{
    ViewData["Title"] = "Import system pack";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Import system pack</h1>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<div class="alert alert-info">
    Upload a .zip of BIOS/system files. Files are matched by CRC32 against libretro-database <code>System.dat</code> and placed into the correct relative path under the system directory.
</div>

<form asp-action="ImportPack" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Pack (.zip)</label>
            <input name="pack" type="file" class="form-control" accept=".zip,application/zip" />
        </div>

        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="overwrite" value="true" id="systemfiles-overwrite" />
                <label class="form-check-label" for="systemfiles-overwrite">
                    Overwrite existing files
                </label>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary">Import</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

