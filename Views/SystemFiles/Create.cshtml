@{
    ViewData["Title"] = "Add system file";
    var systems = ViewData["Systems"] as IReadOnlyList<string> ?? Array.Empty<string>();
    var knownPaths = ViewData["KnownPaths"] as IReadOnlyList<string> ?? Array.Empty<string>();
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Add system file</h1>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="mt-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">System</label>
            <input name="systemName" class="form-control" list="systemfiles-systems" placeholder="e.g. Sony - PlayStation" />
            <datalist id="systemfiles-systems">
                @foreach (var s in systems)
                {
                    <option value="@s"></option>
                }
            </datalist>
        </div>

        <div class="col-md-2">
            <label class="form-label">Kind</label>
            <select name="kind" class="form-select">
                <option value="bios" selected>BIOS</option>
                <option value="system">System</option>
                <option value="other">Other</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Target path (optional)</label>
            <input name="targetPath" class="form-control" list="systemfiles-knownpaths" placeholder="e.g. dc/boot.bin" />
            <datalist id="systemfiles-knownpaths">
                @foreach (var p in knownPaths)
                {
                    <option value="@p"></option>
                }
            </datalist>
            <div class="form-text">If set, bytes are stored under the system directory at this exact relative path.</div>
        </div>

        <div class="col-md-3">
            <label class="form-label">File</label>
            <input name="file" type="file" class="form-control" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary">Upload</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
