@model games_vault.Models.ViewModels.JobsIndexViewModel

@{
    ViewData["Title"] = "Jobs";
    var currentPage = Model.Page;
    var pageSize = Model.PageSize;
}

@if (TempData["Message"] is string message && !string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info">@message</div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Jobs</h1>
</div>

<div class="d-flex align-items-end justify-content-between gap-3 flex-wrap mb-3">
    <div style="min-width: 14rem;">
        <label class="form-label mb-1">Status</label>
        <select class="form-select" id="jobs-status">
            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Status))">All</option>
            <option value="Queued" selected="@(string.Equals(Model.Status, "Queued", StringComparison.OrdinalIgnoreCase))">Queued</option>
            <option value="Running" selected="@(string.Equals(Model.Status, "Running", StringComparison.OrdinalIgnoreCase))">Running</option>
            <option value="Succeeded" selected="@(string.Equals(Model.Status, "Succeeded", StringComparison.OrdinalIgnoreCase))">Succeeded</option>
            <option value="Failed" selected="@(string.Equals(Model.Status, "Failed", StringComparison.OrdinalIgnoreCase))">Failed</option>
            <option value="Paused" selected="@(string.Equals(Model.Status, "Paused", StringComparison.OrdinalIgnoreCase))">Paused</option>
            <option value="Canceled" selected="@(string.Equals(Model.Status, "Canceled", StringComparison.OrdinalIgnoreCase))">Canceled</option>
        </select>
    </div>

    <form id="jobs-bulk-form" method="post" class="d-flex gap-2 flex-wrap align-items-center mb-0">
        @Html.AntiForgeryToken()
        <input type="hidden" name="status" id="jobs-bulk-status" value="@Model.Status" />
        <input type="hidden" name="page" id="jobs-bulk-page" value="@currentPage" />
        <input type="hidden" name="pageSize" id="jobs-bulk-pageSize" value="@pageSize" />
        <button type="submit" class="btn btn-outline-secondary" formaction="/Jobs/ClearCompleted">Clear completed</button>
        <button type="submit" class="btn btn-outline-secondary" id="jobs-pause-selected" formaction="/Jobs/PauseSelected" disabled>Pause selected</button>
        <button type="submit" class="btn btn-outline-warning" id="jobs-cancel-selected" formaction="/Jobs/CancelSelected" disabled>Cancel selected</button>
        <button type="submit" class="btn btn-outline-danger" id="jobs-delete-selected" formaction="/Jobs/DeleteSelected" disabled>Delete selected</button>
        <button type="submit" class="btn btn-outline-primary" id="jobs-rerun-selected" formaction="/Jobs/RerunSelected" disabled>Re-run selected</button>
        <span class="text-muted" id="jobs-selected-count"></span>
    </form>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th style="width:2.5rem;"><input type="checkbox" class="form-check-input" id="jobs-select-all" /></th>
                <th>Id</th>
                <th>Command</th>
                <th>Status</th>
                <th>Attempt</th>
                <th>Progress</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody id="jobs-tbody">
            <partial name="_JobRows" model="Model.Jobs" />
        </tbody>
    </table>
</div>

@if (Model.PageCount > 1)
{
    var start = Math.Max(1, Model.Page - 3);
    var end = Math.Min(Model.PageCount, start + 6);
    start = Math.Max(1, end - 6);

    <nav aria-label="Jobs pagination" class="mt-3">
        <ul class="pagination mb-0">
            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-status="@Model.Status"
                   asp-route-page="@(Model.Page - 1)"
                   asp-route-pageSize="@pageSize">Previous</a>
            </li>

            @for (var p = start; p <= end; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-status="@Model.Status"
                       asp-route-page="@p"
                       asp-route-pageSize="@pageSize">@p</a>
                </li>
            }

            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-status="@Model.Status"
                   asp-route-page="@(Model.Page + 1)"
                   asp-route-pageSize="@pageSize">Next</a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        (function () {
            var statusSel = document.getElementById("jobs-status");
            var tbody = document.getElementById("jobs-tbody");
            var selectAll = document.getElementById("jobs-select-all");
            var bulkForm = document.getElementById("jobs-bulk-form");
            var bulkStatus = document.getElementById("jobs-bulk-status");
            var bulkPage = document.getElementById("jobs-bulk-page");
            var bulkPageSize = document.getElementById("jobs-bulk-pageSize");
            var btnPause = document.getElementById("jobs-pause-selected");
            var btnCancel = document.getElementById("jobs-cancel-selected");
            var btnDelete = document.getElementById("jobs-delete-selected");
            var btnRerun = document.getElementById("jobs-rerun-selected");
            var countEl = document.getElementById("jobs-selected-count");

            var selected = new Set();
            var pauseUntil = 0;
            var lastHtml = "";
            var page = parseInt("@currentPage", 10) || 1;
            var pageSize = parseInt("@pageSize", 10) || 100;

            function setPaused(ms) {
                pauseUntil = Math.max(pauseUntil, Date.now() + ms);
            }

            function updateBulkUi() {
                var checks = Array.prototype.slice.call(document.querySelectorAll("input.job-select"));
                var ids = (window.GVTables ? window.GVTables.distinctInts(checks.filter(function (c) { return c.checked; }).map(function (c) { return c.value; })) : []);
                var count = ids.length;
                if (btnPause) btnPause.disabled = count === 0;
                if (btnCancel) btnCancel.disabled = count === 0;
                if (btnDelete) btnDelete.disabled = count === 0;
                if (btnRerun) btnRerun.disabled = count === 0;
                if (countEl) countEl.textContent = count === 0 ? "" : (count + " selected");
                if (selectAll) selectAll.checked = count > 0 && count === checks.length;
            }

            function wireCheckboxes() {
                Array.prototype.slice.call(document.querySelectorAll("input.job-select"))
                    .forEach(function (c) {
                        var id = parseInt(c.value, 10);
                        if (Number.isFinite(id)) {
                            c.checked = selected.has(id);
                        }
                        c.addEventListener("change", function () {
                            var id2 = parseInt(c.value, 10);
                            if (Number.isFinite(id2)) {
                                if (c.checked) selected.add(id2); else selected.delete(id2);
                            }
                            setPaused(1200);
                            updateBulkUi();
                        });
                    });

                updateBulkUi();
            }

            async function refreshRows() {
                if (!tbody) return;
                if (Date.now() < pauseUntil) return;

                var st = statusSel ? statusSel.value : "";
                try {
                    var res = await fetch("/Jobs/Rows?status=" + encodeURIComponent(st) + "&page=" + encodeURIComponent(String(page)) + "&pageSize=" + encodeURIComponent(String(pageSize)), { cache: "no-store" });
                    if (!res.ok) return;
                    var html = await res.text();
                    if (html === lastHtml) return;
                    lastHtml = html;
                    tbody.innerHTML = html;
                    wireCheckboxes();
                } catch (e) { }
            }

            if (tbody) {
                tbody.addEventListener("pointerdown", function () { setPaused(1500); });
                tbody.addEventListener("pointerenter", function () { setPaused(500); });
                tbody.addEventListener("keydown", function () { setPaused(1500); });
            }

            if (selectAll) {
                selectAll.addEventListener("change", function () {
                    var checks = Array.prototype.slice.call(document.querySelectorAll("input.job-select"));
                    checks.forEach(function (c) {
                        c.checked = selectAll.checked;
                        var id = parseInt(c.value, 10);
                        if (Number.isFinite(id)) {
                            if (c.checked) selected.add(id); else selected.delete(id);
                        }
                    });
                    setPaused(1200);
                    updateBulkUi();
                });
            }

            if (statusSel) {
                statusSel.addEventListener("change", function () {
                    // Simpler and more reliable than trying to live-update pagination + selection:
                    // reload to page 1 for the chosen status.
                    var url = new URL(window.location.href);
                    if (statusSel.value) url.searchParams.set("status", statusSel.value);
                    else url.searchParams.delete("status");
                    url.searchParams.set("page", "1");
                    url.searchParams.set("pageSize", String(pageSize));
                    window.location.href = url.toString();
                });
            }

            if (bulkForm) {
                bulkForm.addEventListener("submit", function () {
                    if (window.GVTables) {
                        window.GVTables.setHiddenIds(bulkForm, Array.from(selected.values()), "ids");
                    }
                    if (bulkStatus && statusSel) bulkStatus.value = statusSel.value || "";
                    if (bulkPage) bulkPage.value = String(page);
                    if (bulkPageSize) bulkPageSize.value = String(pageSize);
                });
            }

            wireCheckboxes();
            setInterval(refreshRows, 2000);
            refreshRows();
        })();
    </script>
}
