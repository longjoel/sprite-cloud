@model games_vault.Models.ViewModels.AdminIndexViewModel

@{
    ViewData["Title"] = "Admin";
}

@functions {
    private static string FormatDuration(TimeSpan value)
    {
        if (value.TotalDays >= 1) return $"{(int)value.TotalDays}d {value.Hours}h";
        if (value.TotalHours >= 1) return $"{(int)value.TotalHours}h {value.Minutes}m";
        if (value.TotalMinutes >= 1) return $"{(int)value.TotalMinutes}m";
        return $"{Math.Max(0, (int)value.TotalSeconds)}s";
    }

    private static string ShortId(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "—";
        return value.Length <= 18 ? value : value[..18] + "…";
    }

    private static string FormatBytes(long bytes)
    {
        const double MiB = 1024d * 1024d;
        const double GiB = MiB * 1024d;

        return bytes >= GiB
            ? $"{bytes / GiB:0.00} GiB"
            : $"{bytes / MiB:0.0} MiB";
    }
}

@if (TempData["AdminMessage"] is string adminMessage && !string.IsNullOrWhiteSpace(adminMessage))
{
    <div class="alert alert-success" role="status">@adminMessage</div>
}

@* ── Quick nav ── *@
<div class="d-flex flex-wrap gap-2 mb-4">
    <a class="btn btn-sm btn-outline-secondary" href="#admin-stream-settings">Stream</a>
    <a class="btn btn-sm btn-outline-secondary" href="#admin-nosebleed-runtime">Nosebleed</a>
    <a class="btn btn-sm btn-outline-secondary" href="#admin-game-art">Art</a>
    <a class="btn btn-sm btn-outline-secondary" href="#admin-setup">Setup</a>
    <a class="btn btn-sm btn-outline-primary" asp-controller="SystemFiles" asp-action="Index">System files</a>
    <a class="btn btn-sm btn-outline-primary" asp-controller="Profiles" asp-action="Index">Profiles</a>
    <a class="btn btn-sm btn-outline-primary" asp-controller="Profiles" asp-action="Invites">Invites</a>
    <a class="btn btn-sm btn-outline-primary" asp-controller="GameFiles" asp-action="Index">Game files</a>
    <a class="btn btn-sm btn-outline-primary" asp-controller="Jobs" asp-action="Index">Jobs</a>
</div>


@* ── Stream settings ── *@
<section id="admin-stream-settings" class="mb-4">
    <div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-3">
        <div>
            <div class="text-uppercase text-muted small fw-semibold mb-1">Runtime configuration</div>
            <h2 class="h3 mb-1">Stream settings</h2>
        </div>
        <span class="badge text-bg-light">New sessions only</span>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-controller="Admin" asp-action="SaveStreamSettings" method="post" asp-antiforgery="true" class="row g-3">
                <div class="col-md-6 col-xl-3">
                    <label class="form-label" for="streamPreferredVideoTransport">Video transport</label>
                    <select class="form-select" id="streamPreferredVideoTransport" name="PreferredVideoTransport">
                        <option value="webrtc-track" selected="@(Model.StreamSettings.PreferredVideoTransport == "webrtc-track")">WebRTC media track (VP8)</option>
                        <option value="webrtc" selected="@(Model.StreamSettings.PreferredVideoTransport == "webrtc")">WebRTC data channel</option>
                        <option value="websocket" selected="@(Model.StreamSettings.PreferredVideoTransport == "websocket")">WebSocket frames</option>
                    </select>
                </div>
                <div class="col-12 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">Save stream settings</button>
                </div>
            </form>
        </div>
    </div>
</section>

@* ── Game art ── *@
<section id="admin-game-art" class="mb-4">
    <div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-3">
        <div>
            <div class="text-uppercase text-muted small fw-semibold mb-1">Library media</div>
            <h2 class="h3 mb-1">Game art</h2>
            <div class="text-muted">@Model.GamesWithCoverArtCount covers · @Model.GamesWithScreenshotArtCount screenshots · @Model.GamesMissingArtCount missing</div>
        </div>
        @if (Model.GameArtErrorCount > 0)
        {
            <span class="badge text-bg-warning">@Model.GameArtErrorCount errors</span>
        }
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <h3 class="h5 mb-1">Backfill art</h3>
                    <div class="text-muted">Downloads matching libretro thumbnail art into local storage.</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <form asp-controller="Admin" asp-action="BackfillGameArt" method="post" asp-antiforgery="true" class="d-flex gap-2 align-items-center">
                        <input type="number" class="form-control form-control-sm" name="limit" value="100" min="1" max="500" style="width: 6rem;" aria-label="Limit" />
                        <button type="submit" class="btn btn-sm btn-primary">Backfill</button>
                    </form>
                    <form asp-controller="Admin" asp-action="BackfillGameArt" method="post" asp-antiforgery="true">
                        <input type="hidden" name="force" value="true" />
                        <input type="hidden" name="limit" value="100" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Force 100</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── Nosebleed process survey ── *@
<section id="admin-nosebleed-runtime" class="mb-4">
    <div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-3">
        <div>
            <div class="text-uppercase text-muted small fw-semibold mb-1">Runtime operations</div>
            <h2 class="h3 mb-1">Nosebleed process survey</h2>
            <div class="text-muted">@Model.NosebleedRuntimeProcesses.Count running</div>
        </div>
    </div>

    @if (Model.NosebleedRuntimeProcesses.Count == 0)
    {
        <div class="alert alert-secondary mb-0">No Nosebleed processes are running right now.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">PID</th>
                            <th scope="col">Session</th>
                            <th scope="col">Game</th>
                            <th scope="col">User</th>
                            <th scope="col">Kind</th>
                            <th scope="col">Port</th>
                            <th scope="col">Runtime</th>
                            <th scope="col">CPU / Mem</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var process in Model.NosebleedRuntimeProcesses)
                        {
                            <tr>
                                <td class="font-monospace">@process.ProcessId</td>
                                <td>
                                    <div class="font-monospace small">@ShortId(process.SessionId)</div>
                                    @if (!string.IsNullOrWhiteSpace(process.RoomCode))
                                    {
                                        <div class="small text-muted">Room @process.RoomCode</div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(process.ArcadeCabinetName) ? (process.GameName ?? "Unknown game") : process.ArcadeCabinetName)</div>
                                    @if (!string.IsNullOrWhiteSpace(process.ArcadeCabinetName) && !string.IsNullOrWhiteSpace(process.GameName))
                                    {
                                        <div class="small text-muted">@process.GameName</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(process.ContentPath))
                                    {
                                        <div class="small text-muted text-truncate" style="max-width: 24rem;" title="@process.ContentPath">@process.ContentPath</div>
                                    }
                                </td>
                                <td>@process.UserLabel</td>
                                <td><span class="badge @(process.IsManaged ? "text-bg-primary" : "text-bg-warning")">@process.SessionKind</span></td>
                                <td>@(process.Port?.ToString() ?? "—")</td>
                                <td>@(process.Runtime is null ? "—" : FormatDuration(process.Runtime.Value))</td>
                                <td>
                                    <div>@(process.AverageCpuPercent is null ? "—" : $"{process.AverageCpuPercent:0.0}%")</div>
                                    <div class="small text-muted">@(process.WorkingSetBytes is null ? "—" : FormatBytes(process.WorkingSetBytes.Value))</div>
                                </td>
                                <td class="text-end">
                                    @if (process.IsManaged)
                                    {
                                        <form asp-controller="Home" asp-action="StopNosebleedSession" method="post" asp-antiforgery="true" class="d-inline">
                                            <input type="hidden" name="sessionId" value="@process.SessionId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Terminate</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-controller="Home" asp-action="KillNosebleedProcess" method="post" asp-antiforgery="true" class="d-inline">
                                            <input type="hidden" name="pid" value="@process.ProcessId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Terminate</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>

@* ── System files ── *@
<section id="admin-setup" class="mb-4">
    <div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-3">
        <div>
            <div class="text-uppercase text-muted small fw-semibold mb-1">System</div>
            <h2 class="h3 mb-1">System files</h2>
            <div class="text-muted">@Model.SystemFilesCount files</div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <h2 class="h5 mb-2">BIOS and other required files</h2>
                    @if (Model.LibretroDatabaseInstalled)
                    {
                        <div class="small text-muted">
                            Missing: <span class="fw-semibold">@((Model.MissingSystemFilesCount ?? 0).ToString())</span>
                        </div>
                    }
                </div>
                <a class="btn btn-sm btn-primary" asp-controller="SystemFiles" asp-action="Create">Add system file</a>
            </div>
            @if (!Model.LibretroDatabaseInstalled)
            {
                <div class="mt-2 small text-muted">Sync libretro-database below to see what's missing.</div>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <h2 class="h5 mb-1">Sync libretro-database</h2>
                    <div class="text-muted">
                        Downloads and extracts libretro DAT + metadata so imports can match ROMs by CRC.
                    </div>
                </div>
                <div class="text-end">
                    @if (Model.LibretroDatabaseInstalled)
                    {
                        <span class="badge text-bg-success">Installed</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">Not installed</span>
                    }
                </div>
            </div>

            <div class="mt-3 d-flex gap-2 flex-wrap">
                <form asp-controller="Home" asp-action="StartLibretroSync" method="post" asp-antiforgery="true">
                    <button type="submit" class="btn btn-primary">Sync</button>
                </form>
                <form asp-controller="Home" asp-action="StartLibretroSync" method="post" asp-antiforgery="true">
                    <input type="hidden" name="force" value="true" />
                    <button type="submit" class="btn btn-outline-danger">Force re-sync</button>
                </form>
                <form asp-controller="Admin" asp-action="RunValidation" method="post" asp-antiforgery="true">
                    <button type="submit" class="btn btn-outline-primary">Validate cores + system files</button>
                </form>
            </div>
        </div>
    </div>
</section>
