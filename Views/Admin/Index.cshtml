@model games_vault.Models.ViewModels.AdminIndexViewModel

@{
    ViewData["Title"] = "Admin";
}

@functions {
    private static string FormatDuration(TimeSpan value)
    {
        if (value.TotalDays >= 1) return $"{(int)value.TotalDays}d {value.Hours}h";
        if (value.TotalHours >= 1) return $"{(int)value.TotalHours}h {value.Minutes}m";
        if (value.TotalMinutes >= 1) return $"{(int)value.TotalMinutes}m";
        return $"{Math.Max(0, (int)value.TotalSeconds)}s";
    }

    private static string ShortId(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "—";
        return value.Length <= 18 ? value : value[..18] + "…";
    }

    private static string FormatBytes(long bytes)
    {
        const double MiB = 1024d * 1024d;
        const double GiB = MiB * 1024d;

        return bytes >= GiB
            ? $"{bytes / GiB:0.00} GiB"
            : $"{bytes / MiB:0.0} MiB";
    }
}

<section id="admin-backend-hero" class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4 p-lg-5">
        <div class="text-uppercase text-primary-emphasis small fw-semibold mb-2">Administrative backend</div>
        <h1 class="display-6 mb-3">One place for everything behind the curtain.</h1>
        <p class="lead text-muted mb-0">Use this page for library management, imports, profiles, jobs, runtime operations, and system configuration. Playing, watching, and logging in stay on their own surfaces.</p>
    </div>
</section>

<section id="admin-backend-sections" class="row g-3 mb-4">
    <div class="col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
                <div class="text-uppercase small text-muted fw-semibold mb-2">Library</div>
                <h2 class="h5">Games and files</h2>
                <p class="text-muted small">@Model.GamesCount games · @Model.GameFilesCount game files</p>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-sm btn-primary" asp-controller="Games" asp-action="Index">Manage games</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="GameFiles" asp-action="Index">Game files</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
                <div class="text-uppercase small text-muted fw-semibold mb-2">Imports</div>
                <h2 class="h5">Sources and downloads</h2>
                <p class="text-muted small">@Model.NetworkSharesCount network · @Model.LocalFoldersCount local · @Model.WebSourcesCount web</p>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-sm btn-primary" asp-controller="Sources" asp-action="Index">Sources</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Downloads" asp-action="Index">Downloads</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
                <div class="text-uppercase small text-muted fw-semibold mb-2">Runtime</div>
                <h2 class="h5">Jobs and Nosebleed</h2>
                <p class="text-muted small">@Model.JobsQueuedOrRunningCount queued/running jobs · @Model.NosebleedRuntimeProcesses.Count Nosebleed processes</p>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-sm btn-primary" asp-controller="Jobs" asp-action="Index">Jobs</a>
                    <a class="btn btn-sm btn-outline-secondary" href="#admin-stream-settings">Stream settings</a>
                    <a class="btn btn-sm btn-outline-secondary" href="#admin-nosebleed-runtime">Nosebleed survey</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
                <div class="text-uppercase small text-muted fw-semibold mb-2">Profiles</div>
                <h2 class="h5">Users and invites</h2>
                <p class="text-muted small">@Model.ProfilesCount active profiles · @Model.ProfileInviteCodesCount invite codes</p>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-sm btn-primary" asp-controller="Profiles" asp-action="Index">Profiles</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Profiles" asp-action="Invites">Invites</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
                <div class="text-uppercase small text-muted fw-semibold mb-2">System</div>
                <h2 class="h5">BIOS and cores</h2>
                <p class="text-muted small">@Model.SystemFilesCount system files · @Model.CoreMappingsCount core mappings</p>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-sm btn-primary" asp-controller="SystemFiles" asp-action="Index">System files</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="SystemCoreMappings" asp-action="Index">Core mappings</a>
                </div>
            </div>
        </div>
    </div>
</section>

@if (TempData["AdminMessage"] is string adminMessage && !string.IsNullOrWhiteSpace(adminMessage))
{
    <div class="alert alert-success" role="status">@adminMessage</div>
}

<section id="admin-stream-settings" class="mb-4">
    <div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-3">
        <div>
            <div class="text-uppercase text-muted small fw-semibold mb-1">Runtime configuration</div>
            <h2 class="h3 mb-1">Stream settings</h2>
            <div class="text-muted">Choose the default transport for new player pages and the ffmpeg encoder used by new Nosebleed sessions.</div>
        </div>
        <span class="badge text-bg-light">New sessions only</span>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-controller="Admin" asp-action="SaveStreamSettings" method="post" asp-antiforgery="true" class="row g-3">
                <div class="col-md-6 col-xl-3">
                    <label class="form-label" for="streamPreferredVideoTransport">Default video transport</label>
                    <select class="form-select" id="streamPreferredVideoTransport" name="PreferredVideoTransport">
                        <option value="webrtc-track" selected="@(Model.StreamSettings.PreferredVideoTransport == "webrtc-track")">WebRTC media track (VP8)</option>
                        <option value="webrtc" selected="@(Model.StreamSettings.PreferredVideoTransport == "webrtc")">WebRTC data channel</option>
                        <option value="websocket" selected="@(Model.StreamSettings.PreferredVideoTransport == "websocket")">WebSocket frames</option>
                    </select>
                    <div class="form-text">Use WebSocket frames when a box should skip WebRTC encoding and just push raw/JPEG frames.</div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label" for="streamMediaBackend">Media backend</label>
                    <input class="form-control" id="streamMediaBackend" type="text" value="@Model.StreamSettings.MediaBackend" readonly />
                    <div class="form-text">GStreamer is the only media backend supported by Nosebleed.</div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label" for="streamWebSocketCompression">WebSocket frame mode</label>
                    <select class="form-select" id="streamWebSocketCompression" name="WebSocketVideoCompression">
                        <option value="balanced" selected="@(Model.StreamSettings.WebSocketVideoCompression == "balanced")">JPEG balanced</option>
                        <option value="crisp" selected="@(Model.StreamSettings.WebSocketVideoCompression == "crisp")">JPEG crisp</option>
                        <option value="compact" selected="@(Model.StreamSettings.WebSocketVideoCompression == "compact")">JPEG compact</option>
                        <option value="raw" selected="@(Model.StreamSettings.WebSocketVideoCompression == "raw")">Raw frames</option>
                    </select>
                    <div class="form-text">JPEG is lighter on the network; raw avoids JPEG encoding cost.</div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label" for="streamWebRtcVideoEncoder">WebRTC VP8 encoder</label>
                    <input class="form-control" id="streamWebRtcVideoEncoder" name="WebRtcVideoEncoder" value="@Model.StreamSettings.WebRtcVideoEncoder" placeholder="libvpx" />
                    <div class="form-text">Examples: <code>libvpx</code>, <code>vp8_vaapi</code>. Nosebleed currently expects VP8 output.</div>
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label" for="streamFfmpegBinary">ffmpeg binary</label>
                    <input class="form-control" id="streamFfmpegBinary" name="FfmpegBinary" value="@Model.StreamSettings.FfmpegBinary" placeholder="ffmpeg" />
                    <div class="form-text">Override when a server needs a custom ffmpeg build/path.</div>
                </div>
                <div class="col-12">
                    <label class="form-label" for="streamWebRtcVideoEncoderArgs">Extra encoder args</label>
                    <input class="form-control font-monospace" id="streamWebRtcVideoEncoderArgs" name="WebRtcVideoEncoderArgs" value="@Model.StreamSettings.WebRtcVideoEncoderArgs" placeholder="-deadline realtime -cpu-used 8" />
                    <div class="form-text">Passed to <code>NOSEBLEED_WEBRTC_VIDEO_ENCODER_ARGS</code>. Leave blank for Nosebleed defaults. Running sessions must be restarted to pick up encoder/env changes.</div>
                </div>
                <div class="col-12 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary">Save stream settings</button>
                </div>
            </form>
        </div>
    </div>
</section>

<section id="admin-nosebleed-runtime" class="mb-4">
    <div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-3">
        <div>
            <div class="text-uppercase text-muted small fw-semibold mb-1">Runtime operations</div>
            <h2 class="h3 mb-1">Nosebleed process survey</h2>
            <div class="text-muted">Running Nosebleed processes, linked users, and termination controls.</div>
        </div>
        <span class="badge text-bg-light">@Model.NosebleedRuntimeProcesses.Count running</span>
    </div>

    @if (Model.NosebleedRuntimeProcesses.Count == 0)
    {
        <div class="alert alert-secondary mb-0">No Nosebleed processes are running right now.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">PID</th>
                            <th scope="col">Session</th>
                            <th scope="col">Game</th>
                            <th scope="col">User</th>
                            <th scope="col">Kind</th>
                            <th scope="col">Port</th>
                            <th scope="col">Runtime</th>
                            <th scope="col">CPU / Mem</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var process in Model.NosebleedRuntimeProcesses)
                        {
                            <tr>
                                <td class="font-monospace">@process.ProcessId</td>
                                <td>
                                    <div class="font-monospace small">@ShortId(process.SessionId)</div>
                                    @if (!string.IsNullOrWhiteSpace(process.RoomCode))
                                    {
                                        <div class="small text-muted">Room @process.RoomCode</div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(process.ArcadeCabinetName) ? (process.GameName ?? "Unknown game") : process.ArcadeCabinetName)</div>
                                    @if (!string.IsNullOrWhiteSpace(process.ArcadeCabinetName) && !string.IsNullOrWhiteSpace(process.GameName))
                                    {
                                        <div class="small text-muted">@process.GameName</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(process.ContentPath))
                                    {
                                        <div class="small text-muted text-truncate" style="max-width: 24rem;" title="@process.ContentPath">@process.ContentPath</div>
                                    }
                                </td>
                                <td>@process.UserLabel</td>
                                <td><span class="badge @(process.IsManaged ? "text-bg-primary" : "text-bg-warning")">@process.SessionKind</span></td>
                                <td>@(process.Port?.ToString() ?? "—")</td>
                                <td>@(process.Runtime is null ? "—" : FormatDuration(process.Runtime.Value))</td>
                                <td>
                                    <div>@(process.AverageCpuPercent is null ? "—" : $"{process.AverageCpuPercent:0.0}%")</div>
                                    <div class="small text-muted">@(process.WorkingSetBytes is null ? "—" : FormatBytes(process.WorkingSetBytes.Value))</div>
                                </td>
                                <td class="text-end">
                                    @if (process.IsManaged)
                                    {
                                        <form asp-controller="Home" asp-action="StopNosebleedSession" method="post" asp-antiforgery="true" class="d-inline">
                                            <input type="hidden" name="sessionId" value="@process.SessionId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Terminate</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-controller="Home" asp-action="KillNosebleedProcess" method="post" asp-antiforgery="true" class="d-inline">
                                            <input type="hidden" name="pid" value="@process.ProcessId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Terminate</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
