# ═══════════════════════════════════════════════════════════
# Sprite Cloud — gv-web environment template
# Copy to .env.local and fill in your values:
#   cp .env.example .env.local
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
# Postgres connection string (required)
DATABASE_URL=postgresql://sprite-cloud@127.0.0.1:5433/games_vault

# ── Auth ──────────────────────────────────────────────────
# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-random-secret
# Public gateway origin where users connect (required for production)
AUTH_URL=http://localhost:3000
# GitHub OAuth (optional)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# ── ICE / WebRTC (optional, defaults work for LAN) ────────
# Comma-separated STUN URLs (defaults to Google STUN)
# GV_ICE_STUN_URLS=stun:stun.l.google.com:19302
# Comma-separated TURN URLs (needed for NAT traversal)
# GV_ICE_TURN_URLS=
# GV_ICE_TURN_USERNAME=
# GV_ICE_TURN_CREDENTIAL=
# Transport policy: "all" (default), "relay" (TURN-only), "stun" (no TURN)
# GV_ICE_TRANSPORT_POLICY=all

# ── Schema migration (Docker only) ────────────────────────
# Set to 1 to apply Drizzle schema at container startup
# GV_WEB_SCHEMA_PUSH_ON_START=1
