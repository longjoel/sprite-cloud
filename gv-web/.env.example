# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=***

# GitHub OAuth (create at https://github.com/settings/developers)
AUTH_GITHUB_ID=***
AUTH_GITHUB_SECRET=***

# PostgreSQL
DATABASE_URL=postgresql://localhost:5432/games_vault

# Dev dashboard — API key for the paired dev server (see /dev)
SERVER_API_KEY=***

# ── ICE configuration (browser side) ──────────────────────────────────

# Comma-separated STUN server URLs for browser WebRTC.
# Default (when empty): stun:stun.l.google.com:19302
GV_ICE_STUN_URLS=

# Comma-separated TURN server URLs for browser WebRTC relay.
# VPS TURN relay: turn:72.62.243.69:3478?transport=udp
GV_ICE_TURN_URLS=

# TURN authentication credentials.
# VPS TURN credentials (user: nosebleed)
GV_ICE_TURN_USERNAME=
GV_ICE_TURN_CREDENTIAL=

# ICE transport policy: all (default) | relay (forces relay-only)
GV_ICE_TRANSPORT_POLICY=
